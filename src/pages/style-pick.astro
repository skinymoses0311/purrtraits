---
import Layout from "../layouts/Layout.astro";
import { readdirSync } from "node:fs";
import { join } from "node:path";

// Build-time scan of public/samples/styles/ so the client can resolve example
// images by (activity, mood, style) regardless of any trailing suffix on the
// actual filename (e.g. "..._jh799q76ast12y4vhczhd984p185j271").
let styleSamples: string[] = [];
try {
  styleSamples = readdirSync(join(process.cwd(), "public", "samples", "styles"))
    .filter((f) => /\.(jpe?g|png|webp)$/i.test(f))
    .sort();
} catch {
  // Folder doesn't exist yet — ship without examples; tiles fall back to text.
}

// Artists are addressed by a flat slug (e.g. "vangogh.jpg") with no
// activity/mood permutation, so the lookup is a simple basename match.
let artistSamples: string[] = [];
try {
  artistSamples = readdirSync(join(process.cwd(), "public", "samples", "artists"))
    .filter((f) => /\.(jpe?g|png|webp)$/i.test(f))
    .sort();
} catch {
  // Folder doesn't exist yet — operator drops files in post-launch.
}

// Skeleton count matches the 10 real cards so the grid is stable when the
// client replaces them.
const SKELETON_COUNT = 10;
---

<Layout
  title="Pick your styles · Purrtraits"
  description="Choose styles for your portrait."
  noindex
>
  <main class="page container pick">
    <nav class="pick__crumbs" aria-label="Quiz progress">
      <a href="/quiz" class="pick__back">← Back</a>
      <span class="pick__crumbs-dot" aria-hidden="true"></span>
      <span class="pick__crumbs-step">Step 3 of 4</span>
    </nav>

    <header class="pick__header">
      <h1 id="pick-title" class="pick__title">
        We've picked three styles we think suit your pet
      </h1>
      <p class="pick__sub" id="pick-sub">
        Your <strong>3 recommended styles</strong> are highlighted below — tap any to swap it for another.
        The previews show <strong>a different pet as a sample</strong>;
        your portraits will be painted from <span class="pick__pet">your pet</span>'s photos.
      </p>
    </header>

    <div class="pick__rec" role="note">
      <span class="pick__rec-chip">
        ✦ Recommended for <span class="pick__pet">your pet</span>
      </span>
      <span class="pick__rec-text" id="pick-rec-text">
        The first three cards are pre-selected — swap any by tapping a different style.
      </span>
    </div>

    <div class="pick__tabs" role="tablist" aria-label="Picker tabs">
      <button
        class="pick__tab pick__tab--active"
        data-tab="style"
        role="tab"
        aria-selected="true"
        aria-controls="panel-style"
        type="button"
      >Style</button>
      <button
        class="pick__tab"
        data-tab="artist"
        role="tab"
        aria-selected="false"
        aria-controls="panel-artist"
        type="button"
      >Artist</button>
      <button
        class="pick__tab"
        data-tab="artwork"
        role="tab"
        aria-selected="false"
        aria-controls="panel-artwork"
        type="button"
      >Famous Art</button>
    </div>

    <div class="pick__panel" id="panel-style" data-panel="style" role="tabpanel">
      <div class="pick__grid" id="grid-style" role="group" aria-label="Art styles" aria-busy="true">
        {Array.from({ length: SKELETON_COUNT }).map(() => (
          <div class="pcard pcard--skel" aria-hidden="true">
            <div class="pcard__media shimmer"></div>
            <div class="pcard__body">
              <div class="skel-line skel-line--title shimmer"></div>
              <div class="skel-line skel-line--desc shimmer"></div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="pick__panel pick__panel--hidden" id="panel-artist" data-panel="artist" role="tabpanel" hidden>
      <div class="pick__grid" id="grid-artist" role="group" aria-label="Famous artists" aria-busy="true">
        {Array.from({ length: SKELETON_COUNT }).map(() => (
          <div class="pcard pcard--skel" aria-hidden="true">
            <div class="pcard__media shimmer"></div>
            <div class="pcard__body">
              <div class="skel-line skel-line--title shimmer"></div>
              <div class="skel-line skel-line--desc shimmer"></div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="pick__panel pick__panel--hidden" id="panel-artwork" data-panel="artwork" role="tabpanel" hidden>
      <section class="pick__popular" id="popular-section" hidden aria-label="Popular artworks">
        <span
          class="pick__popular-chip"
          title="The most-selected famous artworks across all Purrtraits users"
        >
          <span class="pick__popular-chip-spark" aria-hidden="true">✦</span>
          Popular
        </span>
        <div class="pick__popular-row" id="popular-row"></div>
      </section>
      <div class="pick__chips" id="era-chips" role="group" aria-label="Filter by era">
        <button class="pick__chip pick__chip--active" data-era="all" type="button">All</button>
        <button class="pick__chip" data-era="post-impressionist" type="button">Post-Impressionist</button>
        <button class="pick__chip" data-era="impressionist" type="button">Impressionist</button>
        <button class="pick__chip" data-era="romantic" type="button">Romantic</button>
        <button class="pick__chip" data-era="japanese-woodblock" type="button">Japanese Woodblock</button>
        <button class="pick__chip" data-era="northern-renaissance" type="button">Northern Renaissance</button>
        <button class="pick__chip" data-era="dutch-golden-age" type="button">Dutch Golden Age</button>
        <button class="pick__chip" data-era="symbolist" type="button">Symbolist</button>
        <button class="pick__chip" data-era="art-nouveau" type="button">Art Nouveau</button>
      </div>
      <div class="pick__grid" id="grid-artwork" role="group" aria-label="Famous artworks" aria-busy="true">
        {Array.from({ length: SKELETON_COUNT }).map(() => (
          <div class="pcard pcard--skel" aria-hidden="true">
            <div class="pcard__media shimmer"></div>
            <div class="pcard__body">
              <div class="skel-line skel-line--title shimmer"></div>
              <div class="skel-line skel-line--desc shimmer"></div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="pick__footer">
      <button id="go" class="btn btn--primary btn--lg" disabled>
        Generate my portraits →
      </button>
      <p class="pick__counter" id="counter">Loading your picks…</p>
    </div>

    <script
      type="application/json"
      id="style-sample-manifest"
      is:inline
      set:html={JSON.stringify(styleSamples)}
    />
    <script
      type="application/json"
      id="artist-sample-manifest"
      is:inline
      set:html={JSON.stringify(artistSamples)}
    />
  </main>
</Layout>

<script>
  import { makeClient, getSessionId, requireOrRedirect } from "../lib/client.ts";
  import { isSignedIn } from "../lib/authStorage.ts";
  import { api } from "../../convex/_generated/api.js";
  import { track } from "../lib/analytics.ts";
  import {
    ALL_STYLES,
    STYLE_LABELS,
    STYLE_BLURBS,
    scoreStyles,
    type Style,
  } from "../../convex/styleScoring.ts";
  import {
    ALL_ARTISTS,
    ARTIST_LABELS,
    ARTIST_BLURBS,
    scoreArtists,
    type Artist,
  } from "../../convex/artistScoring.ts";

  type SelKey = Style | Artist;
  type TabKind = "style" | "artist" | "artwork";

  type PickerArtwork = {
    slug: string;
    title: string;
    artist: string;
    year?: string;
    era: string;
    thumbUrl: string;
    placements: { slug: string; label: string }[];
    clickCount: number;
  };

  const client = makeClient();
  const sessionId = getSessionId();

  if (!requireOrRedirect(sessionId, "/upload")) {
    // redirected
  } else {
    const session = await client.query(api.sessions.get, { id: sessionId as any });
    if (!session?.quizAnswers) {
      window.location.href = session?.petPhotoUrls?.length ? "/quiz" : "/upload";
    } else {
      const petName = (session.quizAnswers.name ?? "").trim();
      const petLabel = petName || "your pet";
      const petPossessive = petName ? `${petName}'s` : "your pet's";
      if (petName) {
        document.title = `Pick ${petName}'s styles · Purrtraits`;
      }
      // Substitute pet name into all the places the markup left "your pet" /
      // possessive placeholders.
      document.querySelectorAll<HTMLElement>(".pick__pet").forEach((el) => {
        el.textContent = petLabel;
      });
      const titleEl = document.getElementById("pick-title")!;
      const subEl = document.getElementById("pick-sub")!;
      const recTextEl = document.getElementById("pick-rec-text")!;

      function setHeaderCopy(kind: TabKind) {
        if (kind === "artwork") {
          // Tab 3 has different semantics: pick ONE artwork, system fans out
          // three placements. The "we picked three for you" hook doesn't apply.
          titleEl.textContent = `Place ${petLabel} inside a famous painting`;
          subEl.innerHTML =
            `Pick one artwork. We'll generate <strong>three placements</strong> of ` +
            `${escapeHtml(petLabel)} inside it — different positions in the scene, ` +
            `each painted in the artwork's own style.`;
          recTextEl.textContent =
            `Filter by era or scroll the catalogue. Tap an artwork to choose it.`;
          return;
        }
        const noun = kind === "style" ? "styles" : "artists";
        titleEl.textContent = `We've picked three ${noun} we think suit ${petLabel}`;
        subEl.innerHTML =
          `Your <strong>3 recommended ${noun}</strong> are highlighted below — ` +
          `tap any to swap it for another. The previews show ` +
          `<strong>a different pet as a sample</strong>; your portraits will be ` +
          `painted from ${escapeHtml(petPossessive)} photos.`;
        recTextEl.textContent =
          `The top three ${noun} for ${petLabel} are shown first — tap any to add or swap.`;
      }

      // Prefer the server-side ranking saved on the session; fall back to a
      // fresh client-side score so an older session still gets a sensible
      // pre-selection.
      const ranked: Style[] =
        ((session.rankedStyles as Style[] | undefined)?.filter((s) =>
          (ALL_STYLES as readonly string[]).includes(s),
        ) as Style[] | undefined) ?? scoreStyles(session.quizAnswers);

      // Pad in any styles the saved ranking is missing (e.g. if the spec
      // grew) so we always render all 10.
      const known = new Set<string>(ranked);
      for (const s of ALL_STYLES) if (!known.has(s)) ranked.push(s);

      // Same fallback chain for artists. Older sessions saved before the
      // Artist tab shipped won't have rankedArtists — recompute client-side.
      const rankedArtists: Artist[] =
        ((session.rankedArtists as Artist[] | undefined)?.filter((a) =>
          (ALL_ARTISTS as readonly string[]).includes(a),
        ) as Artist[] | undefined) ?? scoreArtists(session.quizAnswers);

      const knownA = new Set<string>(rankedArtists);
      for (const a of ALL_ARTISTS) if (!knownA.has(a)) rankedArtists.push(a);

      // Selection order matters: if a 4th gets picked we evict the oldest.
      // Default state preserves Tab 1 behaviour — top 3 styles preselected.
      // Tab 2's recommendations are surfaced through grid order only; no
      // artist is selected on initial load.
      const selected: SelKey[] = ranked.slice(0, 3);

      // Tab 3 (Famous Art) selection — separate from the SelKey bucket above
      // because it's single-select, not multi-select. Server-side these two
      // states are mutually exclusive (setSelectedStyles clears the artwork
      // and vice versa); client-side we keep both around so switching tabs
      // doesn't lose the user's progress on the other side.
      let selectedArtwork: string | null =
        ((session as any).selectedArtworkSlug as string | null) ?? null;
      let activeEra: string = "all";
      let artworkCatalog: PickerArtwork[] = [];
      let popularArtworks: PickerArtwork[] = [];
      // Remember the original pre-selected set so we can keep the "Our pick"
      // wording on cards the user kept, and switch to "Selected" on cards
      // they swapped in. Only the initial style pre-selection is captured —
      // any artist the user picks later renders as "Selected".
      const originalPicks = new Set<string>(selected);

      // styles_suggested fires once with the server-side ranking so we can
      // measure how often the user keeps the suggested top 3 vs swaps them.
      track("styles_suggested", {
        top_style_1: ranked[0],
        top_style_2: ranked[1],
        top_style_3: ranked[2],
      });
      // Parallel signal for Tab 2 ranking. Even though no artist is
      // pre-selected, capturing the suggested top 3 lets us measure
      // engagement once the operator turns the Artist tab on.
      track("artists_suggested", {
        top_artist_1: rankedArtists[0],
        top_artist_2: rankedArtists[1],
        top_artist_3: rankedArtists[2],
      });

      const counter = document.getElementById("counter")!;
      const go = document.getElementById("go") as HTMLButtonElement;

      function escapeHtml(s: string) {
        return s.replace(/[&<>"']/g, (c) => ({
          "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
        }[c]!));
      }

      // Build-time manifests of every file in public/samples/{styles,artists}/.
      // Style files match by `${activity}_${mood}_${style}` prefix; artist
      // files match by exact basename (`${artist}.jpg`).
      function readManifest(id: string): string[] {
        const el = document.getElementById(id);
        return el ? JSON.parse(el.textContent || "[]") : [];
      }
      const styleSampleFiles: string[] = readManifest("style-sample-manifest");
      const artistSampleFiles: string[] = readManifest("artist-sample-manifest");

      const quizActivity = session.quizAnswers!.activity;
      const quizMood = session.quizAnswers!.mood;

      function findStyleSample(activity: string, mood: string, style: string): string | null {
        const prefix = `${activity}_${mood}_${style}`;
        const match = styleSampleFiles.find((f) => {
          const base = f.replace(/\.[^.]+$/, "");
          return base === prefix || base.startsWith(prefix + "_");
        });
        return match ? `/samples/styles/${match}` : null;
      }

      function findArtistSample(artist: Artist): string | null {
        const match = artistSampleFiles.find(
          (f) => f.replace(/\.[^.]+$/, "") === artist,
        );
        return match ? `/samples/artists/${match}` : null;
      }

      function isStyleKey(key: SelKey): key is Style {
        return (ALL_STYLES as readonly string[]).includes(key);
      }

      function getMeta(key: SelKey): { label: string; blurb: string; kind: TabKind } {
        if (isStyleKey(key)) {
          return { label: STYLE_LABELS[key], blurb: STYLE_BLURBS[key], kind: "style" };
        }
        return {
          label: ARTIST_LABELS[key as Artist],
          blurb: ARTIST_BLURBS[key as Artist],
          kind: "artist",
        };
      }

      function sampleImg(key: SelKey, label: string): string {
        let src: string | null;
        if (isStyleKey(key)) {
          // Try the user's (activity, mood); fall back to adventuring_playful
          // (the only pair currently generated for every style). If neither
          // file exists, omit the image and the card shows the placeholder bg.
          const personalised = findStyleSample(quizActivity, quizMood, key);
          const fallback =
            quizActivity === "adventuring" && quizMood === "playful"
              ? null
              : findStyleSample("adventuring", "playful", key);
          src = personalised ?? fallback;
        } else {
          src = findArtistSample(key as Artist);
        }
        if (!src) return "";
        return `<img class="pcard__media-img" src="${src}"
                     alt="${escapeHtml(label)} example on another pet"
                     loading="lazy">`;
      }

      function cardHtml(key: SelKey): string {
        const isSel = selected.includes(key);
        const selIdx = isSel ? selected.indexOf(key) + 1 : 0;
        const wasOriginal = originalPicks.has(key);
        const pickLabel = wasOriginal ? "Our pick" : "Selected";
        const meta = getMeta(key);
        const sampleBadge = `<span class="pcard__sample-badge">Sample · not ${escapeHtml(petLabel)}</span>`;
        const topLeft = isSel
          ? `<span class="pcard__pick">
               <span class="pcard__pick-num">${selIdx}</span>
               <span class="pcard__pick-label">${pickLabel}</span>
             </span>`
          : `<span class="pcard__empty" aria-hidden="true"></span>`;
        const tag = isSel
          ? `<span class="pcard__tag">${pickLabel}</span>`
          : "";
        return `
          <button class="pcard${isSel ? " pcard--selected" : ""}"
                  data-style="${key}"
                  data-kind="${meta.kind}"
                  type="button"
                  aria-pressed="${isSel}">
            <span class="pcard__media">
              ${sampleImg(key, meta.label)}
              ${topLeft}
              ${sampleBadge}
            </span>
            <span class="pcard__body">
              <span class="pcard__title-row">
                <span class="pcard__title">${escapeHtml(meta.label)}</span>
                ${tag}
              </span>
              <span class="pcard__desc">${escapeHtml(meta.blurb)}</span>
            </span>
          </button>`;
      }

      function gridOrder(kind: TabKind): SelKey[] {
        const universe: SelKey[] = kind === "style" ? ranked : rankedArtists;
        const allowed = kind === "style"
          ? (ALL_STYLES as readonly string[])
          : (ALL_ARTISTS as readonly string[]);
        // Selected cards (in selection order) first, but only the ones that
        // belong to this tab. Then everything else in ranked order. Keeps the
        // picks anchored to the top of whichever tab they came from.
        const picksInTab = selected.filter((k) => allowed.includes(k));
        const rest = universe.filter((k) => !picksInTab.includes(k));
        return [...picksInTab, ...rest];
      }

      function renderTab(kind: TabKind) {
        const grid = document.getElementById(`grid-${kind}`)!;
        grid.innerHTML = gridOrder(kind).map(cardHtml).join("");
        grid.removeAttribute("aria-busy");
        grid.querySelectorAll<HTMLButtonElement>(".pcard").forEach((btn) => {
          btn.addEventListener("click", () => toggle(btn.dataset.style as SelKey));
        });
      }

      function renderAllTabs() {
        renderTab("style");
        renderTab("artist");
        renderArtworkTab();
      }

      // Tab 3 — single-artwork picker. State lives in `selectedArtwork` /
      // `activeEra` / `artworkCatalog`; not in the `selected[]` bucket above.
      function artworkCardHtml(a: PickerArtwork, source: "grid" | "popular"): string {
        const isSel = selectedArtwork === a.slug;
        const yearPart = a.year ? `, ${a.year}` : "";
        const eraLabel = ERA_LABELS[a.era] ?? a.era;
        const topLeft = isSel
          ? `<span class="pcard__pick">
               <span class="pcard__pick-num">✓</span>
               <span class="pcard__pick-label">Selected</span>
             </span>`
          : `<span class="pcard__empty" aria-hidden="true"></span>`;
        return `
          <button class="pcard${isSel ? " pcard--selected" : ""}"
                  data-artwork="${a.slug}"
                  data-source="${source}"
                  data-kind="artwork"
                  type="button"
                  aria-pressed="${isSel}">
            <span class="pcard__media">
              <img class="pcard__media-img" src="${a.thumbUrl}"
                   alt="${escapeHtml(a.title)} by ${escapeHtml(a.artist)}"
                   loading="lazy">
              ${topLeft}
              <span class="pcard__era-badge">${escapeHtml(eraLabel)}</span>
            </span>
            <span class="pcard__body">
              <span class="pcard__title-row">
                <span class="pcard__title">${escapeHtml(a.title)}</span>
              </span>
              <span class="pcard__desc">${escapeHtml(a.artist + yearPart)}</span>
            </span>
          </button>`;
      }

      function renderArtworkTab() {
        const grid = document.getElementById("grid-artwork")!;
        if (artworkCatalog.length === 0) {
          // Catalog hasn't loaded yet (or is empty post-seed).
          grid.innerHTML = `<p class="pick__empty">No artworks available yet.</p>`;
          grid.removeAttribute("aria-busy");
        } else {
          const filtered =
            activeEra === "all"
              ? artworkCatalog
              : artworkCatalog.filter((a) => a.era === activeEra);
          grid.innerHTML = filtered.map((a) => artworkCardHtml(a, "grid")).join("");
          grid.removeAttribute("aria-busy");
          grid.querySelectorAll<HTMLButtonElement>(".pcard").forEach((btn) => {
            btn.addEventListener("click", () =>
              toggleArtwork(btn.dataset.artwork!, "grid"),
            );
          });
        }

        const popularSection = document.getElementById("popular-section")!;
        const popularRow = document.getElementById("popular-row")!;
        if (popularArtworks.length === 0) {
          popularSection.hidden = true;
        } else {
          popularSection.hidden = false;
          popularRow.innerHTML = popularArtworks
            .map((a) => artworkCardHtml(a, "popular"))
            .join("");
          popularRow.querySelectorAll<HTMLButtonElement>(".pcard").forEach((btn) => {
            btn.addEventListener("click", () =>
              toggleArtwork(btn.dataset.artwork!, "popular"),
            );
          });
        }
      }

      const ERA_LABELS: Record<string, string> = {
        "post-impressionist": "Post-Impressionist",
        "impressionist": "Impressionist",
        "japanese-woodblock": "Japanese Woodblock",
        "romantic": "Romantic",
        "northern-renaissance": "Northern Renaissance",
        "symbolist": "Symbolist",
        "art-nouveau": "Art Nouveau",
        "dutch-golden-age": "Dutch Golden Age",
        "renaissance": "Renaissance",
      };

      function toggleArtwork(slug: string, source: "grid" | "popular") {
        const wasSelected = selectedArtwork === slug;
        selectedArtwork = wasSelected ? null : slug;
        // Click counter is best-effort; we don't await it so a slow click
        // doesn't gate selection feedback.
        if (!wasSelected) {
          client
            .mutation(api.artworks.incrementClick, { slug })
            .catch(() => { /* noop */ });
        }
        track("artwork_selected", {
          slug,
          source,
          action: wasSelected ? "deselected" : "selected",
        });
        renderArtworkTab();
        updateCounter();
      }

      function updateCounter() {
        if (activeTab === "artwork") {
          if (selectedArtwork) {
            counter.textContent =
              `1 artwork selected — 3 placements ready to generate`;
            go.disabled = false;
          } else {
            counter.textContent = `Pick an artwork to continue`;
            go.disabled = true;
          }
          return;
        }
        const n = selected.length;
        let suffix: string;
        if (n === 3) suffix = "ready to go";
        else if (n === 0) suffix = "pick three to continue";
        else suffix = `pick ${3 - n} more`;
        counter.textContent = `${n}/3 selected — ${suffix}`;
        go.disabled = n !== 3;
      }

      function toggle(key: SelKey) {
        const idx = selected.indexOf(key);
        const wasSelected = idx >= 0;
        if (wasSelected) {
          // Tapping a selected card deselects it.
          selected.splice(idx, 1);
        } else {
          if (selected.length >= 3) {
            // Evict the oldest selection so the new one fits.
            selected.shift();
          }
          selected.push(key);
        }
        const kind: TabKind = isStyleKey(key) ? "style" : "artist";
        track("style_toggled", {
          style: key,
          kind,
          action: wasSelected ? "deselected" : "selected",
        });
        renderAllTabs();
        updateCounter();
      }

      // Tab switching. Both panels are kept rendered; we just toggle which
      // is visible so switching is instant.
      let activeTab: TabKind = "style";
      setHeaderCopy(activeTab);
      document.querySelectorAll<HTMLButtonElement>(".pick__tab").forEach((tab) => {
        tab.addEventListener("click", () => {
          const target = tab.dataset.tab as TabKind;
          if (target === activeTab) return;
          activeTab = target;
          document.querySelectorAll<HTMLButtonElement>(".pick__tab").forEach((t) => {
            const active = t.dataset.tab === target;
            t.classList.toggle("pick__tab--active", active);
            t.setAttribute("aria-selected", active ? "true" : "false");
          });
          document.querySelectorAll<HTMLDivElement>(".pick__panel").forEach((p) => {
            const active = p.dataset.panel === target;
            p.classList.toggle("pick__panel--hidden", !active);
            if (active) p.removeAttribute("hidden");
            else p.setAttribute("hidden", "");
          });
          // Tab 3 surfaces its "Popular" context inline (chip above the
          // carousel), so hide the above-tabs recommended callout there.
          // Tabs 1 & 2 keep it — their pre-selection messaging lives there.
          const recEl = document.querySelector<HTMLDivElement>(".pick__rec");
          if (recEl) recEl.classList.toggle("pick__rec--hidden", target === "artwork");
          setHeaderCopy(target);
          updateCounter();
          track("tab_switched", { to: target });
          if (target === "artwork") {
            // One-shot view event per page load. Used to measure tab-3
            // engagement separately from selection events.
            if (!artworkBrowsedFired) {
              track("artwork_browsed", {});
              artworkBrowsedFired = true;
            }
          }
        });
      });

      let artworkBrowsedFired = false;

      // Era chips — Tab 3. Filtering is purely client-side (catalog is
      // bounded at 30 entries; no point round-tripping the server).
      document.querySelectorAll<HTMLButtonElement>("#era-chips .pick__chip").forEach((chip) => {
        chip.addEventListener("click", () => {
          const era = chip.dataset.era ?? "all";
          if (era === activeEra) return;
          activeEra = era;
          document.querySelectorAll<HTMLButtonElement>("#era-chips .pick__chip").forEach((c) => {
            c.classList.toggle("pick__chip--active", c.dataset.era === era);
          });
          renderArtworkTab();
          if (era !== "all") track("artwork_filtered", { era });
        });
      });

      // Tab 3 catalog — fetched in parallel with the rest of page boot. Uses
      // the picker query (returns thumb URLs only) and the popular query
      // (top 6 by clickCount).
      Promise.all([
        client.query(api.artworks.listForPicker, {}),
        client.query(api.artworks.popularForPicker, {}),
      ])
        .then(([list, popular]) => {
          artworkCatalog = (list as PickerArtwork[]) ?? [];
          popularArtworks = (popular as PickerArtwork[]) ?? [];
          renderArtworkTab();
        })
        .catch((err) => {
          console.warn("Failed to load artwork catalog:", err);
        });

      renderAllTabs();
      updateCounter();

      go.addEventListener("click", async () => {
        // Branch by active tab. The two server-side mutations are
        // mutually-exclusive on the session so committing one always
        // clears the other — frontend doesn't need a confirmation modal
        // to enforce the contract.
        if (activeTab === "artwork") {
          if (!selectedArtwork) return;
          go.disabled = true;
          const original = go.textContent;
          go.textContent = "Saving…";
          track("artwork_confirmed", { slug: selectedArtwork });
          try {
            await client.mutation(api.sessions.setSelectedArtwork, {
              id: sessionId as any,
              slug: selectedArtwork,
            });
            window.location.href = isSignedIn() ? "/generate" : "/sign-up?next=/generate";
          } catch (err) {
            go.disabled = false;
            go.textContent = original;
            alert("Couldn't save artwork: " + (err as Error).message);
          }
          return;
        }
        if (selected.length !== 3) return;
        go.disabled = true;
        const original = go.textContent;
        go.textContent = "Saving…";
        track("styles_confirmed", {
          style_1: selected[0],
          style_2: selected[1],
          style_3: selected[2],
        });
        try {
          await client.mutation(api.sessions.setSelectedStyles, {
            id: sessionId as any,
            styles: selected,
          });
          // Auth gate: anonymous users sign up / sign in before fal is hit.
          // After auth the React island sends them on to /generate.
          window.location.href = isSignedIn() ? "/generate" : "/sign-up?next=/generate";
        } catch (err) {
          go.disabled = false;
          go.textContent = original;
          alert("Couldn't save styles: " + (err as Error).message);
        }
      });
    }
  }
</script>

