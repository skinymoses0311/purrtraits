---
import Layout from "../layouts/Layout.astro";
import { readdirSync } from "node:fs";
import { join } from "node:path";

// Build-time scan of public/samples/styles/ so the client can resolve example
// images by (activity, mood, style) regardless of any trailing suffix on the
// actual filename (e.g. "..._jh799q76ast12y4vhczhd984p185j271").
let sampleFiles: string[] = [];
try {
  sampleFiles = readdirSync(join(process.cwd(), "public", "samples", "styles"))
    .filter((f) => /\.(jpe?g|png|webp)$/i.test(f))
    .sort();
} catch {
  // Folder doesn't exist yet — ship without examples; tiles fall back to text.
}
---

<Layout
  title="Pick your styles · Purrtraits"
  description="Choose styles for your portrait."
  noindex
>
  <main class="page container pick">
    <nav class="pick__crumbs" aria-label="Quiz progress">
      <a href="/quiz" class="pick__back">← Back</a>
      <span class="pick__crumbs-dot" aria-hidden="true"></span>
      <span class="pick__crumbs-step">Step 3 of 4</span>
    </nav>

    <header class="pick__header">
      <h1 id="pick-title" class="pick__title">
        We've picked three styles we think suit your pet
      </h1>
      <p class="pick__sub" id="pick-sub">
        Your <strong>3 recommended styles</strong> are highlighted below — tap any to swap it for another.
        The previews show <strong>a different pet as a sample</strong>;
        your portraits will be painted from <span class="pick__pet">your pet</span>'s photos.
      </p>
    </header>

    <div class="pick__rec" role="note">
      <span class="pick__rec-chip">
        ✦ Recommended for <span class="pick__pet">your pet</span>
      </span>
      <span class="pick__rec-text">
        The first three cards are pre-selected — swap any by tapping a different style.
      </span>
    </div>

    <div class="pick__grid" id="grid" role="group" aria-label="Art styles"></div>

    <div class="pick__footer">
      <button id="go" class="btn btn--primary btn--lg" disabled>
        Generate my portraits →
      </button>
      <p class="pick__counter" id="counter">0/3 styles selected — pick three to continue</p>
    </div>

    <script
      type="application/json"
      id="sample-manifest"
      is:inline
      set:html={JSON.stringify(sampleFiles)}
    />
  </main>
</Layout>

<script>
  import { makeClient, getSessionId, requireOrRedirect } from "../lib/client.ts";
  import { isSignedIn } from "../lib/authStorage.ts";
  import { api } from "../../convex/_generated/api.js";
  import { track } from "../lib/analytics.ts";
  import {
    ALL_STYLES,
    STYLE_LABELS,
    STYLE_BLURBS,
    scoreStyles,
    type Style,
  } from "../../convex/styleScoring.ts";

  const client = makeClient();
  const sessionId = getSessionId();

  if (!requireOrRedirect(sessionId, "/upload")) {
    // redirected
  } else {
    const session = await client.query(api.sessions.get, { id: sessionId as any });
    if (!session?.quizAnswers) {
      window.location.href = session?.petPhotoUrls?.length ? "/quiz" : "/upload";
    } else {
      const petName = (session.quizAnswers.name ?? "").trim();
      const petLabel = petName || "your pet";
      const petPossessive = petName ? `${petName}'s` : "your pet's";
      if (petName) {
        document.title = `Pick ${petName}'s styles · Purrtraits`;
      }
      // Substitute pet name into all the places the markup left "your pet" /
      // possessive placeholders.
      document.querySelectorAll<HTMLElement>(".pick__pet").forEach((el) => {
        el.textContent = petLabel;
      });
      const titleEl = document.getElementById("pick-title")!;
      titleEl.textContent = `We've picked three styles we think suit ${petLabel}`;
      const subEl = document.getElementById("pick-sub")!;
      // Rebuild subtitle with possessive applied to the photos line.
      subEl.innerHTML =
        `Your <strong>3 recommended styles</strong> are highlighted below — ` +
        `tap any to swap it for another. The previews show ` +
        `<strong>a different pet as a sample</strong>; your portraits will be ` +
        `painted from ${escapeHtml(petPossessive)} photos.`;

      // Prefer the server-side ranking saved on the session; fall back to a
      // fresh client-side score so an older session still gets a sensible
      // pre-selection.
      const ranked: Style[] =
        ((session.rankedStyles as Style[] | undefined)?.filter((s) =>
          (ALL_STYLES as readonly string[]).includes(s),
        ) as Style[] | undefined) ?? scoreStyles(session.quizAnswers);

      // Pad in any styles the saved ranking is missing (e.g. if the spec
      // grew) so we always render all 10.
      const known = new Set<string>(ranked);
      for (const s of ALL_STYLES) if (!known.has(s)) ranked.push(s);

      // Selection order matters: if a 4th gets picked we evict the oldest.
      const selected: Style[] = ranked.slice(0, 3);
      // Remember the original pre-selected set so we can keep the "Our pick"
      // wording on cards the user kept, and switch to "Selected" on cards
      // they swapped in.
      const originalPicks = new Set<string>(selected);

      // styles_suggested fires once with the server-side ranking so we can
      // measure how often the user keeps the suggested top 3 vs swaps them.
      track("styles_suggested", {
        top_style_1: ranked[0],
        top_style_2: ranked[1],
        top_style_3: ranked[2],
      });

      const grid = document.getElementById("grid")!;
      const counter = document.getElementById("counter")!;
      const go = document.getElementById("go") as HTMLButtonElement;

      function escapeHtml(s: string) {
        return s.replace(/[&<>"']/g, (c) => ({
          "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
        }[c]!));
      }

      // Build-time manifest of every file in public/samples/styles/. The
      // picker matches by `${activity}_${mood}_${style}` prefix, so files
      // can carry any trailing session-id suffix (e.g.
      // "adventuring_playful_oil_jh799q76….jpg") and still resolve.
      const manifestEl = document.getElementById("sample-manifest");
      const sampleFiles: string[] = manifestEl
        ? JSON.parse(manifestEl.textContent || "[]")
        : [];

      const quizActivity = session.quizAnswers!.activity;
      const quizMood = session.quizAnswers!.mood;

      function findSample(activity: string, mood: string, style: string): string | null {
        const prefix = `${activity}_${mood}_${style}`;
        const match = sampleFiles.find((f) => {
          const base = f.replace(/\.[^.]+$/, "");
          return base === prefix || base.startsWith(prefix + "_");
        });
        return match ? `/samples/styles/${match}` : null;
      }

      function sampleImg(style: Style, label: string): string {
        // Try the user's (activity, mood); fall back to adventuring_playful
        // (the only pair currently generated for every style). If neither
        // file exists, omit the image and the card shows the placeholder bg.
        const personalised = findSample(quizActivity, quizMood, style);
        const fallback =
          quizActivity === "adventuring" && quizMood === "playful"
            ? null
            : findSample("adventuring", "playful", style);
        const src = personalised ?? fallback;
        if (!src) return "";
        return `<img class="pcard__media-img" src="${src}"
                     alt="${escapeHtml(label)} style example on another pet"
                     loading="lazy">`;
      }

      function cardHtml(s: Style): string {
        const isSel = selected.includes(s);
        const selIdx = isSel ? selected.indexOf(s) + 1 : 0;
        const wasOriginal = originalPicks.has(s);
        const pickLabel = wasOriginal ? "Our pick" : "Selected";
        const label = STYLE_LABELS[s];
        const blurb = STYLE_BLURBS[s];
        const sampleBadge = `<span class="pcard__sample-badge">Sample · not ${escapeHtml(petLabel)}</span>`;
        const topLeft = isSel
          ? `<span class="pcard__pick">
               <span class="pcard__pick-num">${selIdx}</span>
               <span class="pcard__pick-label">${pickLabel}</span>
             </span>`
          : `<span class="pcard__empty" aria-hidden="true"></span>`;
        const tag = isSel
          ? `<span class="pcard__tag">${pickLabel}</span>`
          : "";
        return `
          <button class="pcard${isSel ? " pcard--selected" : ""}"
                  data-style="${s}"
                  type="button"
                  aria-pressed="${isSel}">
            <span class="pcard__media">
              ${sampleImg(s, label)}
              ${topLeft}
              ${sampleBadge}
            </span>
            <span class="pcard__body">
              <span class="pcard__title-row">
                <span class="pcard__title">${escapeHtml(label)}</span>
                ${tag}
              </span>
              <span class="pcard__desc">${escapeHtml(blurb)}</span>
            </span>
          </button>`;
      }

      function gridOrder(): Style[] {
        // Selected cards (in selection order) first, then everything else
        // in the original ranked order. Keeps the picks anchored to slots
        // 1/2/3 so the visual reading matches the "Our pick" badges.
        const picks = selected.slice();
        const rest = ranked.filter((s) => !picks.includes(s));
        return [...picks, ...rest];
      }

      function renderGrid() {
        grid.innerHTML = gridOrder().map(cardHtml).join("");
        grid.querySelectorAll<HTMLButtonElement>(".pcard").forEach((btn) => {
          btn.addEventListener("click", () => toggle(btn.dataset.style as Style));
        });
      }

      function updateCounter() {
        const n = selected.length;
        let suffix: string;
        if (n === 3) suffix = "ready to go";
        else if (n === 0) suffix = "pick three to continue";
        else suffix = `pick ${3 - n} more`;
        counter.textContent = `${n}/3 styles selected — ${suffix}`;
        go.disabled = n !== 3;
      }

      function toggle(style: Style) {
        const idx = selected.indexOf(style);
        const wasSelected = idx >= 0;
        if (wasSelected) {
          // Tapping a selected card deselects it.
          selected.splice(idx, 1);
        } else {
          if (selected.length >= 3) {
            // Evict the oldest selection so the new one fits.
            selected.shift();
          }
          selected.push(style);
        }
        track("style_toggled", {
          style,
          action: wasSelected ? "deselected" : "selected",
        });
        renderGrid();
        updateCounter();
      }

      renderGrid();
      updateCounter();

      go.addEventListener("click", async () => {
        if (selected.length !== 3) return;
        go.disabled = true;
        const original = go.textContent;
        go.textContent = "Saving…";
        track("styles_confirmed", {
          style_1: selected[0],
          style_2: selected[1],
          style_3: selected[2],
        });
        try {
          await client.mutation(api.sessions.setSelectedStyles, {
            id: sessionId as any,
            styles: selected,
          });
          // Auth gate: anonymous users sign up / sign in before fal is hit.
          // After auth the React island sends them on to /generate.
          window.location.href = isSignedIn() ? "/generate" : "/sign-up?next=/generate";
        } catch (err) {
          go.disabled = false;
          go.textContent = original;
          alert("Couldn't save styles: " + (err as Error).message);
        }
      });
    }
  }
</script>

<!--
  Style block is intentionally global. The card markup is rendered
  client-side via innerHTML in the script below, so JS-injected nodes
  never receive Astro's scoping attribute and scoped selectors silently
  fail. All class names here are namespaced (`pick__*`, `pcard__*`) to
  keep the global surface tight.
-->
<style is:global>
  .pick { padding-top: 12px; padding-bottom: 0; }

  /* ── Breadcrumb ───────────────────────────────────────── */
  .pick__crumbs {
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 14px;
  }
  .pick__back {
    font-size: 13px; font-weight: 500;
    color: var(--c-pink);
  }
  .pick__back:hover { text-decoration: underline; }
  .pick__crumbs-dot {
    width: 3px; height: 3px; border-radius: 50%;
    background: var(--c-light);
  }
  .pick__crumbs-step {
    font-size: 11.5px; color: var(--c-light);
    text-transform: uppercase; letter-spacing: 0.8px;
  }

  /* ── Header ───────────────────────────────────────────── */
  .pick__header { margin-bottom: 14px; max-width: 760px; }
  .pick__title {
    font-family: var(--font-display);
    font-size: clamp(26px, 4.5vw, 36px);
    font-weight: 700; line-height: 1.05;
    color: var(--c-dark);
    margin-bottom: 6px;
  }
  .pick__sub {
    font-size: 13.5px; line-height: 1.5;
    color: var(--c-text);
  }
  .pick__sub strong { color: var(--c-dark); font-weight: 600; }
  @media (max-width: 699px) {
    .pick__sub { font-size: 12.5px; }
  }

  /* ── Recommended callout ──────────────────────────────── */
  .pick__rec {
    display: flex; align-items: center; gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .pick__rec-chip {
    flex-shrink: 0;
    padding: 4px 10px; border-radius: var(--r-pill);
    background: var(--c-pink-light);
    border: 1px solid var(--c-pink);
    font-size: 11px; font-weight: 700;
    color: var(--c-pink);
    text-transform: uppercase; letter-spacing: 0.6px;
  }
  .pick__rec-text {
    font-size: 12.5px; color: var(--c-text); line-height: 1.3;
  }
  /* On mobile the design treats the callout as a pink-tinted info box */
  @media (max-width: 699px) {
    .pick__rec {
      padding: 8px 12px; border-radius: var(--r-md);
      background: var(--c-pink-light);
      border: 1px solid var(--c-pink);
      gap: 8px;
    }
    .pick__rec-chip {
      padding: 2px 8px;
      background: var(--c-pink);
      color: var(--c-white);
      border-color: var(--c-pink);
      font-size: 9.5px; letter-spacing: 0.6px;
    }
    .pick__rec-text { font-size: 11.5px; }
  }

  /* ── Grid ────────────────────────────────────────────── */
  .pick__grid {
    display: grid; gap: 14px;
    grid-template-columns: 1fr 1fr;
    margin-bottom: 24px;
  }
  @media (min-width: 700px) { .pick__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1000px) { .pick__grid { grid-template-columns: repeat(5, 1fr); } }

  /* ── Card ────────────────────────────────────────────── */
  .pcard {
    position: relative;
    display: flex; flex-direction: column;
    width: 100%;
    background: var(--c-white);
    border: 1.5px solid var(--c-stroke-light);
    border-radius: 14px;
    overflow: hidden;
    text-align: left;
    font-family: inherit;
    cursor: pointer;
    box-shadow: 0 1px 2px rgba(30, 20, 16, 0.04);
    transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease;
  }
  .pcard:hover { transform: translateY(-1px); border-color: var(--c-stroke); }
  .pcard--selected {
    border: 2.5px solid var(--c-pink);
    box-shadow: 0 6px 18px rgba(217, 139, 168, 0.28);
    transform: translateY(-2px);
  }
  .pcard--selected:hover { transform: translateY(-3px); border-color: var(--c-pink); }
  .pcard:focus-visible {
    outline: 3px solid var(--c-pink);
    outline-offset: 2px;
  }

  .pcard__media {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    background: var(--c-fill);
    overflow: hidden;
  }
  .pcard__media-img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Empty circle (top-left) on unselected cards */
  .pcard__empty {
    position: absolute; top: 10px; left: 10px;
    width: 22px; height: 22px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    border: 1.5px solid var(--c-stroke-light);
  }

  /* "Our pick / Selected" pink pill (top-left) on selected cards */
  .pcard__pick {
    position: absolute; top: 10px; left: 10px;
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 10px 4px 4px;
    border-radius: var(--r-pill);
    background: var(--c-pink);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.18);
  }
  .pcard__pick-num {
    width: 22px; height: 22px; border-radius: 50%;
    background: var(--c-white); color: var(--c-pink);
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700; line-height: 1;
  }
  .pcard__pick-label {
    font-size: 10px; font-weight: 700; color: var(--c-white);
    text-transform: uppercase; letter-spacing: 0.8px; line-height: 1;
  }

  /* "Sample · not <pet>" pill (top-right) */
  .pcard__sample-badge {
    position: absolute; top: 10px; right: 10px;
    background: rgba(30, 20, 16, 0.62);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    color: var(--c-white);
    padding: 3px 8px;
    border-radius: var(--r-pill);
    font-size: 10px; font-weight: 500; line-height: 1.3;
    text-transform: uppercase; letter-spacing: 0.4px;
    pointer-events: none;
  }

  .pcard__body {
    display: block;
    padding: 10px 14px 12px;
  }
  .pcard__title-row {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 6px;
  }
  .pcard__title {
    font-family: var(--font-display);
    font-size: 20px; font-weight: 700; line-height: 1.05;
    color: var(--c-dark);
  }
  .pcard__tag {
    font-size: 10px; font-weight: 700;
    color: var(--c-pink);
    text-transform: uppercase; letter-spacing: 0.5px;
  }
  .pcard__desc {
    display: block;
    font-size: 11.5px; color: var(--c-text); line-height: 1.35;
    margin-top: 2px;
  }

  /* Compact mobile cards: smaller badge, hide blurb + selected tag */
  @media (max-width: 699px) {
    .pcard__sample-badge { font-size: 9px; padding: 3px 7px; }
    .pcard__body { padding: 8px 10px 10px; }
    .pcard__title { font-size: 18px; }
    .pcard__desc { display: none; }
    .pcard__tag { display: none; }
  }

  /* ── Footer CTA strip ─────────────────────────────────── */
  .pick__footer {
    margin: 16px -20px 0;
    padding: 16px 20px 26px;
    display: flex; flex-direction: column; align-items: center; gap: 10px;
    border-top: 1px solid var(--c-stroke-light);
    background: var(--c-fill);
  }
  @media (min-width: 768px) {
    .pick__footer {
      margin-left: -40px;
      margin-right: -40px;
      padding-left: 40px;
      padding-right: 40px;
    }
  }
  .pick__counter {
    font-size: 12px; color: var(--c-light);
    text-align: center;
  }
  .pick__pet { white-space: nowrap; }
</style>
