---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Order confirmed · Purrtraits"
  description="Order confirmation."
  noindex
>
  <!-- Slim green ribbon — full bleed across the viewport, sits flush
       under the nav. Renders before the page container so it can break
       out of the .page padding. -->
  <div class="success-ribbon" id="ribbon">
    <div class="success-ribbon__inner">
      <span class="success-ribbon__check" aria-hidden="true">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
          <path d="M5 12.5l4.5 4.5L19 7.5" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <span class="success-ribbon__text" id="ribbon-text">Confirming your order…</span>
      <span class="success-ribbon__email muted" id="ribbon-email"></span>
    </div>
  </div>

  <main class="page success-page container">
    <!-- Upscaling state — shown after Stripe confirms but before
         fal.upscaleAndFulfil patches printFileHiResUpscaledAt. The
         pulsing-paw loader sits where the portrait will eventually be. -->
    <div class="success-loading" id="upscaling" hidden>
      <div class="success-loading__paw img-loading-wrap is-loading"></div>
      <h1 class="success-loading__title" id="upscaling-title">Upscaling your high-res image…</h1>
      <p class="muted">This usually takes a few seconds.</p>
    </div>

    <!-- Pending — shown if Stripe hasn't confirmed within 60s. -->
    <div class="success-pending" id="pending" hidden>
      <h1 class="success-pending__title">We're still confirming your order.</h1>
      <p class="muted">This can take up to a minute. Refresh the page if it doesn't update.</p>
    </div>

    <!-- Main content — shown once the order is paid + upscaled. -->
    <div class="success" id="success" hidden>
      <div class="success__hero">
        <!-- LEFT — portrait or carousel -->
        <div class="success__portrait">
          <div class="success__carousel" id="carousel">
            <!-- Slides injected by JS -->
          </div>
          <div class="success__carousel-nav" id="carousel-nav" hidden>
            <button type="button" class="carousel-arrow" id="carousel-prev" aria-label="Previous">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="carousel-dots" id="carousel-dots"></div>
            <button type="button" class="carousel-arrow" id="carousel-next" aria-label="Next">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
          <div class="success__caption">
            <div class="success__caption-text">
              <div class="success__caption-name" id="caption-name"></div>
              <div class="success__caption-meta muted" id="caption-meta"></div>
            </div>
            <button type="button" class="success__caption-download btn-pill btn-pill--primary" id="caption-download" hidden>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 4v12m0 0l-4-4m4 4l4-4M5 19h14" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span id="caption-download-label">Download high-res</span>
            </button>
          </div>
        </div>

        <!-- RIGHT — headline + body -->
        <div class="success__body">
          <div class="success__headline">
            <h1 class="success__title" id="title"></h1>
            <p class="success__sub muted" id="sub"></p>
          </div>

          <!-- Status tracker (physical orders only) -->
          <section class="card-soft" id="tracker" hidden>
            <header class="card-soft__head">
              <h2 class="card-soft__title">Where your order is</h2>
              <span class="card-soft__meta muted" id="tracker-eta"></span>
            </header>
            <div class="stepper" id="stepper"></div>
          </section>

          <!-- Downloads list (digital-only orders) -->
          <section class="card-soft" id="downloads" hidden>
            <header class="card-soft__head">
              <h2 class="card-soft__title">Your files</h2>
            </header>
            <div class="file-list" id="file-list"></div>
            <div class="file-note">
              <span aria-hidden="true">📧</span>
              <span class="muted">We've also emailed you the download links.</span>
            </div>
          </section>

          <!-- Bottom row: order meta + (digital: upsell + CTAs / physical: CTAs) -->
          <div class="success__footer">
            <section class="card-soft success__meta">
              <div class="meta-head">
                <span class="meta-eyebrow">Order</span>
                <span class="meta-id" id="meta-id"></span>
              </div>
              <div class="meta-divider"></div>
              <div class="meta-rows" id="meta-rows"></div>
              <div class="meta-receipt">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M3 7l9 6 9-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span id="meta-email" class="muted"></span>
              </div>
            </section>

            <div class="success__actions" id="actions">
              <!-- Print upsell (digital-only) injected here by JS -->
              <a href="/upload" class="btn-pill btn-pill--primary btn-pill--block">Create another portrait →</a>
              <a href="/gallery" class="btn-pill btn-pill--ghost btn-pill--block">View my gallery</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { makeClient, attachImageLoading } from "../lib/client.ts";
  import { api } from "../../convex/_generated/api.js";
  import { track, trackEcommerce } from "../lib/analytics.ts";

  function makeDownloadFilename(petName: string | undefined, style: string | undefined) {
    const slug = (s: string) =>
      s.toLowerCase().trim().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
    const parts = [petName ? slug(petName) : "portrait", style ? slug(style) : ""].filter(Boolean);
    return `${parts.join("-")}.jpg`;
  }

  // Cross-origin downloads need the blob+anchor trick: <a download> is
  // ignored when the href is a different origin (Convex storage URLs are),
  // so the browser navigates instead of saving. Fetch as blob, hand it a
  // local blob URL, click a synthetic anchor.
  async function downloadAsFile(url: string, filename: string): Promise<void> {
    const res = await fetch(url);
    if (!res.ok) throw new Error(`Download fetch failed: ${res.status}`);
    const blob = await res.blob();
    const blobUrl = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = blobUrl;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    a.remove();
    setTimeout(() => URL.revokeObjectURL(blobUrl), 1000);
  }

  function lineToEcommerceItem(it: any) {
    const product = it.product ?? {};
    const sizePart = product.format === "digital" || !product.size ? "" : ` - ${product.size}`;
    const framePart = product.format === "framed" && product.frame ? ` - ${product.frame}` : "";
    return {
      item_id: String(product._id ?? ""),
      item_name: `${product.format ?? ""}${sizePart}${framePart}`,
      item_category: product.format,
      item_variant: product.size,
      item_brand: "Purrtraits",
      price: (product.priceCents ?? 0) / 100,
      quantity: it.quantity,
      portrait_style: it.style,
    };
  }

  const STYLE_LABEL: Record<string, string> = {
    oil: "Oil Painting",
    watercolour: "Watercolour",
    pop: "Pop Art",
  };
  const FORMAT_LABEL: Record<string, string> = {
    digital: "Digital download",
    poster: "Poster",
    framed: "Framed",
    canvas: "Canvas",
  };
  const SIZE_LABEL: Record<string, string> = {
    small: "Small",
    medium: "Medium",
    large: "Large",
  };

  function formatProduct(product: any): string {
    if (!product) return "";
    const fmt = FORMAT_LABEL[product.format] ?? product.format ?? "";
    if (product.format === "digital") return fmt;
    const size = product.size ? SIZE_LABEL[product.size] ?? product.size : "";
    return [fmt, size].filter(Boolean).join(" · ");
  }

  function formatEta(creationTimeMs: number): string {
    const startMs = creationTimeMs + 3 * 24 * 60 * 60 * 1000;
    const endMs = creationTimeMs + 7 * 24 * 60 * 60 * 1000;
    const fmt = new Intl.DateTimeFormat(undefined, { month: "short", day: "numeric" });
    const start = fmt.format(new Date(startMs));
    const end = fmt.format(new Date(endMs));
    return `${start} – ${end}`;
  }

  function currencySymbol(currency: string): string {
    switch (currency.toUpperCase()) {
      case "GBP": return "£";
      case "EUR": return "€";
      default:    return "$";
    }
  }

  const client = makeClient();
  const params = new URLSearchParams(window.location.search);
  const stripeSessionId = params.get("session_id");

  const ribbonText = document.getElementById("ribbon-text")!;
  const ribbonEmail = document.getElementById("ribbon-email")!;
  const upscalingEl = document.getElementById("upscaling")!;
  const pendingEl = document.getElementById("pending")!;
  const successEl = document.getElementById("success")!;

  const ribbonEl = document.getElementById("ribbon")!;

  if (!stripeSessionId) {
    upscalingEl.hidden = true;
    ribbonEl.hidden = true;
    pendingEl.hidden = false;
    pendingEl.querySelector(".success-pending__title")!.textContent = "Hmm, no order found.";
    pendingEl.querySelector("p")!.textContent = "Looks like you came here directly. Try starting a new portrait below.";
  } else {
    // Two-phase wait: first for Stripe to settle (status leaves "pending"),
    // then for fal.upscaleAndFulfil to swap each line's printFileUrl with
    // the 4× upscaled version (signalled by printFileHiResUpscaledAt).
    upscalingEl.hidden = false;
    let attempts = 0;
    let result: any = null;
    let upscalingShown = false;
    while (attempts < 100) {
      result = await client.query(api.orders.getByStripeSession, { stripeSessionId });
      if (result?.order && result.order.status !== "pending") {
        if (result.order.printFileHiResUpscaledAt) break;
        if (!upscalingShown) {
          ribbonText.textContent = "Payment received · Upscaling your image";
          (document.getElementById("upscaling-title")!).textContent = "Upscaling your high-res image…";
          upscalingShown = true;
        }
      }
      attempts++;
      await new Promise((r) => setTimeout(r, 600));
    }

    upscalingEl.hidden = true;

    if (!result?.order || result.order.status === "pending") {
      ribbonEl.hidden = true;
      pendingEl.hidden = false;
    } else {
      renderSuccess(result, stripeSessionId);
    }
  }

  function renderSuccess(result: any, stripeSessionId: string) {
    const { order, lineItems, legacyProduct } = result;

    // Normalize legacy single-product orders into a single line for display.
    const lines: any[] = lineItems && lineItems.length > 0
      ? lineItems
      : legacyProduct
        ? [{ product: legacyProduct, printFileUrl: order.printFileUrl, style: order.selectedStyle, quantity: 1, petName: order.petName }]
        : [];

    const hasPhysical = lines.some((l) => l.product?.format && l.product.format !== "digital");
    const orderPetName = (order.petName as string | undefined)?.trim()
      || lines.find((l) => l.petName)?.petName?.trim();
    const possessive = orderPetName ? `${orderPetName}'s` : "Your";

    if (orderPetName) {
      document.title = `${possessive} Purrtrait · Purrtraits`;
    }

    // Ribbon copy varies by order type; email line shown if known.
    ribbonText.textContent = hasPhysical
      ? "Payment received · Your order is confirmed"
      : "Payment received · Files unlocked instantly";
    if (order.customerEmail) {
      ribbonEmail.innerHTML = `A receipt has been sent to <strong>${order.customerEmail}</strong>`;
    }

    // Headline + sub copy varies by physical vs digital-only.
    const titleEl = document.getElementById("title")!;
    const subEl = document.getElementById("sub")!;
    if (hasPhysical) {
      titleEl.textContent = `${possessive} Purrtrait is on its way 🎨`;
      subEl.textContent = "Your high-res files have been saved to your device, and we've handed the printed pieces to our print partner. We'll email tracking the moment they ship.";
    } else {
      titleEl.textContent = `${possessive} files are ready 🎉`;
      subEl.textContent = "Your high-resolution downloads are saving to your device — we've also emailed you copies. Yours to keep, forever.";
    }

    successEl.hidden = false;

    // ── Carousel: one slide per unique purchased image. Multi-line
    //    orders that bought the same source as both digital + print get
    //    deduped so the user doesn't see the same portrait twice.
    type Slide = {
      url: string;
      printUrl: string;
      petName: string | undefined;
      style: string | undefined;
      formats: string[]; // human-readable format labels for the caption
    };
    const slidesByUrl = new Map<string, Slide>();
    for (const line of lines) {
      const key = line.printFileUrl ?? line.displayUrl;
      if (!key) continue;
      const linePet = (line.petName as string | undefined)?.trim() ?? orderPetName;
      const fmt = formatProduct(line.product);
      if (!slidesByUrl.has(key)) {
        slidesByUrl.set(key, {
          url: line.displayUrl ?? line.printFileUrl,
          printUrl: line.printFileUrl,
          petName: linePet,
          style: line.style,
          formats: fmt ? [fmt] : [],
        });
      } else if (fmt) {
        const existing = slidesByUrl.get(key)!;
        if (!existing.formats.includes(fmt)) existing.formats.push(fmt);
      }
    }
    const slides = Array.from(slidesByUrl.values());

    const carouselEl = document.getElementById("carousel")!;
    const carouselNav = document.getElementById("carousel-nav")!;
    const dotsEl = document.getElementById("carousel-dots")!;
    const captionName = document.getElementById("caption-name")!;
    const captionMeta = document.getElementById("caption-meta")!;
    const captionDownload = document.getElementById("caption-download") as HTMLButtonElement;
    const captionDownloadLabel = document.getElementById("caption-download-label")!;

    slides.forEach((s, i) => {
      const slide = document.createElement("div");
      slide.className = "carousel-slide";
      slide.dataset.index = String(i);
      slide.innerHTML = `
        <div class="img-loading-wrap carousel-slide__wrap is-loading">
          <img class="carousel-slide__img" src="${s.url}" alt="" data-loadable />
        </div>
      `;
      carouselEl.appendChild(slide);

      if (slides.length > 1) {
        const dot = document.createElement("button");
        dot.type = "button";
        dot.className = "carousel-dot";
        dot.setAttribute("aria-label", `Slide ${i + 1}`);
        dot.dataset.index = String(i);
        dot.addEventListener("click", () => goToSlide(i));
        dotsEl.appendChild(dot);
      }
    });
    attachImageLoading(carouselEl);

    let currentSlide = 0;
    function setActive(i: number) {
      currentSlide = i;
      const s = slides[i];
      if (!s) return;
      const styleText = STYLE_LABEL[s.style ?? ""] ?? "Custom";
      captionName.textContent = s.petName ?? "Your portrait";
      captionMeta.textContent = [styleText, ...s.formats].filter(Boolean).join(" · ");
      // Caption download button mirrors the active slide's print URL.
      captionDownload.dataset.url = s.printUrl ?? "";
      captionDownload.dataset.filename = makeDownloadFilename(s.petName, s.style);
      captionDownload.dataset.style = s.style ?? "";
      captionDownloadLabel.textContent = "Download high-res";
      captionDownload.hidden = !s.printUrl;
      // Update dot states.
      dotsEl.querySelectorAll<HTMLButtonElement>(".carousel-dot").forEach((d, di) => {
        d.classList.toggle("is-active", di === i);
      });
    }
    function goToSlide(i: number) {
      const slideEl = carouselEl.children[i] as HTMLElement | undefined;
      if (slideEl) slideEl.scrollIntoView({ behavior: "smooth", block: "nearest", inline: "start" });
      setActive(i);
    }
    if (slides.length > 1) {
      carouselNav.hidden = false;
      document.getElementById("carousel-prev")!.addEventListener("click", () => {
        goToSlide((currentSlide - 1 + slides.length) % slides.length);
      });
      document.getElementById("carousel-next")!.addEventListener("click", () => {
        goToSlide((currentSlide + 1) % slides.length);
      });
      // Keep caption + dots in sync with manual swipe / scroll.
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting && e.intersectionRatio > 0.6) {
            const idx = Number((e.target as HTMLElement).dataset.index);
            if (!Number.isNaN(idx) && idx !== currentSlide) setActive(idx);
          }
        }
      }, { root: carouselEl, threshold: [0.6, 0.9] });
      Array.from(carouselEl.children).forEach((c) => io.observe(c));
    }
    setActive(0);

    captionDownload.addEventListener("click", async () => {
      const url = captionDownload.dataset.url;
      if (!url) return;
      track("download_clicked", {
        format: "high-res-jpg",
        style: captionDownload.dataset.style ?? "",
      });
      try {
        await downloadAsFile(url, captionDownload.dataset.filename ?? "portrait.jpg");
      } catch {
        window.open(url, "_blank");
      }
    });

    // ── Status tracker (physical orders only). Maps order.status to
    //    stepper state per the agreed mapping in PR review.
    if (hasPhysical) {
      const trackerEl = document.getElementById("tracker")!;
      const stepperEl = document.getElementById("stepper")!;
      const etaEl = document.getElementById("tracker-eta")!;
      trackerEl.hidden = false;
      etaEl.textContent = `Estimated arrival · ${formatEta(order._creationTime)}`;

      const status = order.status as string;
      const stageStates: Array<"done" | "active" | "upcoming"> =
        status === "fulfilled"
          ? ["done", "done", "done"]
          : status === "fulfilling"
            ? ["done", "done", "active"]
            : ["done", "active", "upcoming"]; // paid (or anything else after pending)

      const stages = [
        { label: "Digital files ready", sub: "Saved to your device & emailed", icon: "download" },
        { label: "At our print partner", sub: "Printed & quality-checked · 3–5 days", icon: "box" },
        { label: "Shipped to you", sub: "Worldwide tracking by email", icon: "truck" },
      ];
      // Stages and inter-stage connectors are rendered as alternating
      // siblings — same structure as the design's Stage/Connector pair.
      // Layout switches between vertical (mobile) and horizontal (desktop)
      // via CSS only.
      const checkSvg = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12.5l4.5 4.5L19 7.5" stroke="#fff" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
      const iconFor = (icon: string) => icon === "download"
        ? `<svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 4v12m0 0l-4-4m4 4l4-4M5 19h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`
        : icon === "box"
          ? `<svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 3l8 4v10l-8 4-8-4V7l8-4z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M4 7l8 4 8-4M12 11v10" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`
          : `<svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M3 7h11v9H3V7zm11 3h4l3 3v3h-7v-6z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><circle cx="7" cy="18" r="1.8" stroke="currentColor" stroke-width="1.6"/><circle cx="17" cy="18" r="1.8" stroke="currentColor" stroke-width="1.6"/></svg>`;

      stepperEl.innerHTML = stages.flatMap((s, i) => {
        const state = stageStates[i];
        const stageHtml = `
          <div class="stage stage--${state}">
            <div class="stage__dot">${state === "done" ? checkSvg : iconFor(s.icon)}</div>
            <div class="stage__text">
              <div class="stage__label">
                <span>${s.label}</span>
                ${state === "active" ? `<span class="stage__pill">Now</span>` : ""}
              </div>
              <div class="stage__sub">${s.sub}</div>
            </div>
          </div>
        `;
        if (i === stages.length - 1) return [stageHtml];
        const connectorState = stageStates[i] === "done" ? "done" : "upcoming";
        return [stageHtml, `<div class="connector connector--${connectorState}"></div>`];
      }).join("");
    }

    // ── Downloads list (digital-only orders). One row per unique
    //    purchased image. Caption download covers the active carousel
    //    slide; this list lets the user grab any of the others without
    //    swiping.
    if (!hasPhysical) {
      const downloadsEl = document.getElementById("downloads")!;
      const fileListEl = document.getElementById("file-list")!;
      downloadsEl.hidden = false;

      slides.forEach((s, i) => {
        const styleText = STYLE_LABEL[s.style ?? ""] ?? "Custom";
        const label = s.petName ? `${s.petName} · ${styleText}` : styleText;
        const row = document.createElement("div");
        row.className = "file-row" + (i === 0 ? " file-row--primary" : "");
        row.innerHTML = `
          <div class="file-row__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <rect x="3" y="4" width="18" height="16" rx="2" stroke="currentColor" stroke-width="1.6"/>
              <circle cx="9" cy="10" r="1.6" stroke="currentColor" stroke-width="1.6"/>
              <path d="M3 17l5-5 4 4 4-3 5 5" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="file-row__body">
            <div class="file-row__label">${label}</div>
            <div class="file-row__sub">High-res JPG · print quality</div>
          </div>
          <button type="button" class="file-row__btn" data-url="${s.printUrl ?? ""}" data-filename="${makeDownloadFilename(s.petName, s.style)}" data-style="${s.style ?? ""}" aria-label="Download ${label}">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 4v12m0 0l-4-4m4 4l4-4M5 19h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        `;
        fileListEl.appendChild(row);
      });

      fileListEl.querySelectorAll<HTMLButtonElement>(".file-row__btn").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const url = btn.dataset.url;
          if (!url) return;
          track("download_clicked", {
            format: "high-res-jpg",
            style: btn.dataset.style ?? "",
          });
          try {
            await downloadAsFile(url, btn.dataset.filename ?? "portrait.jpg");
          } catch {
            window.open(url, "_blank");
          }
        });
      });

      // Print upsell — links to gallery so the user can revisit and
      // order a print. Inserted before the existing CTA pair.
      const actionsEl = document.getElementById("actions")!;
      const upsell = document.createElement("a");
      upsell.href = "/gallery";
      upsell.className = "print-upsell";
      const symbol = currencySymbol(order.currency ?? "usd");
      upsell.innerHTML = `
        <div class="print-upsell__icon" aria-hidden="true">🖼️</div>
        <div class="print-upsell__body">
          <div class="print-upsell__title">Want ${orderPetName ?? "this"} on your wall?</div>
          <div class="print-upsell__sub muted">Order a museum-quality print from ${symbol}19 — same files, ready to hang.</div>
        </div>
        <div class="print-upsell__arrow" aria-hidden="true">→</div>
      `;
      actionsEl.insertBefore(upsell, actionsEl.firstChild);
    }

    // ── Order meta. ID + per-line list + receipt email.
    const metaIdEl = document.getElementById("meta-id")!;
    const metaRowsEl = document.getElementById("meta-rows")!;
    const metaEmailEl = document.getElementById("meta-email")!;
    metaIdEl.textContent = `#${order._id.slice(-8).toUpperCase()}`;
    metaEmailEl.textContent = order.customerEmail ?? "Receipt sent to your email";
    metaRowsEl.innerHTML = lines.map((line: any) => {
      const styleText = STYLE_LABEL[line.style ?? ""] ?? "Custom";
      const fmt = formatProduct(line.product);
      const linePet = (line.petName as string | undefined)?.trim() ?? orderPetName ?? "Your portrait";
      const right = [styleText, fmt].filter(Boolean).join(" · ");
      const qty = line.quantity > 1 ? ` × ${line.quantity}` : "";
      return `
        <div class="meta-row">
          <span class="meta-row__label">${linePet}${qty}</span>
          <span class="meta-row__value">${right}</span>
        </div>
      `;
    }).join("");

    // ── Auto-download every unique high-res file once per Stripe session.
    //    Guarded by sessionStorage so a refresh / back-button doesn't
    //    trigger the downloads again.
    const downloadFlagKey = `purrtraits.autoDownloaded.${stripeSessionId}`;
    if (!sessionStorage.getItem(downloadFlagKey)) {
      sessionStorage.setItem(downloadFlagKey, "1");
      const seenUrls = new Set<string>();
      const downloads: Array<{ url: string; filename: string }> = [];
      for (const s of slides) {
        if (!s.printUrl || seenUrls.has(s.printUrl)) continue;
        seenUrls.add(s.printUrl);
        downloads.push({
          url: s.printUrl,
          filename: makeDownloadFilename(s.petName, s.style),
        });
      }
      // Sequential to avoid Chrome's "site wants to download multiple files"
      // prompt firing in a way that blocks subsequent saves.
      (async () => {
        for (const d of downloads) {
          try {
            await downloadAsFile(d.url, d.filename);
          } catch {
            // Non-fatal: the manual buttons + email link both still work.
          }
        }
      })();
    }

    // ── purchase analytics — fires once per Stripe session.
    const purchaseFlagKey = `purrtraits.purchaseFired.${stripeSessionId}`;
    try {
      if (!sessionStorage.getItem(purchaseFlagKey)) {
        sessionStorage.setItem(purchaseFlagKey, "1");
        const amountTotalCents = Number(order.amountTotal ?? 0);
        const shippingCents = hasPhysical ? 3000 : 0;
        trackEcommerce("purchase", {
          transaction_id: stripeSessionId,
          value: amountTotalCents / 100,
          shipping: shippingCents / 100,
          currency: (order.currency ?? "usd").toUpperCase(),
          items: lines.map(lineToEcommerceItem),
        });
      }
    } catch {
      // Non-fatal — analytics must never break the success page.
    }
  }
</script>

