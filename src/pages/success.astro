---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Order confirmed · Purrtraits">
  <main class="page container">
    <div class="success">
      <div class="success__check">✓</div>
      <h1 id="title">Your Purrtrait is on its way!</h1>
      <p class="muted" id="sub">We're confirming your order…</p>

      <div class="success__lines" id="lines" hidden></div>

      <div class="success__details" id="details" hidden>
        <p class="display success__details-title">What happens next</p>
        <ol class="steps-list" id="steps-list"></ol>
        <p class="muted" id="meta"></p>
      </div>

      <div class="success__actions">
        <a href="/upload" class="btn btn--primary">Create another portrait →</a>
        <a href="/gallery" class="btn">View my gallery</a>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { makeClient, attachImageLoading } from "../lib/client.ts";
  import { api } from "../../convex/_generated/api.js";
  import { track, trackEcommerce } from "../lib/analytics.ts";

  // Build a friendly download filename from the pet name + style. Falls back
  // to "portrait" when the legacy single-product order shape doesn't carry a
  // pet name. Stripped to a-z0-9-_ to keep Windows/macOS file managers happy.
  function makeDownloadFilename(petName: string | undefined, style: string | undefined) {
    const slug = (s: string) =>
      s.toLowerCase().trim().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
    const parts = [petName ? slug(petName) : "portrait", style ? slug(style) : ""].filter(Boolean);
    return `${parts.join("-")}.jpg`;
  }

  // Cross-origin downloads need the blob+anchor trick: <a download> is
  // ignored when the href is a different origin (Convex storage URLs are),
  // so the browser navigates instead of saving. Fetch as blob, hand it a
  // local blob URL, click a synthetic anchor.
  async function downloadAsFile(url: string, filename: string): Promise<void> {
    const res = await fetch(url);
    if (!res.ok) throw new Error(`Download fetch failed: ${res.status}`);
    const blob = await res.blob();
    const blobUrl = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = blobUrl;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    a.remove();
    // Revoke after a tick so the browser has had time to start the save.
    setTimeout(() => URL.revokeObjectURL(blobUrl), 1000);
  }

  // Map an order line into the GA4 ecommerce item shape. Mirrors the
  // helper in cart.astro so purchase events use the same item_id keys.
  function lineToEcommerceItem(it: any) {
    const product = it.product ?? {};
    const sizePart = product.format === "digital" || !product.size ? "" : ` - ${product.size}`;
    const framePart = product.format === "framed" && product.frame ? ` - ${product.frame}` : "";
    return {
      item_id: String(product._id ?? ""),
      item_name: `${product.format ?? ""}${sizePart}${framePart}`,
      item_category: product.format,
      item_variant: product.size,
      item_brand: "Purrtraits",
      price: (product.priceCents ?? 0) / 100,
      quantity: it.quantity,
      portrait_style: it.style,
    };
  }

  const client = makeClient();
  const params = new URLSearchParams(window.location.search);
  const stripeSessionId = params.get("session_id");

  const title = document.getElementById("title")!;
  const sub = document.getElementById("sub")!;
  const linesEl = document.getElementById("lines")!;
  const details = document.getElementById("details")!;
  const stepsList = document.getElementById("steps-list")!;
  const meta = document.getElementById("meta")!;

  const STYLE_LABEL: Record<string, string> = {
    oil: "Oil Painting",
    watercolour: "Watercolour",
    pop: "Pop Art",
  };
  const FORMAT_LABEL: Record<string, string> = {
    digital: "Digital",
    poster: "Poster",
    framed: "Framed",
    canvas: "Canvas",
  };

  if (!stripeSessionId) {
    title.textContent = "Hmm, no order found.";
    sub.textContent = "Looks like you came here directly. Try starting a new portrait below.";
  } else {
    let attempts = 0;
    let result: any = null;
    while (attempts < 12) {
      result = await client.query(api.orders.getByStripeSession, { stripeSessionId });
      if (result?.order && result.order.status !== "pending") break;
      attempts++;
      await new Promise((r) => setTimeout(r, 600));
    }

    if (!result?.order || result.order.status === "pending") {
      title.textContent = "We're still confirming your order.";
      sub.textContent = "This can take up to a minute. Refresh the page if it doesn't update.";
    } else {
      const { order, lineItems, legacyProduct } = result;

      // Normalize legacy single-product orders into a single line for display.
      const lines: Array<{
        product: any;
        printFileUrl?: string;
        style?: string;
        quantity: number;
      }> = lineItems && lineItems.length > 0
        ? lineItems
        : legacyProduct
          ? [{ product: legacyProduct, printFileUrl: order.printFileUrl, style: order.selectedStyle, quantity: 1 }]
          : [];

      const hasPhysical = lines.some((l) => l.product?.format && l.product.format !== "digital");
      const petName = (order.petName as string | undefined)?.trim()
        || lines.find((l) => l.petName)?.petName?.trim();
      const possessive = petName ? `${petName}'s` : "Your";

      if (petName) {
        document.title = `${possessive} Purrtrait · Purrtraits`;
      }

      // Every paid order now bundles the high-res digital file, so the
      // download messaging applies whether or not a Digital SKU is in the
      // cart. Branches differ only on whether printed pieces are also coming.
      if (hasPhysical) {
        title.textContent = `${possessive} Purrtrait order is confirmed! 🎨`;
        sub.textContent = "Your high-res files are saving to your device; printed pieces are heading to our print partner now.";
      } else {
        title.textContent = `${possessive} Purrtraits are ready! 🎉`;
        sub.textContent = "Your high-resolution downloads are saving to your device — we've also emailed you copies.";
      }

      // Render line items. Every paid line gets a download button — physical
      // orders include the digital file for free, so the experience is the
      // same as a digital-only purchase.
      linesEl.hidden = false;
      linesEl.innerHTML = "";
      lines.forEach((line: any) => {
        const styleText = STYLE_LABEL[line.style ?? ""] ?? "Custom";
        const formatText = FORMAT_LABEL[line.product?.format ?? ""] ?? "";
        const linePetName = (line.petName as string | undefined)?.trim() ?? petName;
        const heading = linePetName
          ? `${linePetName} · ${styleText} · ${formatText}`
          : `${styleText} · ${formatText}`;
        // Thumb uses small display URL when available; download is always the
        // print-quality file so the buyer gets the high-res asset.
        const thumbSrc = line.displayUrl ?? line.printFileUrl;
        const filename = makeDownloadFilename(linePetName, line.style);
        const card = document.createElement("div");
        card.className = "success-line";
        card.innerHTML = `
          ${thumbSrc ? `<div class="img-loading-wrap success-line__thumb is-loading"><img class="success-line__img" src="${thumbSrc}" alt="" data-loadable /></div>` : ""}
          <div class="success-line__body">
            <div class="success-line__title">${heading}</div>
            <div class="success-line__meta muted">Qty ${line.quantity}</div>
            ${line.printFileUrl
              ? `<button type="button" class="btn btn--primary success-line__download" data-url="${line.printFileUrl}" data-filename="${filename}" data-style="${line.style ?? ""}" data-format="${line.product?.format ?? ""}">⬇ Download</button>`
              : ""}
          </div>
        `;
        linesEl.appendChild(card);
      });

      attachImageLoading(linesEl);

      // Manual download: fetch as blob and trigger save. The `<a download>`
      // attribute is ignored cross-origin, so we go through a blob URL to
      // force a save dialog regardless of where the file is hosted.
      linesEl.querySelectorAll<HTMLButtonElement>(".success-line__download").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const url = btn.dataset.url;
          const filename = btn.dataset.filename ?? "portrait.jpg";
          if (!url) return;
          track("download_clicked", {
            format: btn.dataset.format ?? "",
            style: btn.dataset.style ?? "",
          });
          try {
            await downloadAsFile(url, filename);
          } catch {
            // Fallback: open in a new tab so the user still gets at the file.
            window.open(url, "_blank");
          }
        });
      });

      // Auto-download every unique high-res file once per Stripe session.
      // Guarded by sessionStorage so a refresh / back-button doesn't trigger
      // the downloads again.
      const downloadFlagKey = `purrtraits.autoDownloaded.${stripeSessionId}`;
      if (!sessionStorage.getItem(downloadFlagKey)) {
        sessionStorage.setItem(downloadFlagKey, "1");
        const seenUrls = new Set<string>();
        const downloads: Array<{ url: string; filename: string }> = [];
        for (const line of lines as any[]) {
          if (!line.printFileUrl || seenUrls.has(line.printFileUrl)) continue;
          seenUrls.add(line.printFileUrl);
          const linePetName = (line.petName as string | undefined)?.trim() ?? petName;
          downloads.push({
            url: line.printFileUrl,
            filename: makeDownloadFilename(linePetName, line.style),
          });
        }
        // Sequential to avoid Chrome's "site wants to download multiple files"
        // prompt firing in a way that blocks subsequent saves.
        (async () => {
          for (const d of downloads) {
            try {
              await downloadAsFile(d.url, d.filename);
            } catch {
              // Non-fatal: the manual button + email link both still work.
            }
          }
        })();
      }

      // purchase fires once per Stripe session. Guard with sessionStorage so
      // a refresh, back-button, or duplicate render doesn't double-count
      // revenue. Key includes the stripe session id to keep distinct purchases
      // independent within the same browser session.
      const purchaseFlagKey = `purrtraits.purchaseFired.${stripeSessionId}`;
      try {
        if (!sessionStorage.getItem(purchaseFlagKey)) {
          sessionStorage.setItem(purchaseFlagKey, "1");
          // Stripe's amount_total is the grand total in cents — see
          // convex/orders.ts markPaid. Shipping isn't stored separately
          // on the order, so derive it the same way the cart does:
          // a flat $30 when any physical line is present (convex/cart.ts).
          const amountTotalCents = Number(order.amountTotal ?? 0);
          const shippingCents = hasPhysical ? 3000 : 0;
          trackEcommerce("purchase", {
            transaction_id: stripeSessionId,
            value: amountTotalCents / 100,
            shipping: shippingCents / 100,
            currency: (order.currency ?? "usd").toUpperCase(),
            items: lines.map(lineToEcommerceItem),
          });
        }
      } catch {
        // Non-fatal — analytics must never break the success page.
      }

      details.hidden = false;
      const steps = hasPhysical
        ? [
            "Digital files saved to your device (and emailed to you)",
            "Order queued at our print partner — printed and quality-checked (3–5 days)",
            "Shipped worldwide — tracking sent by email",
          ]
        : [
            "Digital files saved to your device (and emailed to you)",
            "Save anywhere you'd like — JPEG, ready to print",
            "Print at home or order a frame separately",
          ];
      stepsList.innerHTML = steps
        .map((s, i) => `<li><span class="num">${i + 1}</span><span>${s}</span></li>`)
        .join("");

      const orderRef = order._id.slice(-8).toUpperCase();
      const lineCount = lines.reduce((n, l) => n + l.quantity, 0);
      meta.textContent = `${lineCount} item${lineCount === 1 ? "" : "s"} · Order #${orderRef}`;
    }
  }
</script>

<style>
  .success {
    max-width: 720px; margin: 0 auto; text-align: center;
    display: flex; flex-direction: column; align-items: center; gap: 16px;
  }
  .success__check {
    width: 80px; height: 80px; border-radius: 50%; background: var(--c-pink);
    color: white; font-size: 38px; display: flex; align-items: center; justify-content: center;
  }
  .success__lines {
    width: 100%;
    display: flex; flex-direction: column; gap: 12px;
  }
  .success-line {
    display: flex; gap: 14px; align-items: center;
    background: var(--c-white); border: 1.5px solid var(--c-stroke-light);
    border-radius: var(--r-md); padding: 14px;
    text-align: left;
  }
  .success-line__thumb {
    width: 96px; height: 96px; flex-shrink: 0;
    border-radius: var(--r-sm); overflow: hidden;
    border: 1px solid var(--c-stroke-light);
  }
  .success-line__img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .success-line__body { flex: 1; display: flex; flex-direction: column; gap: 6px; min-width: 0; }
  .success-line__title { font-weight: 600; color: var(--c-dark); font-size: 15px; }
  .success-line__meta { font-size: 13px; }
  .success-line__download { padding: 8px 16px; font-size: 14px; align-self: flex-start; border-radius: var(--r-sm); }

  .success__details { width: 100%; text-align: left; padding: 16px; }
  .success__details-title { font-size: 20px; margin-bottom: 12px; text-align: center; }
  .steps-list { list-style: none; display: flex; flex-direction: column; gap: 10px; padding: 0; }
  .steps-list li { display: flex; gap: 12px; align-items: flex-start; color: var(--c-text); }
  .success__actions { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
  .num {
    flex-shrink: 0; width: 26px; height: 26px; border-radius: 50%;
    background: var(--c-pink); color: white; display: inline-flex;
    align-items: center; justify-content: center; font-family: var(--font-display); font-weight: 700;
  }
</style>
