---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Order confirmed · Purrtraits">
  <main class="page container">
    <div class="success">
      <div class="success__check">✓</div>
      <h1 id="title">Your Purrtrait is on its way!</h1>
      <p class="muted" id="sub">We're confirming your order…</p>

      <div class="success__lines" id="lines" hidden></div>

      <div class="success__details" id="details" hidden>
        <p class="display success__details-title">What happens next</p>
        <ol class="steps-list" id="steps-list"></ol>
        <p class="muted" id="meta"></p>
      </div>

      <div class="success__actions">
        <a href="/upload" class="btn btn--primary">Create another portrait →</a>
        <a href="/gallery" class="btn">View my gallery</a>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { makeClient, attachImageLoading } from "../lib/client.ts";
  import { api } from "../../convex/_generated/api.js";

  const client = makeClient();
  const params = new URLSearchParams(window.location.search);
  const stripeSessionId = params.get("session_id");

  const title = document.getElementById("title")!;
  const sub = document.getElementById("sub")!;
  const linesEl = document.getElementById("lines")!;
  const details = document.getElementById("details")!;
  const stepsList = document.getElementById("steps-list")!;
  const meta = document.getElementById("meta")!;

  const STYLE_LABEL: Record<string, string> = {
    oil: "Oil Painting",
    watercolour: "Watercolour",
    pop: "Pop Art",
  };
  const FORMAT_LABEL: Record<string, string> = {
    digital: "Digital",
    poster: "Poster",
    framed: "Framed",
    canvas: "Canvas",
  };

  if (!stripeSessionId) {
    title.textContent = "Hmm, no order found.";
    sub.textContent = "Looks like you came here directly. Try starting a new portrait below.";
  } else {
    let attempts = 0;
    let result: any = null;
    while (attempts < 12) {
      result = await client.query(api.orders.getByStripeSession, { stripeSessionId });
      if (result?.order && result.order.status !== "pending") break;
      attempts++;
      await new Promise((r) => setTimeout(r, 600));
    }

    if (!result?.order || result.order.status === "pending") {
      title.textContent = "We're still confirming your order.";
      sub.textContent = "This can take up to a minute. Refresh the page if it doesn't update.";
    } else {
      const { order, lineItems, legacyProduct } = result;

      // Normalize legacy single-product orders into a single line for display.
      const lines: Array<{
        product: any;
        printFileUrl?: string;
        style?: string;
        quantity: number;
      }> = lineItems && lineItems.length > 0
        ? lineItems
        : legacyProduct
          ? [{ product: legacyProduct, printFileUrl: order.printFileUrl, style: order.selectedStyle, quantity: 1 }]
          : [];

      const hasPhysical = lines.some((l) => l.product?.format && l.product.format !== "digital");
      const hasDigital = lines.some((l) => l.product?.format === "digital");
      const petName = (order.petName as string | undefined)?.trim()
        || lines.find((l) => l.petName)?.petName?.trim();
      const possessive = petName ? `${petName}'s` : "Your";

      if (petName) {
        document.title = `${possessive} Purrtrait · Purrtraits`;
      }

      if (hasPhysical && hasDigital) {
        title.textContent = `${possessive} Purrtrait order is confirmed! 🎨`;
        sub.textContent = "Digital downloads are below; printed pieces are heading to our print partner now.";
      } else if (hasPhysical) {
        title.textContent = `${possessive} Purrtraits are being printed! 🎨`;
        sub.textContent = "We've sent your order to our print partner. You'll get tracking by email when it ships.";
      } else {
        title.textContent = `${possessive} Purrtraits are ready! 🎉`;
        sub.textContent = "Your high-resolution downloads are right below — we've also emailed you copies.";
      }

      // Render line items
      linesEl.hidden = false;
      linesEl.innerHTML = "";
      lines.forEach((line: any) => {
        const isDigital = line.product?.format === "digital";
        const styleText = STYLE_LABEL[line.style ?? ""] ?? "Custom";
        const formatText = FORMAT_LABEL[line.product?.format ?? ""] ?? "";
        const linePetName = (line.petName as string | undefined)?.trim() ?? petName;
        const heading = linePetName
          ? `${linePetName} · ${styleText} · ${formatText}`
          : `${styleText} · ${formatText}`;
        // Thumb uses small display URL when available; download is always the
        // print-quality file so the buyer gets the high-res asset.
        const thumbSrc = line.displayUrl ?? line.printFileUrl;
        const card = document.createElement("div");
        card.className = "success-line";
        card.innerHTML = `
          ${thumbSrc ? `<div class="img-loading-wrap success-line__thumb is-loading"><img class="success-line__img" src="${thumbSrc}" alt="" data-loadable /></div>` : ""}
          <div class="success-line__body">
            <div class="success-line__title">${heading}</div>
            <div class="success-line__meta muted">Qty ${line.quantity}</div>
            ${isDigital && line.printFileUrl
              ? `<a class="btn btn--primary success-line__download" href="${line.printFileUrl}" download>⬇ Download</a>`
              : ""}
          </div>
        `;
        linesEl.appendChild(card);
      });

      attachImageLoading(linesEl);

      details.hidden = false;
      const steps = hasPhysical
        ? [
            "Order confirmed and queued at our print partner",
            hasDigital ? "Digital files available immediately above" : "Printed and quality-checked (3–5 days)",
            "Shipped worldwide — tracking sent by email",
          ]
        : [
            "Download links sent to your email",
            "Save the high-res file (JPEG + PDF)",
            "Print at home or order a frame separately",
          ];
      stepsList.innerHTML = steps
        .map((s, i) => `<li><span class="num">${i + 1}</span><span>${s}</span></li>`)
        .join("");

      const orderRef = order._id.slice(-8).toUpperCase();
      const lineCount = lines.reduce((n, l) => n + l.quantity, 0);
      meta.textContent = `${lineCount} item${lineCount === 1 ? "" : "s"} · Order #${orderRef}`;
    }
  }
</script>

<style>
  .success {
    max-width: 720px; margin: 0 auto; text-align: center;
    display: flex; flex-direction: column; align-items: center; gap: 16px;
  }
  .success__check {
    width: 80px; height: 80px; border-radius: 50%; background: var(--c-pink);
    color: white; font-size: 38px; display: flex; align-items: center; justify-content: center;
  }
  .success__lines {
    width: 100%;
    display: flex; flex-direction: column; gap: 12px;
  }
  .success-line {
    display: flex; gap: 14px; align-items: center;
    background: var(--c-white); border: 1.5px solid var(--c-stroke-light);
    border-radius: var(--r-md); padding: 14px;
    text-align: left;
  }
  .success-line__thumb {
    width: 96px; height: 96px; flex-shrink: 0;
    border-radius: var(--r-sm); overflow: hidden;
    border: 1px solid var(--c-stroke-light);
  }
  .success-line__img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .success-line__body { flex: 1; display: flex; flex-direction: column; gap: 6px; min-width: 0; }
  .success-line__title { font-weight: 600; color: var(--c-dark); font-size: 15px; }
  .success-line__meta { font-size: 13px; }
  .success-line__download { padding: 8px 16px; font-size: 14px; align-self: flex-start; border-radius: var(--r-sm); }

  .success__details { width: 100%; text-align: left; padding: 16px; }
  .success__details-title { font-size: 20px; margin-bottom: 12px; text-align: center; }
  .steps-list { list-style: none; display: flex; flex-direction: column; gap: 10px; padding: 0; }
  .steps-list li { display: flex; gap: 12px; align-items: flex-start; color: var(--c-text); }
  .success__actions { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
  .num {
    flex-shrink: 0; width: 26px; height: 26px; border-radius: 50%;
    background: var(--c-pink); color: white; display: inline-flex;
    align-items: center; justify-content: center; font-family: var(--font-display); font-weight: 700;
  }
</style>
