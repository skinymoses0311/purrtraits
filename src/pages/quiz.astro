---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Style quiz · Purrtraits">
  <main class="page container">
    <a href="/upload" class="back-link muted">← Back</a>

    <div class="quiz" id="quiz" data-step="1">
      <div class="quiz__top">
        <div class="progress">
          <div class="progress__track"><div class="progress__fill" id="progress-fill" style="width:14%"></div></div>
          <span class="muted" id="progress-label">1 of 7</span>
        </div>
      </div>

      <div id="quiz-step"></div>

      <div class="quiz__footer">
        <button id="prev" class="btn">← Previous</button>
        <button id="next" class="btn btn--primary" disabled>Next →</button>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { makeClient, getSessionId, requireOrRedirect } from "../lib/client.ts";
  import { api } from "../../convex/_generated/api.js";
  import { DOG_BREEDS } from "../lib/dogBreeds.ts";
  import { track } from "../lib/analytics.ts";

  const client = makeClient();
  const sessionId = getSessionId();
  if (!requireOrRedirect(sessionId, "/upload")) {
    // redirected
  } else {
    // quiz_start fires once per page load. The page is a script-only
    // entry — there's no React re-render to dedupe against — so a single
    // call here is sufficient.
    track("quiz_start");

    const TOTAL_STEPS = 7;

    type AnswerKey = "name" | "breed" | "age" | "lifestyle" | "activity" | "mood" | "room";
    const answers: Partial<Record<AnswerKey, string>> = {};

    const fill = document.getElementById("progress-fill") as HTMLDivElement;
    const label = document.getElementById("progress-label")!;
    const stepEl = document.getElementById("quiz-step")!;
    const next = document.getElementById("next") as HTMLButtonElement;
    const prev = document.getElementById("prev") as HTMLButtonElement;

    let step = 1;

    type ChoiceOption = { v: string; e: string; t: string; b: string };
    type Step =
      | { kind: "name"; key: AnswerKey; title: string; sub: string }
      | { kind: "breed"; key: AnswerKey; title: string; sub: string }
      | { kind: "choices"; key: AnswerKey; title: string; sub: string; options: ChoiceOption[] };

    function petTok() {
      return answers.name?.trim() || "your pet";
    }

    function buildSteps(): Step[] {
      const name = petTok();
      return [
        {
          kind: "name",
          key: "name",
          title: "What's your pet's name?",
          sub: "We'll use it on your portraits and order.",
        },
        {
          kind: "breed",
          key: "breed",
          title: "What breed is your dog?",
          sub: "Start typing — we'll narrow it down. Pick the closest match if it's a mix.",
        },
        {
          kind: "choices",
          key: "age",
          title: `How old is ${name}?`,
          sub: "Roughly is fine.",
          options: [
            { v: "under-1", e: "🐶", t: "Under 1", b: "Puppy energy" },
            { v: "1-3", e: "🦴", t: "1–3", b: "Young & lively" },
            { v: "4-7", e: "🐕", t: "4–7", b: "In their prime" },
            { v: "8-plus", e: "🦮", t: "8+", b: "Distinguished senior" },
          ],
        },
        {
          kind: "choices",
          key: "lifestyle",
          title: `Is ${name} more of a homebody or an adventurer?`,
          sub: "Pick the one that fits most days.",
          options: [
            { v: "homebody", e: "🏡", t: "Homebody", b: "Couch and cuddles" },
            { v: "adventurer", e: "🌲", t: "Adventurer", b: "Outdoors and exploring" },
          ],
        },
        {
          kind: "choices",
          key: "activity",
          title: `What should ${name} be doing?`,
          sub: "Pick a vibe — we'll paint them this way in every style.",
          options: [
            { v: "regal", e: "👑", t: "Sitting regally", b: "Crown-on-head energy" },
            { v: "playing", e: "🎾", t: "Playing with a toy", b: "Mid-zoomies action" },
            { v: "napping", e: "💤", t: "Curled up napping", b: "Soft, cosy, dreaming" },
            { v: "adventuring", e: "🏔️", t: "On an adventure", b: "Outdoors, exploring" },
          ],
        },
        {
          kind: "choices",
          key: "mood",
          title: `What's ${name}'s vibe?`,
          sub: "There are no wrong answers.",
          options: [
            { v: "calm", e: "😌", t: "Calm", b: "Sleepy snuggle expert" },
            { v: "playful", e: "😄", t: "Playful", b: "Permanent zoomies mode" },
            { v: "regal", e: "👑", t: "Regal", b: "Owns the household" },
            { v: "quirky", e: "🤪", t: "Quirky", b: "Has a weird side" },
          ],
        },
        {
          kind: "choices",
          key: "room",
          title: `Where will ${name}'s portrait hang?`,
          sub: "Helps us frame it for the room.",
          options: [
            { v: "living", e: "🛋️", t: "Living room", b: "Statement piece" },
            { v: "bedroom", e: "🛏️", t: "Bedroom", b: "Cosy + personal" },
            { v: "office", e: "💼", t: "Office", b: "Cheer up the desk" },
            { v: "kitchen", e: "🍳", t: "Kitchen", b: "Why not?" },
          ],
        },
      ];
    }

    function renderName(s: Extract<Step, { kind: "name" }>) {
      const value = answers.name ?? "";
      stepEl.innerHTML = `
        <h1>${s.title}</h1>
        <p class="muted quiz__sub">${s.sub}</p>
        <input id="name-input" class="input quiz__name-input" type="text" maxlength="40"
               placeholder="e.g. Bella" autocomplete="off" value="${escapeHtml(value)}" />
      `;
      const input = document.getElementById("name-input") as HTMLInputElement;
      input.focus();
      const sync = () => {
        const v = input.value.trim();
        if (v) answers.name = v;
        else delete answers.name;
        next.disabled = !answers.name;
      };
      sync();
      input.addEventListener("input", sync);
      input.addEventListener("keydown", (e) => {
        if (e.key === "Enter" && !next.disabled) next.click();
      });
    }

    function renderBreed(s: Extract<Step, { kind: "breed" }>) {
      const value = answers.breed ?? "";
      stepEl.innerHTML = `
        <h1>${s.title}</h1>
        <p class="muted quiz__sub">${s.sub}</p>
        <div class="quiz__breed-wrap">
          <input id="breed-input" class="input quiz__breed-input" type="text"
                 placeholder="Start typing a breed…" autocomplete="off" value="${escapeHtml(value)}" />
          <ul id="breed-list" class="quiz__breed-list" hidden></ul>
        </div>
      `;
      const input = document.getElementById("breed-input") as HTMLInputElement;
      const list = document.getElementById("breed-list") as HTMLUListElement;

      function setMatches(query: string) {
        const q = query.trim().toLowerCase();
        if (!q) {
          list.hidden = true;
          list.innerHTML = "";
          return;
        }
        const starts = DOG_BREEDS.filter((b) => b.toLowerCase().startsWith(q));
        const contains = DOG_BREEDS.filter(
          (b) => !b.toLowerCase().startsWith(q) && b.toLowerCase().includes(q),
        );
        const matches = [...starts, ...contains].slice(0, 8);
        if (matches.length === 0) {
          list.hidden = true;
          list.innerHTML = "";
          return;
        }
        list.innerHTML = matches
          .map((b) => `<li class="quiz__breed-opt" data-v="${escapeHtml(b)}">${escapeHtml(b)}</li>`)
          .join("");
        list.hidden = false;
      }

      function pick(breed: string) {
        answers.breed = breed;
        input.value = breed;
        list.hidden = true;
        next.disabled = false;
      }

      function syncFromInput() {
        const v = input.value.trim();
        // Only count as a valid answer when the typed text exactly matches a known breed.
        const match = DOG_BREEDS.find((b) => b.toLowerCase() === v.toLowerCase());
        if (match) {
          answers.breed = match;
          next.disabled = false;
        } else {
          delete answers.breed;
          next.disabled = true;
        }
      }

      input.addEventListener("input", () => {
        setMatches(input.value);
        syncFromInput();
      });
      input.addEventListener("focus", () => setMatches(input.value));
      input.addEventListener("blur", () => {
        // Delay so a click on the list registers before we hide it.
        setTimeout(() => (list.hidden = true), 120);
      });
      input.addEventListener("keydown", (e) => {
        if (e.key === "Enter" && !next.disabled) next.click();
      });
      list.addEventListener("mousedown", (e) => {
        const target = (e.target as HTMLElement).closest<HTMLLIElement>(".quiz__breed-opt");
        if (target?.dataset.v) {
          e.preventDefault();
          pick(target.dataset.v);
        }
      });

      syncFromInput();
      input.focus();
    }

    function renderChoices(s: Extract<Step, { kind: "choices" }>) {
      stepEl.innerHTML = `
        <h1>${s.title}</h1>
        <p class="muted quiz__sub">${s.sub}</p>
        <div class="quiz__grid">
          ${s.options
            .map(
              (o) => `
                <button class="option ${answers[s.key] === o.v ? "option--active" : ""}" data-v="${escapeHtml(o.v)}">
                  <span class="option__emoji">${o.e}</span>
                  <div>
                    <p class="display option__title">${o.t}</p>
                    <p class="muted option__blurb">${o.b}</p>
                  </div>
                </button>`,
            )
            .join("")}
        </div>
      `;
      stepEl.querySelectorAll<HTMLButtonElement>(".option").forEach((btn) => {
        btn.addEventListener("click", () => {
          answers[s.key] = btn.dataset.v!;
          stepEl.querySelectorAll(".option").forEach((el) =>
            el.classList.toggle("option--active", el === btn),
          );
          next.disabled = false;
        });
      });
      next.disabled = !answers[s.key];
    }

    function showStep(n: number) {
      step = n;
      const steps = buildSteps();
      const current = steps[n - 1];
      fill.style.width = `${(n / TOTAL_STEPS) * 100}%`;
      label.textContent = `${n} of ${TOTAL_STEPS}`;
      prev.style.visibility = n === 1 ? "hidden" : "visible";
      next.textContent = n === TOTAL_STEPS ? "Pick your styles →" : "Next →";
      if (current.kind === "name") renderName(current);
      else if (current.kind === "breed") renderBreed(current);
      else renderChoices(current);
    }

    function escapeHtml(s: string) {
      return s.replace(/[&<>"']/g, (c) => ({
        "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
      }[c]!));
    }

    next.addEventListener("click", async () => {
      // Capture the step we're leaving so the event reflects the answer
      // the user just locked in (not the step we're about to render).
      const completedStep = step;
      const completedKey = buildSteps()[completedStep - 1].key;
      const completedAnswer = answers[completedKey];
      if (completedAnswer) {
        track("quiz_step_complete", {
          step_number: completedStep,
          step_name: completedKey,
          answer: completedAnswer,
        });
      }

      if (step < TOTAL_STEPS) {
        showStep(step + 1);
        return;
      }
      // Submit
      next.disabled = true;
      next.textContent = "Saving...";
      track("quiz_complete", {
        activity: answers.activity,
        mood: answers.mood,
        lifestyle: answers.lifestyle,
        room: answers.room,
      });
      await client.mutation(api.sessions.saveQuiz, {
        id: sessionId as any,
        answers: {
          name: answers.name,
          breed: answers.breed,
          age: answers.age,
          lifestyle: answers.lifestyle,
          activity: answers.activity!,
          mood: answers.mood!,
          room: answers.room!,
        },
      });
      window.location.href = "/style-pick";
    });

    prev.addEventListener("click", () => {
      if (step > 1) showStep(step - 1);
    });

    showStep(1);
  }
</script>

<style is:global>
  .back-link { display: inline-block; margin-bottom: 16px; }
  .quiz { max-width: 820px; margin: 0 auto; }
  .quiz__top { margin-bottom: 32px; }
  .quiz h1 { margin-bottom: 6px; }
  .quiz__sub { margin-bottom: 24px; }

  .quiz__grid { display: grid; gap: 12px; grid-template-columns: 1fr; }
  @media (min-width: 600px) { .quiz__grid { grid-template-columns: 1fr 1fr; } }

  .option {
    display: flex; align-items: center; gap: 16px; text-align: left;
    padding: 16px 18px; background: var(--c-white);
    border: 2.5px solid var(--c-stroke-light); border-radius: var(--r-md);
    cursor: pointer; transition: border-color .15s ease, transform .08s ease;
    font-family: inherit; width: 100%;
  }
  .option:hover { border-color: var(--c-stroke); transform: translateY(-1px); }
  .option--active { border-color: var(--c-pink); background: var(--c-pink-light); }
  .option__emoji { font-size: 32px; flex-shrink: 0; }
  .option__title { font-size: 20px; }
  .option__blurb { font-size: 14px; }

  .quiz__name-input { max-width: 420px; font-size: 17px; }

  .quiz__breed-wrap { position: relative; max-width: 420px; }
  .quiz__breed-input { font-size: 17px; }
  .quiz__breed-list {
    position: absolute; left: 0; right: 0; top: calc(100% + 4px);
    list-style: none; padding: 6px;
    background: var(--c-white);
    border: 1.5px solid var(--c-stroke);
    border-radius: var(--r-sm);
    box-shadow: 0 6px 20px rgba(0,0,0,0.08);
    max-height: 280px; overflow-y: auto;
    z-index: 10;
  }
  .quiz__breed-list[hidden] { display: none; }
  .quiz__breed-opt {
    padding: 10px 12px; border-radius: var(--r-sm);
    font-size: 15px; color: var(--c-dark);
    cursor: pointer;
  }
  .quiz__breed-opt:hover { background: var(--c-pink-light); }

  .quiz__footer {
    margin-top: 32px; display: flex; justify-content: space-between; gap: 12px;
  }
</style>
