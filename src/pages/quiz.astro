---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Style quiz · Purrtraits"
  description="Find the right portrait style for your pet."
  noindex
>
  <main class="page container">
    <a href="/upload" class="back-link muted">← Back</a>

    <div class="quiz" id="quiz" data-step="1">
      <div class="quiz__top">
        <div class="progress">
          <div class="progress__track"><div class="progress__fill" id="progress-fill" style="width:11%"></div></div>
          <span class="muted" id="progress-label">1 of 9</span>
        </div>
      </div>

      <div id="quiz-step"></div>

      <div class="quiz__footer">
        <button id="prev" class="btn">← Previous</button>
        <button id="next" class="btn btn--primary" disabled>Next →</button>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { makeClient, getSessionId, requireOrRedirect } from "../lib/client.ts";
  import { api } from "../../convex/_generated/api.js";
  import { DOG_BREEDS } from "../lib/dogBreeds.ts";
  import { track } from "../lib/analytics.ts";

  const client = makeClient();
  const sessionId = getSessionId();
  if (!requireOrRedirect(sessionId, "/upload")) {
    // redirected
  } else {
    // quiz_start fires once per page load. The page is a script-only
    // entry — there's no React re-render to dedupe against — so a single
    // call here is sufficient.
    track("quiz_start");

    const TOTAL_STEPS = 9;
    const MAX_CROSSBREEDS = 4;
    const MIN_CROSSBREEDS = 2;

    type AnswerKey =
      | "name"
      | "breed"
      | "gender"
      | "age"
      | "size"
      | "lifestyle"
      | "activity"
      | "mood"
      | "favouriteFeature";

    type Answers = {
      name?: string;
      // Display string used by PDP/cart/Stripe. For crossbreeds it's the
      // joined form ("Labrador Retriever / Poodle"); for single-breed it's
      // the matched name. Undefined when the user ticks "I'm not sure".
      breed?: string;
      // Structured form, only set in crossbreed mode (length 2..4). Used by
      // the prompt builder to choose the right phrasing.
      breeds?: string[];
      gender?: string;
      age?: string;
      size?: string;
      lifestyle?: string;
      activity?: string;
      mood?: string;
      favouriteFeature?: string;
    };

    // UI-only state — not persisted with the answers.
    type BreedUiState = {
      isCrossbreed: boolean;
      isUnknown: boolean;
    };

    const answers: Answers = {};
    const breedUi: BreedUiState = { isCrossbreed: false, isUnknown: false };

    const fill = document.getElementById("progress-fill") as HTMLDivElement;
    const label = document.getElementById("progress-label")!;
    const stepEl = document.getElementById("quiz-step")!;
    const next = document.getElementById("next") as HTMLButtonElement;
    const prev = document.getElementById("prev") as HTMLButtonElement;

    let step = 1;

    type ChoiceOption = { v: string; e: string; t: string; b: string };
    type Step =
      | { kind: "name"; key: AnswerKey; title: string; sub: string }
      | { kind: "breed"; key: AnswerKey; title: string; sub: string }
      | { kind: "choices"; key: AnswerKey; title: string; sub: string; options: ChoiceOption[] };

    function petTok() {
      return answers.name?.trim() || "your pet";
    }

    function buildSteps(): Step[] {
      const name = petTok();
      return [
        {
          kind: "name",
          key: "name",
          title: "What's your pet's name?",
          sub: "We'll use it on your portraits and order.",
        },
        {
          kind: "breed",
          key: "breed",
          title: `What breed is ${name}?`,
          sub: "Start typing — we'll narrow it down. Pick the closest match if it's a mix.",
        },
        {
          kind: "choices",
          key: "gender",
          title: `Is ${name} a boy or a girl?`,
          sub: "Just so we know.",
          options: [
            { v: "boy", e: "💙", t: "Boy", b: "He / him" },
            { v: "girl", e: "💖", t: "Girl", b: "She / her" },
          ],
        },
        {
          kind: "choices",
          key: "age",
          title: `How old is ${name}?`,
          sub: "Roughly is fine.",
          options: [
            { v: "under-1", e: "🐶", t: "Under 1", b: "Puppy energy" },
            { v: "1-3", e: "🦴", t: "1–3", b: "Young & lively" },
            { v: "4-7", e: "🐕", t: "4–7", b: "In their prime" },
            { v: "8-plus", e: "🦮", t: "8+", b: "Distinguished senior" },
          ],
        },
        {
          kind: "choices",
          key: "size",
          title: `How big is ${name}?`,
          sub: "Roughly — no need to weigh them.",
          options: [
            { v: "xs", e: "🐭", t: "Extra small", b: "Under 4 kg / under 9 lb" },
            { v: "s", e: "🐰", t: "Small", b: "4–9 kg / 9–20 lb" },
            { v: "m", e: "🐕", t: "Medium", b: "9–22 kg / 20–48 lb" },
            { v: "l", e: "🐺", t: "Large", b: "22–40 kg / 48–88 lb" },
            { v: "xl", e: "🐴", t: "Extra large", b: "40 kg+ / 88 lb+" },
          ],
        },
        {
          kind: "choices",
          key: "lifestyle",
          title: `Is ${name} more of a homebody or an adventurer?`,
          sub: "Pick the one that fits most days.",
          options: [
            { v: "homebody", e: "🏡", t: "Homebody", b: "Couch and cuddles" },
            { v: "adventurer", e: "🌲", t: "Adventurer", b: "Outdoors and exploring" },
          ],
        },
        {
          kind: "choices",
          key: "activity",
          title: `What should ${name} be doing?`,
          sub: "Pick a vibe — we'll paint them this way in every style.",
          options: [
            { v: "regal", e: "👑", t: "Sitting regally", b: "Crown-on-head energy" },
            { v: "playing", e: "🎾", t: "Playing with a toy", b: "Toy or ball in mouth" },
            { v: "napping", e: "💤", t: "Curled up napping", b: "Soft, cosy, dreaming" },
            { v: "adventuring", e: "🏔️", t: "On an adventure", b: "Outdoors, exploring" },
            { v: "tongue-out", e: "👅", t: "Tongue out", b: "Full goofball energy" },
            { v: "zoomies", e: "💨", t: "Mid-zoomies", b: "Action shot, running" },
          ],
        },
        {
          kind: "choices",
          key: "mood",
          title: `What's ${name}'s vibe?`,
          sub: "There are no wrong answers.",
          options: [
            { v: "calm", e: "😌", t: "Calm", b: "Sleepy snuggle expert" },
            { v: "playful", e: "😄", t: "Playful", b: "Permanent zoomies mode" },
            { v: "regal", e: "👑", t: "Regal", b: "Owns the household" },
            { v: "quirky", e: "🤪", t: "Quirky", b: "Has a weird side" },
            { v: "cheeky", e: "😏", t: "Cheeky", b: "A bit naughty, knowing side-eye" },
            { v: "brooding", e: "🌙", t: "Brooding", b: "Dramatic, soulful, Heathcliff" },
          ],
        },
        {
          kind: "choices",
          key: "favouriteFeature",
          title: `What do you love most about how ${name} looks?`,
          sub: "We'll lean the portrait into this.",
          options: [
            { v: "eyes", e: "👀", t: "Their eyes", b: "Soulful, expressive" },
            { v: "smile", e: "😁", t: "Their smile / mouth", b: "That happy face" },
            { v: "fur", e: "🧶", t: "Their fur / coat", b: "Markings and texture" },
            { v: "ears", e: "👂", t: "Their ears", b: "The defining frame" },
            { v: "nose", e: "👃", t: "Their nose", b: "The boop-worthy focal point" },
            { v: "whole-vibe", e: "✨", t: "Their whole vibe", b: "All of it, honestly" },
          ],
        },
      ];
    }

    function renderName(s: Extract<Step, { kind: "name" }>) {
      const value = answers.name ?? "";
      stepEl.innerHTML = `
        <h1>${s.title}</h1>
        <p class="muted quiz__sub">${s.sub}</p>
        <input id="name-input" class="input quiz__name-input" type="text" maxlength="40"
               placeholder="e.g. Bella" autocomplete="off" value="${escapeHtml(value)}" />
      `;
      const input = document.getElementById("name-input") as HTMLInputElement;
      input.focus();
      const sync = () => {
        const v = input.value.trim();
        if (v) answers.name = v;
        else delete answers.name;
        next.disabled = !answers.name;
      };
      sync();
      input.addEventListener("input", sync);
      input.addEventListener("keydown", (e) => {
        if (e.key === "Enter" && !next.disabled) next.click();
      });
    }

    // breed step is more involved: it carries two checkboxes (crossbreed +
    // "I'm not sure") below the autocomplete, and the multi-select chips
    // appear in crossbreed mode.
    function renderBreed(s: Extract<Step, { kind: "breed" }>) {
      const singleValue = !breedUi.isCrossbreed && !breedUi.isUnknown
        ? answers.breed ?? ""
        : "";
      stepEl.innerHTML = `
        <h1>${s.title}</h1>
        <p class="muted quiz__sub">${s.sub}</p>
        <div class="quiz__breed-wrap">
          <input id="breed-input" class="input quiz__breed-input" type="text"
                 placeholder="Start typing a breed…" autocomplete="off"
                 value="${escapeHtml(singleValue)}" />
          <ul id="breed-list" class="quiz__breed-list" hidden></ul>
        </div>
        <div id="breed-chips" class="quiz__breed-chips" hidden></div>
        <p id="breed-hint" class="quiz__breed-hint muted" hidden></p>
        <div class="quiz__breed-toggles">
          <label class="option option--toggle">
            <input id="breed-pure" type="radio" name="breed-mode" class="option__checkbox" />
            <span class="option__emoji">🐕</span>
            <div>
              <p class="display option__title">Purebreed</p>
              <p class="muted option__blurb">One specific breed</p>
            </div>
          </label>
          <label class="option option--toggle">
            <input id="breed-cross" type="radio" name="breed-mode" class="option__checkbox" />
            <span class="option__emoji">🐾</span>
            <div>
              <p class="display option__title">Crossbreed</p>
              <p class="muted option__blurb">A mix of breeds</p>
            </div>
          </label>
          <label class="option option--toggle">
            <input id="breed-unknown" type="radio" name="breed-mode" class="option__checkbox" />
            <span class="option__emoji">❓</span>
            <div>
              <p class="display option__title">I'm not sure</p>
              <p class="muted option__blurb">Pick the closest later</p>
            </div>
          </label>
        </div>
      `;

      const input = document.getElementById("breed-input") as HTMLInputElement;
      const list = document.getElementById("breed-list") as HTMLUListElement;
      const chips = document.getElementById("breed-chips") as HTMLDivElement;
      const hint = document.getElementById("breed-hint") as HTMLParagraphElement;
      const pureCb = document.getElementById("breed-pure") as HTMLInputElement;
      const crossCb = document.getElementById("breed-cross") as HTMLInputElement;
      const unknownCb = document.getElementById("breed-unknown") as HTMLInputElement;

      // The mode tiles are a radio group; "purebreed" is the implicit default
      // (no flags set) so a quick boolean derives the initial checked state.
      pureCb.checked = !breedUi.isCrossbreed && !breedUi.isUnknown;
      crossCb.checked = breedUi.isCrossbreed;
      unknownCb.checked = breedUi.isUnknown;

      // Index of the keyboard-highlighted option in the dropdown. -1 means
      // nothing is highlighted, which is the state on first open.
      let activeIndex = -1;

      function listOptions() {
        return Array.from(
          list.querySelectorAll<HTMLLIElement>(".quiz__breed-opt"),
        );
      }

      function setActive(i: number) {
        const opts = listOptions();
        activeIndex = i;
        opts.forEach((el, idx) => {
          el.classList.toggle("is-active", idx === i);
        });
        if (i >= 0 && opts[i]) {
          opts[i].scrollIntoView({ block: "nearest" });
        }
      }

      function showMatches(query: string) {
        const q = query.trim().toLowerCase();
        if (!q) {
          list.hidden = true;
          list.innerHTML = "";
          activeIndex = -1;
          return;
        }
        // In crossbreed mode, hide breeds the user has already picked so the
        // dropdown stays useful.
        const taken = new Set(
          breedUi.isCrossbreed ? answers.breeds ?? [] : [],
        );
        const starts = DOG_BREEDS.filter(
          (b) => !taken.has(b) && b.toLowerCase().startsWith(q),
        );
        const contains = DOG_BREEDS.filter(
          (b) =>
            !taken.has(b) &&
            !b.toLowerCase().startsWith(q) &&
            b.toLowerCase().includes(q),
        );
        const matches = [...starts, ...contains].slice(0, 8);
        if (matches.length === 0) {
          list.hidden = true;
          list.innerHTML = "";
          activeIndex = -1;
          return;
        }
        list.innerHTML = matches
          .map((b) => `<li class="quiz__breed-opt" data-v="${escapeHtml(b)}">${escapeHtml(b)}</li>`)
          .join("");
        list.hidden = false;
        // Re-rendering the options invalidates any prior highlight.
        activeIndex = -1;
      }

      function pickBreed(picked: string) {
        if (breedUi.isCrossbreed) {
          const current = answers.breeds ?? [];
          if (current.includes(picked) || current.length >= MAX_CROSSBREEDS) return;
          answers.breeds = [...current, picked];
          updateBreedDisplayFromBreeds();
          input.value = "";
          list.hidden = true;
          activeIndex = -1;
          renderChips();
          renderHint();
          recomputeNext();
          input.focus();
        } else {
          answers.breed = picked;
          input.value = picked;
          list.hidden = true;
          activeIndex = -1;
          recomputeNext();
        }
      }

      function syncSingle() {
        // In single mode the typed text must exactly match a known breed.
        const v = input.value.trim();
        const match = DOG_BREEDS.find(
          (b) => b.toLowerCase() === v.toLowerCase(),
        );
        if (match) {
          answers.breed = match;
          delete answers.breeds;
        } else {
          delete answers.breed;
          delete answers.breeds;
        }
        recomputeNext();
      }

      function renderChips() {
        const list = answers.breeds ?? [];
        if (!breedUi.isCrossbreed || list.length === 0) {
          chips.hidden = true;
          chips.innerHTML = "";
          return;
        }
        chips.hidden = false;
        chips.innerHTML = list
          .map(
            (b, i) => `
              <span class="chip-tag">
                <span>${escapeHtml(b)}</span>
                <button type="button" class="chip-tag__x" data-i="${i}" aria-label="Remove ${escapeHtml(b)}">×</button>
              </span>`,
          )
          .join("");
      }

      function renderHint() {
        if (breedUi.isUnknown) {
          hint.hidden = true;
          return;
        }
        if (breedUi.isCrossbreed) {
          const n = answers.breeds?.length ?? 0;
          if (n < MIN_CROSSBREEDS) {
            hint.textContent = `Pick ${MIN_CROSSBREEDS - n} more breed${MIN_CROSSBREEDS - n === 1 ? "" : "s"} to continue.`;
            hint.hidden = false;
          } else if (n >= MAX_CROSSBREEDS) {
            hint.textContent = `That's the max — ${MAX_CROSSBREEDS} breeds.`;
            hint.hidden = false;
          } else {
            hint.hidden = true;
          }
          return;
        }
        hint.hidden = true;
      }

      function recomputeNext() {
        if (breedUi.isUnknown) {
          next.disabled = false;
          return;
        }
        if (breedUi.isCrossbreed) {
          const n = answers.breeds?.length ?? 0;
          next.disabled = n < MIN_CROSSBREEDS || n > MAX_CROSSBREEDS;
          return;
        }
        next.disabled = !answers.breed;
      }

      function updateBreedDisplayFromBreeds() {
        // Keep the display string in lockstep with the breeds array. The
        // joined form is what propagates to PDP/cart/Stripe copy.
        if (answers.breeds && answers.breeds.length >= MIN_CROSSBREEDS) {
          answers.breed = answers.breeds.join(" / ");
        } else if (breedUi.isCrossbreed) {
          // Fewer than the minimum — clear the display string too so we
          // don't ship a half-finished value if the user backs out.
          delete answers.breed;
        }
      }

      function applyDisabledState() {
        const disabled = breedUi.isUnknown;
        input.disabled = disabled;
        chips.classList.toggle("is-disabled", disabled);
        // Visually grey the wrap.
        (input.closest(".quiz__breed-wrap") as HTMLElement | null)
          ?.classList.toggle("is-disabled", disabled);
      }

      // ---- Event wiring ----------------------------------------------------

      input.addEventListener("input", () => {
        if (breedUi.isUnknown) return;
        showMatches(input.value);
        if (!breedUi.isCrossbreed) syncSingle();
      });
      input.addEventListener("focus", () => {
        if (breedUi.isUnknown) return;
        showMatches(input.value);
      });
      input.addEventListener("blur", () => {
        // Delay so a click on the list registers before we hide it.
        setTimeout(() => (list.hidden = true), 120);
      });
      input.addEventListener("keydown", (e) => {
        if (breedUi.isUnknown) return;

        if (e.key === "ArrowDown" || e.key === "ArrowUp") {
          // Open the list if it's closed and we have something to show.
          if (list.hidden) showMatches(input.value);
          const opts = listOptions();
          if (opts.length === 0) return;
          e.preventDefault();
          const last = opts.length - 1;
          if (e.key === "ArrowDown") {
            setActive(activeIndex < 0 ? 0 : (activeIndex + 1) % opts.length);
          } else {
            setActive(activeIndex < 0 ? last : (activeIndex - 1 + opts.length) % opts.length);
          }
          return;
        }

        if (e.key === "Escape") {
          if (!list.hidden) {
            e.preventDefault();
            list.hidden = true;
            activeIndex = -1;
          }
          return;
        }

        if (e.key === "Enter") {
          // If a dropdown option is highlighted, Enter selects it.
          const opts = listOptions();
          if (!list.hidden && activeIndex >= 0 && opts[activeIndex]?.dataset.v) {
            e.preventDefault();
            pickBreed(opts[activeIndex].dataset.v!);
            return;
          }
          // Otherwise: in crossbreed mode Enter shouldn't submit the form —
          // only the explicit Next button does. In single mode it's a
          // fast-forward to Next when a breed is already selected.
          if (breedUi.isCrossbreed) {
            e.preventDefault();
            return;
          }
          if (!next.disabled) next.click();
        }
      });

      list.addEventListener("mousedown", (e) => {
        const target = (e.target as HTMLElement).closest<HTMLLIElement>(".quiz__breed-opt");
        if (!target?.dataset.v) return;
        e.preventDefault();
        pickBreed(target.dataset.v);
      });

      chips.addEventListener("click", (e) => {
        const target = (e.target as HTMLElement).closest<HTMLButtonElement>(
          ".chip-tag__x",
        );
        if (!target) return;
        const i = Number(target.dataset.i);
        if (Number.isNaN(i)) return;
        const current = answers.breeds ?? [];
        const next = current.filter((_, idx) => idx !== i);
        if (next.length === 0) delete answers.breeds;
        else answers.breeds = next;
        updateBreedDisplayFromBreeds();
        renderChips();
        renderHint();
        recomputeNext();
      });

      // Single mode-switch handler for the radio group. Radios only fire
      // 'change' on the newly-selected input (not the deselected one), so
      // each handler can assume its own input is now checked.
      function applyMode(mode: "pure" | "cross" | "unknown") {
        breedUi.isCrossbreed = mode === "cross";
        breedUi.isUnknown = mode === "unknown";

        if (mode === "cross") {
          // Switching to crossbreed: seed the breeds array from any single
          // breed already typed so the user doesn't lose their pick, then
          // clear the input ready for the next selection.
          if (answers.breed && !answers.breeds) {
            answers.breeds = [answers.breed];
          }
          input.value = "";
          delete answers.breed;
          updateBreedDisplayFromBreeds();
        } else if (mode === "unknown") {
          // Clear all breed state — nothing flows to the prompt or copy.
          delete answers.breed;
          delete answers.breeds;
          input.value = "";
        } else {
          // Purebreed (default): drop any multi-select state and let the
          // user type / pick a single breed fresh.
          delete answers.breeds;
          delete answers.breed;
          input.value = "";
        }

        list.hidden = true;
        applyDisabledState();
        renderChips();
        renderHint();
        recomputeNext();
      }

      pureCb.addEventListener("change", () => {
        if (pureCb.checked) applyMode("pure");
      });
      crossCb.addEventListener("change", () => {
        if (crossCb.checked) applyMode("cross");
      });
      unknownCb.addEventListener("change", () => {
        if (unknownCb.checked) applyMode("unknown");
      });

      // Initial paint
      applyDisabledState();
      renderChips();
      renderHint();
      // If we returned to this step with an existing single-breed answer,
      // make sure the next button reflects that.
      if (!breedUi.isCrossbreed && !breedUi.isUnknown) syncSingle();
      else recomputeNext();
      if (!breedUi.isUnknown) input.focus();
    }

    function renderChoices(s: Extract<Step, { kind: "choices" }>) {
      const key = s.key;
      stepEl.innerHTML = `
        <h1>${s.title}</h1>
        <p class="muted quiz__sub">${s.sub}</p>
        <div class="quiz__grid">
          ${s.options
            .map(
              (o) => `
                <button class="option ${answers[key as keyof Answers] === o.v ? "option--active" : ""}" data-v="${escapeHtml(o.v)}">
                  <span class="option__emoji">${o.e}</span>
                  <div>
                    <p class="display option__title">${o.t}</p>
                    <p class="muted option__blurb">${o.b}</p>
                  </div>
                </button>`,
            )
            .join("")}
        </div>
      `;
      stepEl.querySelectorAll<HTMLButtonElement>(".option").forEach((btn) => {
        btn.addEventListener("click", () => {
          (answers as Record<string, string>)[key] = btn.dataset.v!;
          stepEl.querySelectorAll(".option").forEach((el) =>
            el.classList.toggle("option--active", el === btn),
          );
          next.disabled = false;
        });
      });
      next.disabled = !answers[key as keyof Answers];
    }

    function showStep(n: number) {
      step = n;
      const steps = buildSteps();
      const current = steps[n - 1];
      fill.style.width = `${(n / TOTAL_STEPS) * 100}%`;
      label.textContent = `${n} of ${TOTAL_STEPS}`;
      prev.style.visibility = n === 1 ? "hidden" : "visible";
      next.textContent = n === TOTAL_STEPS ? "Pick your styles →" : "Next →";
      if (current.kind === "name") renderName(current);
      else if (current.kind === "breed") renderBreed(current);
      else renderChoices(current);
    }

    function escapeHtml(s: string) {
      return s.replace(/[&<>"']/g, (c) => ({
        "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
      }[c]!));
    }

    // Resolves the analytics shape for the breed step. Existing reports key
    // on `answer` as a string, so we keep that field and add the structured
    // params alongside.
    function breedAnalytics(): {
      answer: string;
      breed_mode: "single" | "crossbreed" | "unknown";
      breed_count: number;
    } {
      if (breedUi.isUnknown) {
        return { answer: "unknown", breed_mode: "unknown", breed_count: 0 };
      }
      if (breedUi.isCrossbreed) {
        const list = answers.breeds ?? [];
        return {
          answer: list.join(" / "),
          breed_mode: "crossbreed",
          breed_count: list.length,
        };
      }
      return {
        answer: answers.breed ?? "",
        breed_mode: "single",
        breed_count: answers.breed ? 1 : 0,
      };
    }

    next.addEventListener("click", async () => {
      // Capture the step we're leaving so the event reflects the answer
      // the user just locked in (not the step we're about to render).
      const completedStep = step;
      const completedKey = buildSteps()[completedStep - 1].key;

      if (completedKey === "breed") {
        const a = breedAnalytics();
        track("quiz_step_complete", {
          step_number: completedStep,
          step_name: "breed",
          ...a,
        });
      } else if (completedKey === "favouriteFeature") {
        const value = answers.favouriteFeature;
        if (value) {
          track("quiz_step_complete", {
            step_number: completedStep,
            step_name: "favouriteFeature",
            answer: value,
            favourite_feature: value,
          });
        }
      } else {
        const completedAnswer = (answers as Record<string, unknown>)[completedKey];
        if (completedAnswer !== undefined) {
          track("quiz_step_complete", {
            step_number: completedStep,
            step_name: completedKey,
            answer: completedAnswer,
          });
        }
      }

      if (step < TOTAL_STEPS) {
        showStep(step + 1);
        return;
      }
      // Submit
      next.disabled = true;
      next.textContent = "Saving...";

      const breedSummary = breedAnalytics();
      track("quiz_complete", {
        gender: answers.gender,
        size: answers.size,
        activity: answers.activity,
        mood: answers.mood,
        lifestyle: answers.lifestyle,
        favourite_feature: answers.favouriteFeature,
        breed: answers.breed,
        breed_mode: breedSummary.breed_mode,
        breed_count: breedSummary.breed_count,
      });

      await client.mutation(api.sessions.saveQuiz, {
        id: sessionId as any,
        answers: {
          name: answers.name,
          breed: answers.breed,
          breeds: answers.breeds,
          gender: answers.gender!,
          age: answers.age,
          size: answers.size!,
          lifestyle: answers.lifestyle,
          activity: answers.activity!,
          mood: answers.mood!,
          favouriteFeature: answers.favouriteFeature!,
        },
      });
      window.location.href = "/style-pick";
    });

    prev.addEventListener("click", () => {
      if (step > 1) showStep(step - 1);
    });

    showStep(1);
  }
</script>

