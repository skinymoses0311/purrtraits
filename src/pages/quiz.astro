---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Style quiz · Purrtraits">
  <main class="page container">
    <a href="/upload" class="back-link muted">← Back</a>

    <div class="quiz" id="quiz" data-step="1">
      <div class="quiz__top">
        <div class="progress">
          <div class="progress__track"><div class="progress__fill" id="progress-fill" style="width:33%"></div></div>
          <span class="muted" id="progress-label">1 of 3</span>
        </div>
      </div>

      <!-- Q1 -->
      <section class="quiz__step" data-q="1">
        <h1>What should your pet be doing?</h1>
        <p class="muted">Pick a vibe — we'll paint them this way in every style.</p>
        <div class="quiz__grid">
          {[
            { v: "regal", e: "👑", t: "Sitting regally", b: "Crown-on-head energy" },
            { v: "playing", e: "🎾", t: "Playing with a toy", b: "Mid-zoomies action" },
            { v: "napping", e: "💤", t: "Curled up napping", b: "Soft, cosy, dreaming" },
            { v: "adventuring", e: "🏔️", t: "On an adventure", b: "Outdoors, exploring" },
          ].map((o) => (
            <button class="option" data-q="activity" data-v={o.v}>
              <span class="option__emoji">{o.e}</span>
              <div>
                <p class="display option__title">{o.t}</p>
                <p class="muted option__blurb">{o.b}</p>
              </div>
            </button>
          ))}
        </div>
      </section>

      <!-- Q2 -->
      <section class="quiz__step" data-q="2" hidden>
        <h1>What's your pet's vibe?</h1>
        <p class="muted">There are no wrong answers.</p>
        <div class="quiz__grid">
          {[
            { v: "calm", e: "😌", t: "Calm", b: "Sleepy snuggle expert" },
            { v: "playful", e: "😄", t: "Playful", b: "Permanent zoomies mode" },
            { v: "regal", e: "👑", t: "Regal", b: "Owns the household" },
            { v: "quirky", e: "🤪", t: "Quirky", b: "Has a weird side" },
          ].map((o) => (
            <button class="option" data-q="mood" data-v={o.v}>
              <span class="option__emoji">{o.e}</span>
              <div>
                <p class="display option__title">{o.t}</p>
                <p class="muted option__blurb">{o.b}</p>
              </div>
            </button>
          ))}
        </div>
      </section>

      <!-- Q3 -->
      <section class="quiz__step" data-q="3" hidden>
        <h1>Where will it hang?</h1>
        <p class="muted">Helps us frame it for the room.</p>
        <div class="quiz__grid">
          {[
            { v: "living", e: "🛋️", t: "Living room", b: "Statement piece" },
            { v: "bedroom", e: "🛏️", t: "Bedroom", b: "Cosy + personal" },
            { v: "office", e: "💼", t: "Office", b: "Cheer up the desk" },
            { v: "kitchen", e: "🍳", t: "Kitchen", b: "Why not?" },
          ].map((o) => (
            <button class="option" data-q="room" data-v={o.v}>
              <span class="option__emoji">{o.e}</span>
              <div>
                <p class="display option__title">{o.t}</p>
                <p class="muted option__blurb">{o.b}</p>
              </div>
            </button>
          ))}
        </div>
      </section>

      <div class="quiz__footer">
        <button id="prev" class="btn">← Previous</button>
        <button id="next" class="btn btn--primary" disabled>Next →</button>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { makeClient, getSessionId, requireOrRedirect } from "../lib/client.ts";
  import { api } from "../../convex/_generated/api.js";

  const client = makeClient();
  const sessionId = getSessionId();
  if (!requireOrRedirect(sessionId, "/upload")) {
    // redirected
  } else {
    let step = 1;
    const answers: Record<string, string> = {};

    const fill = document.getElementById("progress-fill") as HTMLDivElement;
    const label = document.getElementById("progress-label")!;
    const next = document.getElementById("next") as HTMLButtonElement;
    const prev = document.getElementById("prev") as HTMLButtonElement;

    function showStep(n: number) {
      step = n;
      document.querySelectorAll<HTMLElement>(".quiz__step").forEach((el) => {
        el.hidden = el.dataset.q !== String(n);
      });
      fill.style.width = `${(n / 3) * 100}%`;
      label.textContent = `${n} of 3`;
      const q = ["activity", "mood", "room"][n - 1];
      next.disabled = !answers[q];
      next.textContent = n === 3 ? "Generate my portraits ✨" : "Next →";
      prev.style.visibility = n === 1 ? "hidden" : "visible";
    }

    document.querySelectorAll<HTMLButtonElement>(".option").forEach((btn) => {
      btn.addEventListener("click", () => {
        const q = btn.dataset.q!;
        const v = btn.dataset.v!;
        answers[q] = v;
        // Mark active among siblings
        btn.parentElement!.querySelectorAll(".option").forEach((s) =>
          s.classList.toggle("option--active", s === btn),
        );
        next.disabled = false;
      });
    });

    next.addEventListener("click", async () => {
      if (step < 3) {
        showStep(step + 1);
        return;
      }
      // Submit
      next.disabled = true;
      next.textContent = "Saving...";
      await client.mutation(api.sessions.saveQuiz, {
        id: sessionId as any,
        answers: { activity: answers.activity, mood: answers.mood, room: answers.room },
      });
      window.location.href = "/generate";
    });

    prev.addEventListener("click", () => {
      if (step > 1) showStep(step - 1);
    });

    showStep(1);
  }
</script>

<style>
  .back-link { display: inline-block; margin-bottom: 16px; }
  .quiz { max-width: 820px; margin: 0 auto; }
  .quiz__top { margin-bottom: 32px; }
  .quiz__step h1 { margin-bottom: 6px; }
  .quiz__step p { margin-bottom: 24px; }

  .quiz__grid { display: grid; gap: 12px; grid-template-columns: 1fr; }
  @media (min-width: 600px) { .quiz__grid { grid-template-columns: 1fr 1fr; } }

  .option {
    display: flex; align-items: center; gap: 16px; text-align: left;
    padding: 16px 18px; background: var(--c-white);
    border: 2.5px solid var(--c-stroke-light); border-radius: var(--r-md);
    cursor: pointer; transition: border-color .15s ease, transform .08s ease;
    font-family: inherit;
  }
  .option:hover { border-color: var(--c-stroke); transform: translateY(-1px); }
  .option--active { border-color: var(--c-pink); background: var(--c-pink-light); }
  .option__emoji { font-size: 32px; flex-shrink: 0; }
  .option__title { font-size: 20px; }
  .option__blurb { font-size: 14px; }

  .quiz__footer {
    margin-top: 32px; display: flex; justify-content: space-between; gap: 12px;
  }
</style>
