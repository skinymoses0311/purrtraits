---
import Layout from "../layouts/Layout.astro";
import ProductPreview from "../components/ProductPreview.astro";
---

<Layout title="Choose your format · Purrtraits">
  <main class="page container">
    <a href="/gallery" class="back-link muted">← See my gallery</a>

    <div class="pdp">
      <div class="pdp__media">
        <div class="protected-wrap pdp__hero-wrap is-loading is-loading--hero">
          <img id="hero" class="pdp__hero protected-img is-loading-img" alt="" />
        </div>
        <div id="preview-wrap" hidden>
          <p class="display pdp__preview-label">How it'll look</p>
          <ProductPreview />
        </div>
      </div>

      <div class="pdp__detail">
        <p class="muted" id="style-label"></p>
        <h1 id="title">Your portrait</h1>

        <div class="format-tabs" id="formats"></div>

        <div class="pdp__variant" id="size-area">
          <p class="display pdp__section-label">Choose size</p>
          <div class="pdp__chips" id="sizes"></div>
        </div>

        <div class="pdp__variant" id="frame-area" hidden>
          <p class="display pdp__section-label">Frame colour</p>
          <div class="pdp__chips" id="frames">
            <button class="chip" data-frame="natural-wood">Natural wood</button>
            <button class="chip" data-frame="dark-wood">Dark wood</button>
          </div>
        </div>

        <div class="pdp__about" id="about-area">
          <div class="info-tabs" id="info-tabs">
            <button class="info-tab info-tab--active" data-info-tab="details">Details</button>
            <button class="info-tab" data-info-tab="shipping" id="info-tab-shipping">Shipping</button>
          </div>
          <div class="info-panel" id="info-panel-details">
            <p class="pdp__about-copy" id="about-copy"></p>
          </div>
          <div class="info-panel" id="info-panel-shipping" hidden>
            <table class="shipping-table">
              <tbody>
                <tr><td>UK</td><td>2–5 business days</td></tr>
                <tr><td>US</td><td>2–4 business days</td></tr>
                <tr><td>Canada</td><td>3–6 business days</td></tr>
                <tr><td>Australia</td><td>4–7 business days</td></tr>
              </tbody>
            </table>
            <p class="muted shipping-note">Printed and shipped by our local production partners.</p>
          </div>
        </div>

        <div class="pdp__price-row">
          <p class="display pdp__price" id="price">—</p>
          <div class="pdp__benefits">
            <span class="tag">✓ Secure checkout</span>
            <span class="tag" id="benefit-2">✓ Instant download</span>
          </div>
        </div>

        <button id="buy" class="btn btn--primary btn--block" disabled>Add to cart</button>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { makeClient, getSessionId, requireOrRedirect, disableImageGrabbers, attachImageLoading } from "../lib/client.ts";
  import { api } from "../../convex/_generated/api.js";
  import { STYLE_LABELS } from "../../convex/styleScoring.ts";
  import { formatProductDescription } from "../../convex/productCopy.ts";
  import { track, trackEcommerce } from "../lib/analytics.ts";

  type Format = "digital" | "poster" | "framed" | "canvas";
  type Size = "small" | "medium" | "large";
  type Frame = "natural-wood" | "dark-wood";

  // GA4 ecommerce item shape used by view_item / add_to_cart. Centralised
  // so both events emit the same item_id and the portrait_style custom
  // dimension stays consistent across the funnel.
  function buildEcommerceItem(opts: {
    productId: string;
    format: string;
    size?: string;
    frame?: string;
    priceCents: number;
    quantity: number;
    selectedStyle: string;
  }) {
    const sizePart = opts.size ? ` - ${opts.size}` : "";
    const framePart = opts.frame ? ` - ${opts.frame}` : "";
    return {
      item_id: opts.productId,
      item_name: `${opts.format}${sizePart}${framePart}`,
      item_category: opts.format,
      item_variant: opts.size,
      item_brand: "Purrtraits",
      price: opts.priceCents / 100,
      quantity: opts.quantity,
      portrait_style: opts.selectedStyle,
    };
  }
  const FORMAT_LABELS: Record<Format, string> = {
    digital: "Digital",
    poster: "Poster",
    framed: "Framed",
    canvas: "Canvas",
  };
  const SIZE_LABELS: Record<Size, string> = {
    small: "Small",
    medium: "Medium",
    large: "Large",
  };

  const client = makeClient();
  const sessionId = getSessionId();
  if (!requireOrRedirect(sessionId, "/upload")) {
    // redirected
  } else {
    const session = await client.query(api.sessions.get, { id: sessionId as any });
    if (!session?.selectedStyle || !session.generations) {
      window.location.href = "/reveal";
    } else {
      const products = await client.query(api.products.list, {});
      const selectedStyle = session.selectedStyle;
      const styleLabel = (STYLE_LABELS as Record<string, string>)[selectedStyle] ?? selectedStyle;
      const portrait = session.generations.find((g) => g.style === selectedStyle)!;

      // DOM refs
      const hero = document.getElementById("hero") as HTMLImageElement;
      const title = document.getElementById("title")!;
      const styleLbl = document.getElementById("style-label")!;
      const formats = document.getElementById("formats")!;
      const sizes = document.getElementById("sizes")!;
      const sizeArea = document.getElementById("size-area")!;
      const frameArea = document.getElementById("frame-area")!;
      const frames = document.getElementById("frames")!;
      const aboutCopy = document.getElementById("about-copy")!;
      const infoTabShipping = document.getElementById("info-tab-shipping") as HTMLButtonElement;
      const infoPanelDetails = document.getElementById("info-panel-details")!;
      const infoPanelShipping = document.getElementById("info-panel-shipping")!;
      const infoTabs = document.querySelectorAll<HTMLButtonElement>(".info-tab");
      let activeInfoTab: "details" | "shipping" = "details";
      function setInfoTab(name: "details" | "shipping") {
        activeInfoTab = name;
        infoTabs.forEach((t) =>
          t.classList.toggle("info-tab--active", t.dataset.infoTab === name),
        );
        infoPanelDetails.hidden = name !== "details";
        infoPanelShipping.hidden = name !== "shipping";
      }
      infoTabs.forEach((t) =>
        t.addEventListener("click", () =>
          setInfoTab((t.dataset.infoTab as "details" | "shipping") ?? "details"),
        ),
      );
      const price = document.getElementById("price")!;
      const buy = document.getElementById("buy") as HTMLButtonElement;
      const benefit2 = document.getElementById("benefit-2")!;

      const petName = session.quizAnswers?.name?.trim();
      const breed = session.quizAnswers?.breed?.trim();

      attachImageLoading();
      hero.src = portrait.imageUrl;
      disableImageGrabbers();
      title.textContent = petName
        ? `${petName} · ${styleLabel}`
        : `${styleLabel} Portrait`;
      styleLbl.textContent = petName ? `Your portrait of ${petName}` : "Your selection";
      if (petName) {
        document.title = `${petName}'s portrait · Purrtraits`;
      }

      // Product preview wiring. The CSS component reads data-format,
      // data-frame, and data-size to pick its mockup style, plus its image.
      const previewWrap = document.getElementById("preview-wrap")!;
      const preview = document.getElementById("product-preview") as HTMLElement;
      const previewImg = document.getElementById("pp-img") as HTMLImageElement;
      const previewCaption = document.getElementById("pp-caption")!;
      previewImg.src = portrait.imageUrl;

      // State
      let format: Format = "digital";
      let size: Size = "medium";
      let frame: Frame = "natural-wood";

      function findProduct() {
        return products.find(
          (p: any) =>
            p.format === format &&
            (format === "digital" || p.size === size) &&
            (format !== "framed" || p.frame === frame),
        ) as any;
      }

      function fmtPrice(cents: number) {
        return new Intl.NumberFormat(undefined, { style: "currency", currency: "USD" }).format(cents / 100);
      }

      function render() {
        // Format tabs
        formats.innerHTML = "";
        (Object.keys(FORMAT_LABELS) as Format[]).forEach((f) => {
          const tab = document.createElement("button");
          tab.className = "format-tab" + (f === format ? " format-tab--active" : "");
          tab.textContent = FORMAT_LABELS[f];
          tab.addEventListener("click", () => {
            format = f;
            render();
          });
          formats.appendChild(tab);
        });

        // Size area
        if (format === "digital") {
          sizeArea.hidden = true;
          frameArea.hidden = true;
        } else {
          sizeArea.hidden = false;
          sizes.innerHTML = "";
          (["small", "medium", "large"] as Size[]).forEach((s) => {
            const c = document.createElement("button");
            c.className = "chip" + (s === size ? " chip--active" : "");
            c.textContent = SIZE_LABELS[s];
            c.addEventListener("click", () => {
              size = s;
              render();
            });
            sizes.appendChild(c);
          });
          frameArea.hidden = format !== "framed";
          if (format === "framed") {
            frames.querySelectorAll<HTMLButtonElement>(".chip").forEach((el) => {
              el.classList.toggle("chip--active", el.dataset.frame === frame);
              el.onclick = () => {
                frame = (el.dataset.frame as Frame) ?? "natural-wood";
                render();
              };
            });
          }
        }

        // Shipping tab only applies to physical formats.
        const isDigital = format === "digital";
        infoTabShipping.hidden = isDigital;
        if (isDigital && activeInfoTab === "shipping") setInfoTab("details");

        // Personalised description for the currently-selected variant.
        // Uses the same helper as Stripe checkout so both surfaces match.
        const product = findProduct();
        aboutCopy.textContent = product
          ? formatProductDescription(product, petName, breed)
          : "";

        // Benefits chip
        benefit2.textContent =
          format === "digital" ? "✓ Instant download" : "✓ Worldwide shipping";

        // Price + buy state
        if (product) {
          price.textContent = fmtPrice(product.priceCents);
          buy.disabled = false;
          buy.textContent = "Add to cart";
          buy.dataset.productId = product._id;
        } else {
          price.textContent = "—";
          buy.disabled = true;
          buy.textContent = "Out of stock";
        }

        // Product preview update — driven by data attributes.
        if (format === "digital") {
          previewWrap.hidden = true;
        } else {
          previewWrap.hidden = false;
          preview.dataset.format = format;
          preview.dataset.frame = format === "framed" ? frame : "";
          preview.dataset.size = size;
          // Scale the on-screen preview by chosen size so customers feel
          // a physical sense of "small vs large" — purely visual scaling.
          const widths: Record<typeof size, string> = {
            small: "180px",
            medium: "240px",
            large: "300px",
          } as any;
          preview.style.setProperty("--art-w", widths[size]);

          const dimLabel: Record<string, string> = {
            small: '12 × 16"',
            medium: '18 × 24"',
            large: '24 × 32"',
          };
          const formatLabel: Record<Format, string> = {
            poster: "Poster",
            framed: `Framed (${frame === "natural-wood" ? "natural wood" : "dark wood"})`,
            canvas: "Canvas (slim 2cm)",
            digital: "",
          };
          previewCaption.textContent =
            `${formatLabel[format]} · ${dimLabel[size]} · scaled for screen`;
        }
      }

      let addedFlashTimer: number | undefined;
      buy.addEventListener("click", async () => {
        const productId = buy.dataset.productId;
        if (!productId) return;
        if (addedFlashTimer) {
          clearTimeout(addedFlashTimer);
          addedFlashTimer = undefined;
        }
        buy.disabled = true;
        buy.textContent = "Adding…";
        const product = findProduct();
        try {
          await client.mutation(api.cart.addItem, {
            sessionId: sessionId as any,
            productId: productId as any,
            // printFileUrl is the high-res print version (or display fallback);
            // displayUrl is the small UI version used for cart thumbs.
            printFileUrl: (portrait as any).printFileUrl ?? portrait.imageUrl,
            displayUrl: portrait.imageUrl,
            style: selectedStyle,
            petName: petName ?? undefined,
          });
          if (product) {
            const item = buildEcommerceItem({
              productId,
              format: product.format,
              size: product.format === "digital" ? undefined : product.size,
              frame: product.format === "framed" ? product.frame : undefined,
              priceCents: product.priceCents,
              quantity: 1,
              selectedStyle,
            });
            trackEcommerce("add_to_cart", {
              currency: "USD",
              value: product.priceCents / 100,
              items: [item],
            });
          }
          buy.textContent = "Added to cart ✓";
          addedFlashTimer = window.setTimeout(() => {
            buy.disabled = false;
            buy.textContent = "Add to cart";
            addedFlashTimer = undefined;
          }, 1600);
        } catch (err) {
          buy.disabled = false;
          buy.textContent = "Add to cart";
          alert("Couldn't add to cart: " + (err as Error).message);
        }
      });

      render();

      // view_item fires once on page load with the default selection
      // (digital format, medium size). Subsequent format/size changes are
      // measured separately via add_to_cart so we don't drown GA in churn.
      const initialProduct = findProduct();
      if (initialProduct) {
        const item = buildEcommerceItem({
          productId: String(initialProduct._id),
          format: initialProduct.format,
          size: initialProduct.format === "digital" ? undefined : initialProduct.size,
          frame: initialProduct.format === "framed" ? initialProduct.frame : undefined,
          priceCents: initialProduct.priceCents,
          quantity: 1,
          selectedStyle,
        });
        trackEcommerce("view_item", {
          currency: "USD",
          value: initialProduct.priceCents / 100,
          items: [item],
        });
      }
    }
  }
</script>

<style>
  .back-link { display: inline-block; margin-bottom: 16px; }

  .pdp { display: grid; gap: 32px; grid-template-columns: 1fr; align-items: start; }
  @media (min-width: 900px) { .pdp { grid-template-columns: 1fr 1fr; gap: 60px; } }

  .pdp__media { display: flex; flex-direction: column; gap: 12px; }
  .pdp__preview-label { font-size: 18px; font-weight: 600; margin: 12px 0 8px; }
  /* Let the AI output dictate the displayed ratio — no forced container ratio,
     no object-fit cropping, no cream letterbox. */
  .pdp__hero {
    width: 100%; height: auto; display: block;
    border: 1.5px solid var(--c-stroke-light); border-radius: var(--r-md);
  }
  .pdp__detail { display: flex; flex-direction: column; gap: 16px; }
  .pdp__detail h1 { font-size: clamp(2rem, 4vw, 2.4rem); }
  .pdp__section-label { font-size: 18px; font-weight: 600; }
  .pdp__chips { display: flex; gap: 10px; flex-wrap: wrap; }

  .pdp__about { display: flex; flex-direction: column; gap: 12px; }
  .pdp__about-copy {
    font-size: 15px; line-height: 1.55; color: var(--c-dark);
  }

  .info-tabs {
    display: flex; gap: 0;
    border-bottom: 1.5px solid var(--c-stroke-light);
  }
  .info-tab {
    padding: 10px 18px; background: transparent; border: none; cursor: pointer;
    font-family: var(--font-display); font-size: 15px; color: var(--c-text);
    border-bottom: 2px solid transparent; margin-bottom: -1.5px;
  }
  .info-tab:hover { color: var(--c-dark); }
  .info-tab--active { color: var(--c-dark); border-bottom-color: var(--c-pink); font-weight: 700; }

  .shipping-table {
    width: 100%; border-collapse: collapse; font-size: 15px;
  }
  .shipping-table td {
    padding: 8px 0; border-bottom: 1px solid var(--c-stroke-light); color: var(--c-dark);
  }
  .shipping-table tr:last-child td { border-bottom: none; }
  .shipping-table td:last-child { text-align: right; color: var(--c-text); }
  .shipping-note { font-size: 13px; margin-top: 10px; }

  .pdp__price-row {
    display: flex; justify-content: space-between; align-items: center; gap: 16px;
    border-top: 1px solid var(--c-stroke-light); padding-top: 16px; flex-wrap: wrap;
  }
  .pdp__price { font-size: 36px; font-weight: 700; }
  .pdp__benefits { display: flex; gap: 8px; flex-wrap: wrap; }
</style>
