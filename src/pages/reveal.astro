---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Your portraits · Purrtraits"
  description="Your generated portraits."
  noindex
>
  <main class="page container">
    <header class="reveal__header">
      <div>
        <h1>Your portraits are ready! 🎨</h1>
        <p class="muted">Click a style to select it, then choose your format.</p>
      </div>
      <button id="regen" class="btn">Regenerate (<span id="regen-count">2</span> left)</button>
    </header>

    <div class="reveal__grid" id="grid"></div>

    <div class="reveal__footer">
      <button id="continue" class="btn btn--primary btn--lg" disabled>Choose this style →</button>
    </div>
  </main>
</Layout>

<script>
  import { getSessionId, requireOrRedirect, disableImageGrabbers, attachImageLoading } from "../lib/client.ts";
  import { isSignedIn, makeAuthedClient } from "../lib/authStorage.ts";
  import { api } from "../../convex/_generated/api.js";
  import { STYLE_LABELS } from "../../convex/styleScoring.ts";
  import { track } from "../lib/analytics.ts";

  function labelFor(style: string): string {
    return (STYLE_LABELS as Record<string, string>)[style] ?? style;
  }

  // Dedupe portrait_viewed events: each style fires at most once per page
  // load, even if the user re-renders the grid by regenerating.
  const viewedStyles = new Set<string>();

  const sessionId = getSessionId();

  if (!requireOrRedirect(sessionId, "/upload")) {
    // redirected
  } else if (!isSignedIn()) {
    // Reveal is only reachable for authed users — anyone here without a token
    // came back via stale URL after sign-out. Re-gate them at /sign-up.
    window.location.href = "/sign-up?next=/reveal";
  } else {
    // Authed client so the regenerate action and getMyRegensRemaining query
    // include the JWT from the React-island sign-in.
    const client = makeAuthedClient();

    const grid = document.getElementById("grid")!;
    const continueBtn = document.getElementById("continue") as HTMLButtonElement;
    const regenBtn = document.getElementById("regen") as HTMLButtonElement;
    const regenCount = document.getElementById("regen-count")!;

    let selected: string | null = null;

    function render(generations: { style: string; imageUrl: string }[], regensRemaining: number) {
      regenCount.textContent = String(regensRemaining);
      regenBtn.disabled = regensRemaining <= 0;
      grid.innerHTML = "";
      generations.forEach((g) => {
        // portrait_viewed fires once per style per page load. A regenerated
        // batch can return the same style at a different URL — we still want
        // a single view event per style.
        if (!viewedStyles.has(g.style)) {
          viewedStyles.add(g.style);
          try {
            track("portrait_viewed", {
              style: g.style,
              style_label: labelFor(g.style),
            });
          } catch { /* noop */ }
        }
        const card = document.createElement("button");
        card.className = "selectable reveal__card";
        card.dataset.style = g.style;
        card.innerHTML = `
          <div class="protected-wrap reveal__media is-loading is-loading--hero">
            <img src="${g.imageUrl}" alt="" class="reveal__img protected-img is-loading-img" />
          </div>
          <div class="reveal__meta">
            <span class="display">${labelFor(g.style)}</span>
            <span class="reveal__check" aria-hidden="true">✓</span>
          </div>
        `;
        card.addEventListener("click", () => {
          selected = g.style;
          document.querySelectorAll(".reveal__card").forEach((el) =>
            el.classList.toggle("selectable--active", el === card),
          );
          continueBtn.disabled = false;
          continueBtn.textContent = `Choose ${labelFor(g.style)} →`;
        });
        grid.appendChild(card);
      });
      disableImageGrabbers(grid);
      attachImageLoading(grid);
    }

    const [session, regens] = await Promise.all([
      client.query(api.sessions.get, { id: sessionId as any }),
      client.query(api.sessions.getMyRegensRemaining, {}),
    ]);
    if (!session?.generations) {
      window.location.href = "/generate";
    } else {
      const petName = session.quizAnswers?.name?.trim();
      if (petName) {
        document.title = `${petName}'s portraits · Purrtraits`;
        const heading = document.querySelector(".reveal__header h1");
        if (heading) heading.textContent = `Which ${petName} do you love most?`;
        const sub = document.querySelector(".reveal__header .muted");
        if (sub) sub.textContent = `Click a style for ${petName}, then choose your format.`;
      }

      render(session.generations, regens ?? 0);

      regenBtn.addEventListener("click", async () => {
        // Snapshot regens BEFORE the action so the event reflects what the
        // user had when they clicked, and so we can detect the budget hitting 0.
        const regensBeforeClick = Number(regenCount.textContent) || 0;
        try {
          track("regen_clicked", { regens_remaining: regensBeforeClick });
        } catch { /* noop */ }

        regenBtn.disabled = true;
        regenBtn.textContent = "Regenerating…";
        try {
          await client.action(api.fal.regenerate, { sessionId: sessionId as any });
          const [updated, updatedRegens] = await Promise.all([
            client.query(api.sessions.get, { id: sessionId as any }),
            client.query(api.sessions.getMyRegensRemaining, {}),
          ]);
          const remaining = updatedRegens ?? 0;
          render(updated!.generations!, remaining);
          regenBtn.textContent = `Regenerate (${remaining} left)`;
          regenBtn.disabled = remaining <= 0;
          if (remaining <= 0) {
            try { track("regen_limit_reached"); } catch { /* noop */ }
          }
        } catch (err) {
          alert("Regeneration failed: " + (err as Error).message);
          regenBtn.disabled = false;
          regenBtn.textContent = `Regenerate`;
        }
      });

      continueBtn.addEventListener("click", async () => {
        if (!selected) return;
        try { track("portrait_selected", { style: selected }); } catch { /* noop */ }
        await client.mutation(api.sessions.selectStyle, {
          id: sessionId as any,
          style: selected,
        });
        window.location.href = "/pdp";
      });
    }
  }
</script>

<style>
  .reveal__header {
    display: flex; justify-content: space-between; align-items: flex-end; gap: 16px; flex-wrap: wrap;
    margin-bottom: 24px;
  }
  .reveal__grid {
    display: grid; gap: 16px;
    grid-template-columns: repeat(2, 1fr);
  }
  @media (min-width: 800px) { .reveal__grid { grid-template-columns: repeat(3, 1fr); } }

  .reveal__card { padding: 0; font-family: inherit; }
  .reveal__img {
    width: 100%; height: auto; display: block;
  }
  .reveal__meta {
    padding: 10px 14px; display: flex; justify-content: space-between; align-items: center;
    font-size: 18px;
  }
  .reveal__check { display: none; color: var(--c-pink); font-weight: 700; }
  .selectable--active .reveal__check { display: inline; }

  .reveal__footer { margin-top: 28px; display: flex; justify-content: center; }
</style>
