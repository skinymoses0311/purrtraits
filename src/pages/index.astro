  .how--visible .how-step:nth-child(9) .how-step__blurb { animation-delay: 520ms; }

  /* Arrows: each fires 50ms AFTER the preceding step lands.
     Step i delay = i*100ms, duration 600ms ⇒ lands at i*100 + 600.
     Arrow i (between step i and step i+1) delay = i*100 + 650. */
  .how--visible .how__arrow path,
  .how--visible .how__arrow-v path {
    animation: arrow-draw 0.55s ease-out both;
  }
  .how--visible .how__arrow:nth-child(2) path,
