---
import Layout from "../layouts/Layout.astro";
import AdUnit from "../components/AdUnit.astro";

const homeJsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      name: "Purrtraits",
      url: "https://purrtraits.shop",
      logo: "https://purrtraits.shop/og-default.png",
    },
    {
      "@type": "WebSite",
      url: "https://purrtraits.shop",
      name: "Purrtraits",
    },
  ],
};

// Hero gallery wall — frame compositions for desktop (10) and mobile (6).
// Widths are percentages of the wall so the layout scales with the hero
// width; the inner image always renders at a 3:4 aspect ratio. Variants
// 0–6 map to /public/hero-wall/portrait-0{1..7}.jpg.
type Frame = {
  x: number;          // left % within the wall
  y: number;          // top % within the wall
  w: number;          // width % within the wall
  kind: "framed" | "canvas" | "poster";
  wood?: "natural" | "dark" | "gold";
  v: number;          // 0..6 → portrait variant
};
const heroDesktop: Frame[] = [
  { x: 4,  y: 8,  w: 10.94, kind: "framed", wood: "natural", v: 0 },
  { x: 18, y: 40, w: 8.59,  kind: "framed", wood: "dark",    v: 1 },
  { x: 4,  y: 64, w: 7.81,  kind: "canvas",                  v: 4 },
  { x: 28, y: 6,  w: 10.16, kind: "framed", wood: "gold",    v: 2 },
  { x: 32, y: 36, w: 10.16, kind: "poster",                  v: 3 },
  { x: 50, y: 60, w: 8.59,  kind: "framed", wood: "natural", v: 6 },
  { x: 70, y: 2,  w: 7.42,  kind: "canvas",                  v: 5 },
  { x: 67, y: 26, w: 10.16, kind: "framed", wood: "dark",    v: 0 },
  { x: 84, y: 52, w: 7.81,  kind: "framed", wood: "natural", v: 4 },
  { x: 73, y: 68, w: 7.42,  kind: "poster",                  v: 6 },
];
const heroMobile: Frame[] = [
  { x: -4, y: 4,  w: 28.2, kind: "framed", wood: "natural", v: 0 },
  { x: 60, y: 2,  w: 23.1, kind: "canvas",                  v: 5 },
  { x: 68, y: 24, w: 26.9, kind: "framed", wood: "dark",    v: 1 },
  { x: -6, y: 38, w: 24.6, kind: "framed", wood: "gold",    v: 2 },
  { x: 64, y: 56, w: 23.1, kind: "poster",                  v: 4 },
  { x: -2, y: 64, w: 23.1, kind: "canvas",                  v: 6 },
];
const portraitSrc = (v: number) =>
  `/hero-wall/portrait-0${v + 1}.jpg`;

// "How it works" — 5 steps; matches the live flow which routes through
// /quiz between upload and style-pick.
const steps = [
  { n: 1, title: "Upload photo",  blurb: "Drop a clear shot of your pet — phone snaps welcome.", icon: "upload",  tint: "#A8BFD4" },
  { n: 2, title: "Complete quiz", blurb: "A few quick questions help us paint the real them.",   icon: "quiz",    tint: "#FBEEF1" },
  { n: 3, title: "Pick a style",  blurb: "Renaissance, watercolour, pop art and 30+ more.",      icon: "palette", tint: "#B8C9A8" },
  { n: 4, title: "Generate",      blurb: "AI paints your portrait in under 60 seconds.",         icon: "sparkle", tint: "#E8D08A" },
  { n: 5, title: "Buy & ship",    blurb: "Download, frame, or ship a canvas worldwide.",         icon: "box",     tint: "#E5A6B3" },
];

// Sample portraits — three tabs shown in segmented control.
type Sample = { name: string; blurb: string; src: string };
const samples: Record<"styles" | "artists" | "famous", Sample[]> = {
  styles: [
    { name: "Oil Painting", blurb: "Rich, textured, classical",   src: "/samples/oil.jpg" },
    { name: "Watercolour",  blurb: "Soft, dreamy, gentle tones",  src: "/samples/watercolour.jpg" },
    { name: "Pop Art",      blurb: "Bold colours, graphic style", src: "/samples/pop.jpg" },
  ],
  artists: [
    { name: "Old Master",            blurb: "Dramatic chiaroscuro, baroque mood",   src: "/samples/artists/old-master.jpg" },
    { name: "Post-Impressionist",    blurb: "Expressive brushwork, swirling colour", src: "/samples/artists/post-impressionist.jpg" },
    { name: "Folk Portraitist",      blurb: "Bold flat fields, symbolic flora",     src: "/samples/artists/folk-portraitist.jpg" },
  ],
  famous: [
    { name: "On the Riverbank", blurb: "Pointillist park scene · summer afternoon", src: "/samples/famous/on-the-riverbank.jpg" },
    { name: "Candlelit Study",  blurb: "Dutch Golden Age, single light source",     src: "/samples/famous/candlelit-study.jpg" },
    { name: "A Quiet Garden",   blurb: "Impressionist florals, dappled light",      src: "/samples/famous/a-quiet-garden.jpg" },
  ],
};
const tabs: { key: "styles" | "artists" | "famous"; label: string }[] = [
  { key: "styles",  label: "Styles" },
  { key: "artists", label: "Artists" },
  { key: "famous",  label: "Famous Art" },
];
---

<Layout
  title="Purrtraits — Custom AI pet portraits, framed and shipped"
  description="Turn your pet's photo into museum-worthy art in under 60 seconds. Oil painting, watercolour, pop art and more — digital downloads, framed prints, and canvas, shipped worldwide."
>
  <script type="application/ld+json" slot="jsonld" set:html={JSON.stringify(homeJsonLd)} />

  <!-- Mobile top banner — sits directly under the nav, above the hero. -->
  <div class="ad-band ad-band--top">
    <AdUnit
      viewport="mobile"
      slot="5052784229"
      width={320}
      height={50}
      label="purrtraits_home_top_banner_mobile_320x50"
    />
  </div>

  <!-- HERO · Gallery wall ============================================ -->
  <section class="hero-wall" aria-label="Hero">
    <!-- Two compositions: desktop (10 frames) and mobile (6 frames),
         toggled by media query. They share the wall background gradient
         which fades into the cream body below. -->
    <div class="hero-wall__frames hero-wall__frames--desktop" aria-hidden="true">
      {heroDesktop.map((f, i) => (
        <div
          class:list={[
            "frame",
            `frame--${f.kind}`,
            f.wood ? `frame--wood-${f.wood}` : "",
          ]}
          style={`left:${f.x}%; top:${f.y}%; width:${f.w}%; transform: rotate(${(i % 3 - 1) * 0.6}deg);`}
        >
          <span class="frame__pin" aria-hidden="true"></span>
          <img src={portraitSrc(f.v)} alt="" loading="lazy" decoding="async" />
        </div>
      ))}
    </div>

    <div class="hero-wall__frames hero-wall__frames--mobile" aria-hidden="true">
      {heroMobile.map((f, i) => (
        <div
          class:list={[
            "frame",
            `frame--${f.kind}`,
            f.wood ? `frame--wood-${f.wood}` : "",
          ]}
          style={`left:${f.x}%; top:${f.y}%; width:${f.w}%; transform: rotate(${(i % 3 - 1) * 0.7}deg);`}
        >
          <img src={portraitSrc(f.v)} alt="" loading="lazy" decoding="async" />
        </div>
      ))}
    </div>

    <div class="hero-wall__card">
      <h1 class="hero-wall__title">Turn your pet into<br />museum-worthy art</h1>
      <p class="hero-wall__sub">
        AI-generated portraits in seconds — digital downloads, framed prints, or canvas, shipped worldwide.
      </p>
      <a href="/upload" class="hero-wall__cta" id="nav-create-cta-hero">✦ Create My Portrait</a>
      <p class="hero-wall__note">Generate art for free · Results in under 60 seconds</p>
    </div>
  </section>

  <!-- Desktop hero leaderboard — between hero CTA and "How it works". -->
  <div class="ad-band">
    <AdUnit
      viewport="desktop"
      slot="5686149558"
      width={728}
      height={90}
      label="purrtraits_home_hero_top_leaderboard_728x90"
    />
  </div>

  <!-- HOW IT WORKS · V3 ============================================== -->
  <section class="how" id="how">
    <div class="how__inner">
      <p class="section-eyebrow">HOW IT WORKS</p>
      <h2 class="display how__heading">Five taps to a tail-wagging masterpiece</h2>

      <div class="how__row">
        {steps.map((s, i) => (
          <>
            <a
              href={s.icon === "quiz" ? "/quiz" : s.icon === "upload" ? "/upload" : "#"}
              class="how-step"
              data-step={s.n}
              aria-label={`Step ${s.n}: ${s.title}`}
            >
              <span class="how-step__circle" style={`background:${s.tint}`}>
                {s.icon === "upload" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="#2B1F1A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 16V4M12 4l-4 4M12 4l4 4M4 18v2a1 1 0 001 1h14a1 1 0 001-1v-2"/>
                  </svg>
                )}
                {s.icon === "quiz" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="#2B1F1A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="5" y="3" width="14" height="18" rx="2"/>
                    <path d="M9 8h6M9 12h6M9 16h3"/>
                    <path d="M16.5 15.5l1.4 1.4L21 13.5"/>
                  </svg>
                )}
                {s.icon === "palette" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="#2B1F1A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3a9 9 0 100 18c1.1 0 2-.9 2-2 0-.5-.2-1-.5-1.4-.3-.4-.5-.9-.5-1.4 0-1.1.9-2 2-2h2a4 4 0 004-4c0-3.9-4-7-9-7z"/>
                    <circle cx="7.5" cy="11" r="1" fill="#2B1F1A" stroke="none"/>
                    <circle cx="11" cy="7" r="1" fill="#2B1F1A" stroke="none"/>
                    <circle cx="15" cy="7.5" r="1" fill="#2B1F1A" stroke="none"/>
                    <circle cx="17.5" cy="11" r="1" fill="#2B1F1A" stroke="none"/>
                  </svg>
                )}
                {s.icon === "sparkle" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="#2B1F1A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3l1.8 5L19 10l-5.2 2L12 17l-1.8-5L5 10l5.2-2L12 3z"/>
                    <path d="M19 16l.7 1.8L21.5 18.5l-1.8.7L19 21l-.7-1.8L16.5 18.5l1.8-.7L19 16z"/>
                  </svg>
                )}
                {s.icon === "box" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="#2B1F1A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 8l9-4 9 4-9 4-9-4z"/>
                    <path d="M3 8v8l9 4 9-4V8M12 12v8"/>
                  </svg>
                )}
                <span class="how-step__num">{s.n}</span>
              </span>
              <span class="how-step__title">{s.title}</span>
              <span class="how-step__blurb">{s.blurb}</span>
            </a>
            {i < steps.length - 1 && (
              <svg class:list={["how__arrow", { "how__arrow--flip": i % 2 === 1 }]} viewBox="0 0 80 30" aria-hidden="true">
                <path d="M 6 18 Q 24 4 44 14 T 72 14" fill="none" stroke="#D88A9A" stroke-width="1.8" stroke-linecap="round"/>
                <path d="M 65 8 L 73 14 L 65 20" fill="none" stroke="#D88A9A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </>
        ))}
      </div>

      <!-- Mobile: vertical layout with vertical arrows between steps. -->
      <div class="how__col">
        {steps.map((s, i) => (
          <>
            <a
              href={s.icon === "quiz" ? "/quiz" : s.icon === "upload" ? "/upload" : "#"}
              class="how-step how-step--mobile"
              aria-label={`Step ${s.n}: ${s.title}`}
            >
              <span class="how-step__circle" style={`background:${s.tint}`}>
                {s.icon === "upload" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="#2B1F1A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 16V4M12 4l-4 4M12 4l4 4M4 18v2a1 1 0 001 1h14a1 1 0 001-1v-2"/></svg>
                )}
                {s.icon === "quiz" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="#2B1F1A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="14" height="18" rx="2"/><path d="M9 8h6M9 12h6M9 16h3"/><path d="M16.5 15.5l1.4 1.4L21 13.5"/></svg>
                )}
                {s.icon === "palette" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="#2B1F1A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a9 9 0 100 18c1.1 0 2-.9 2-2 0-.5-.2-1-.5-1.4-.3-.4-.5-.9-.5-1.4 0-1.1.9-2 2-2h2a4 4 0 004-4c0-3.9-4-7-9-7z"/><circle cx="7.5" cy="11" r="1" fill="#2B1F1A" stroke="none"/><circle cx="11" cy="7" r="1" fill="#2B1F1A" stroke="none"/><circle cx="15" cy="7.5" r="1" fill="#2B1F1A" stroke="none"/><circle cx="17.5" cy="11" r="1" fill="#2B1F1A" stroke="none"/></svg>
                )}
                {s.icon === "sparkle" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="#2B1F1A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.8 5L19 10l-5.2 2L12 17l-1.8-5L5 10l5.2-2L12 3z"/><path d="M19 16l.7 1.8L21.5 18.5l-1.8.7L19 21l-.7-1.8L16.5 18.5l1.8-.7L19 16z"/></svg>
                )}
                {s.icon === "box" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="#2B1F1A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8l9-4 9 4-9 4-9-4z"/><path d="M3 8v8l9 4 9-4V8M12 12v8"/></svg>
                )}
                <span class="how-step__num">{s.n}</span>
              </span>
              <span class="how-step__col-text">
                <span class="how-step__title">{s.title}</span>
                <span class="how-step__blurb">{s.blurb}</span>
              </span>
            </a>
            {i < steps.length - 1 && (
              <svg class:list={["how__arrow-v", { "how__arrow-v--flip": i % 2 === 1 }]} viewBox="0 0 30 60" aria-hidden="true">
                <path d={i % 2 === 1 ? "M 18 4 Q 6 18 18 32 T 18 50" : "M 12 4 Q 24 18 12 32 T 12 50"} fill="none" stroke="#D88A9A" stroke-width="1.8" stroke-linecap="round"/>
                <path d={i % 2 === 1 ? "M 12 44 L 18 52 L 24 44" : "M 6 44 L 12 52 L 18 44"} fill="none" stroke="#D88A9A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- Mid-content MPU — between How-it-works and Sample portraits. -->
  <div class="ad-band ad-band--mid">
    <AdUnit
      viewport="desktop"
      slot="3552000295"
      width={300}
      height={250}
      label="purrtraits_home_midcontent_mpu_300x250"
    />
    <AdUnit
      viewport="mobile"
      slot="3223637740"
      width={300}
      height={250}
      label="purrtraits_home_midcontent_mpu_mobile_300x250"
    />
  </div>

  <!-- SAMPLE PORTRAITS · V5 (museum plaque + tabs) ==================== -->
  <section class="samples" id="samples">
    <div class="container">
      <p class="section-eyebrow samples__eyebrow">— THE COLLECTION —</p>
      <h2 class="display samples__title">Sample portraits</h2>

      <div class="samples__tabs" role="tablist" aria-label="Sample portrait categories">
        {tabs.map((t, i) => (
          <button
            type="button"
            role="tab"
            class="samples__tab"
            data-tab={t.key}
            aria-selected={i === 0 ? "true" : "false"}
            aria-controls={`samples-panel-${t.key}`}
            id={`samples-tab-${t.key}`}
          >{t.label}</button>
        ))}
      </div>

      {tabs.map((t, i) => (
        <div
          class="samples__panel"
          role="tabpanel"
          id={`samples-panel-${t.key}`}
          aria-labelledby={`samples-tab-${t.key}`}
          data-panel={t.key}
          hidden={i !== 0}
        >
          {samples[t.key].map((s, idx) => (
            <div class="sample-card">
              <div class="sample-card__frame">
                <img src={s.src} alt={`${s.name} sample portrait`} loading="lazy" decoding="async" />
              </div>
              <div class="sample-card__plaque">
                <div class="sample-card__no">NO. 0{idx + 1}</div>
                <div class="sample-card__name">{s.name}</div>
                <div class="sample-card__blurb">{s.blurb}</div>
              </div>
            </div>
          ))}
        </div>
      ))}
    </div>
  </section>
</Layout>

<script>
  // Sample-portraits tabs — vanilla, no React island. Toggle aria-selected
  // on the buttons and hidden on the panels.
  const tabs = document.querySelectorAll<HTMLButtonElement>(".samples__tab");
  const panels = document.querySelectorAll<HTMLElement>(".samples__panel");
  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const key = tab.dataset.tab;
      tabs.forEach((t) => t.setAttribute("aria-selected", String(t === tab)));
      panels.forEach((p) => {
        p.hidden = p.dataset.panel !== key;
      });
    });
  });
</script>

<style>
  /* Hero gallery wall ===================================================== */
  /* Tokens local to this section so the design colours don't have to fight
     the global tokens. */
  .hero-wall {
    --wall-a: #ECDCC2;
    --wall-b: #E4D2B6;
    --wall-c: #D6C09E;
    --wall-cream: #FAF6EE;
    --ink: #2B1F1A;
    --ink-soft: #5C4A3F;
    --ink-mute: #8A7766;
    --pink: #E5A6B3;

    position: relative;
    width: 100%;
    height: clamp(560px, 56vw, 720px);
    overflow: hidden;
    background:
      linear-gradient(180deg, transparent 0%, transparent 78%, var(--wall-cream) 100%),
      radial-gradient(ellipse at 50% 38%, var(--wall-a) 0%, var(--wall-b) 50%, var(--wall-c) 100%);
  }
  .hero-wall::before {
    content: "";
    position: absolute; inset: 0;
    opacity: .35;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(255,255,255,.18) 0px, transparent 2px),
      radial-gradient(circle at 70% 60%, rgba(0,0,0,.06) 0px, transparent 3px);
    background-size: 8px 8px, 12px 12px;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  .hero-wall__frames { position: absolute; inset: 0; }
  .hero-wall__frames--mobile  { display: block; }
  .hero-wall__frames--desktop { display: none; }
  @media (min-width: 768px) {
    .hero-wall__frames--mobile  { display: none; }
    .hero-wall__frames--desktop { display: block; }
    .hero-wall { height: clamp(620px, 56vw, 760px); }
  }

  .frame {
    position: absolute;
    line-height: 0;       /* drop the inline-image baseline gap */
    user-select: none;
  }
  .frame__pin {
    position: absolute; top: -4px; left: 50%; transform: translateX(-50%);
    width: 4px; height: 4px; background: #3A2A1E; border-radius: 50%;
    box-shadow: 0 1px 1px rgba(255,255,255,.5);
  }
  .frame img {
    display: block; width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    background: #EFE7D5;  /* placeholder while image loads */
  }

  /* Poster — clean white border (no padding), drop shadow */
  .frame--poster img {
    background: #fff;
    box-shadow:
      0 14px 26px -8px rgba(40,28,16,.32),
      0 4px 10px rgba(40,28,16,.18);
  }

  /* Canvas — image with a thin green side strip + faint canvas weave */
  .frame--canvas {
    box-shadow:
      12px 16px 22px -6px rgba(40,28,16,.32),
      4px 6px 10px rgba(40,28,16,.18);
  }
  .frame--canvas::after {
    content: "";
    position: absolute; top: 0; right: -9px;
    width: 9px; height: 100%;
    background: linear-gradient(90deg, #6F8C72 0%, #4D6650 100%);
  }
  .frame--canvas img {
    background-image:
      repeating-linear-gradient(0deg, rgba(0,0,0,.06) 0 1px, transparent 1px 3px),
      repeating-linear-gradient(90deg, rgba(0,0,0,.06) 0 1px, transparent 1px 3px);
  }

  /* Framed — wood gradient background, image inset by padding */
  .frame--framed {
    padding: 10px;
    box-shadow:
      0 14px 28px -10px rgba(80,50,20,.42),
      0 6px 12px rgba(80,50,20,.22);
  }
  .frame--framed img {
    box-shadow:
      inset 0 0 0 1.5px rgba(255,255,255,.16),
      inset 0 0 6px rgba(120,80,40,.35);
  }
  .frame--wood-natural { background: linear-gradient(135deg, #d4b896 0%, #c19a6f 35%, #b8916a 70%, #a07d54 100%); }
  .frame--wood-dark    {
    background: linear-gradient(135deg, #2a1810 0%, #3d2418 35%, #2a1810 70%, #1a0e08 100%);
    box-shadow:
      0 16px 30px -10px rgba(20,10,4,.55),
      0 6px 12px rgba(20,10,4,.30);
  }
  .frame--wood-gold    {
    background: linear-gradient(135deg, #d4ad5e 0%, #b8893f 40%, #e6c684 70%, #9a7030 100%);
    box-shadow:
      0 16px 30px -10px rgba(120,80,20,.45),
      0 6px 12px rgba(120,80,20,.25);
  }
  /* Tighter padding on mobile so the frames don't dwarf the artwork */
  @media (max-width: 767.98px) {
    .frame--framed { padding: 6px; }
  }

  /* Centre hero card */
  .hero-wall__card {
    position: absolute;
    left: 50%; top: 50%;
    transform: translate(-50%, -50%);
    width: 82%; max-width: 320px;
    padding: 24px 22px 22px;
    background: rgba(255, 253, 247, .96);
    border: 1px solid rgba(40, 28, 16, .06);
    backdrop-filter: blur(2px);
    border-radius: 8px;
    text-align: center;
    box-shadow:
      0 20px 44px -10px rgba(40,28,16,.35),
      0 6px 14px rgba(40,28,16,.18);
    z-index: 2;
  }
  @media (min-width: 768px) {
    .hero-wall__card {
      top: 46%;
      max-width: 520px; width: 60%;
      padding: 40px 48px 36px;
      box-shadow:
        0 24px 60px -12px rgba(40,28,16,.35),
        0 8px 18px rgba(40,28,16,.18);
    }
  }
  .hero-wall__title {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--ink);
    line-height: 1.05;
    font-size: clamp(2rem, 5.4vw, 3.4rem);
  }
  .hero-wall__sub {
    font-family: var(--font-body);
