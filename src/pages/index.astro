  body.js-anim .samples__panel.is-entering .sample-card:nth-child(2) .sample-card__plaque { animation: plaque-up 0.4s ease both 220ms; }
  body.js-anim .samples__panel.is-entering .sample-card:nth-child(3) .sample-card__plaque { animation: plaque-up 0.4s ease both 340ms; }

