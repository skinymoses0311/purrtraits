  /* ======================================================================
     ANIMATIONS
     ---------------------------------------------------------------------
     Initial opacity:0 rules are gated by body.js-anim (set synchronously by
     an inline script at the top of the body) so users without JS still
     see the page rendered.
     ====================================================================== */

  /* Keyframes ---------------------------------------------------------- */
  @keyframes frame-enter {
    from { opacity: 0; transform: translateY(28px) rotate(var(--frame-rot, 0deg)); }
    to   { opacity: 1; transform: translateY(0)    rotate(var(--frame-rot, 0deg)); }
  }
  @keyframes card-enter {
    0%   { opacity: 0; transform: translate(-50%, -50%) scale(0.92); }
    60%  { opacity: 1; transform: translate(-50%, -50%) scale(1.04); }
    100% { opacity: 1; transform: translate(-50%, -50%) scale(1);    }
  }
  @keyframes word-up {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes circle-bounce {
    0%   { opacity: 0; transform: scale(0)    rotate(var(--rot, 0deg)); }
    55%  { opacity: 1; transform: scale(1.18) rotate(var(--rot, 0deg)); }
    75%  { transform: scale(0.92) rotate(var(--rot, 0deg)); }
    100% { transform: scale(1)    rotate(var(--rot, 0deg)); }
  }
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes arrow-draw {
    from { stroke-dashoffset: var(--dash-len, 300); }
    to   { stroke-dashoffset: 0; }
  }
  @keyframes card-slide-up {
    from { opacity: 0; transform: translateY(24px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0)    scale(1); }
  }
  @keyframes plaque-up {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes eyebrow-in {
    from { opacity: 0; letter-spacing: 0.1em; }
    to   { opacity: 1; letter-spacing: 0.25em; }
  }
  @keyframes panel-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* PART 1 — Hero wall (page-load) ------------------------------------- */
  body.js-anim .hero-wall .frame { opacity: 0; }
  .hero-wall .frame.is-visible {
    animation: frame-enter 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    animation-delay: calc(var(--i, 0) * 90ms);
  }

  body.js-anim .hero-wall__card { opacity: 0; }
  .hero-wall__card.is-visible {
    animation: card-enter 0.6s cubic-bezier(0.34, 1.4, 0.64, 1) both;
  }

  .hero-wall__title .hw { display: inline-block; }
  body.js-anim .hero-wall__title .hw { opacity: 0; }
  .hero-wall__title .hw.is-visible {
    animation: word-up 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  body.js-anim .hero-wall__sub,
  body.js-anim .hero-wall__note {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .hero-wall__sub.is-visible,
  .hero-wall__note.is-visible { opacity: 1; transform: translateY(0); }

  /* PART 2 — How it works (scroll-triggered) --------------------------- */
  /* Carry the existing per-step static rotation onto a CSS var so the
     circle-bounce keyframe keeps it through the final state. */
  .how-step:nth-child(1) .how-step__circle { --rot: -2deg; }
  .how-step:nth-child(3) .how-step__circle { --rot:  2deg; }
  .how-step:nth-child(5) .how-step__circle { --rot: -1deg; }
  .how-step:nth-child(7) .how-step__circle { --rot:  1deg; }
  .how-step:nth-child(9) .how-step__circle { --rot: -2deg; }

  body.js-anim .how-step__circle { opacity: 0; }
  .how--visible .how-step__circle {
    animation: circle-bounce 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  .how--visible .how-step:nth-child(1) .how-step__circle { animation-delay: 0ms; }
  .how--visible .how-step:nth-child(3) .how-step__circle { animation-delay: 100ms; }
  .how--visible .how-step:nth-child(5) .how-step__circle { animation-delay: 200ms; }
  .how--visible .how-step:nth-child(7) .how-step__circle { animation-delay: 300ms; }
  .how--visible .how-step:nth-child(9) .how-step__circle { animation-delay: 400ms; }

  body.js-anim .how-step__title,
  body.js-anim .how-step__blurb { opacity: 0; }
  .how--visible .how-step__title { animation: fade-up 0.4s ease both; }
  .how--visible .how-step__blurb { animation: fade-up 0.35s ease both; }
  .how--visible .how-step:nth-child(1) .how-step__title { animation-delay: 80ms; }
  .how--visible .how-step:nth-child(1) .how-step__blurb { animation-delay: 120ms; }
  .how--visible .how-step:nth-child(3) .how-step__title { animation-delay: 180ms; }
