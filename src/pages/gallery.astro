---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Your gallery · Purrtraits"
  description="Your saved portraits."
  noindex
>
  <main class="page container">
    <header class="g-head">
      <div>
        <h1>Your gallery</h1>
        <p class="g-sub" id="meta">Saved portraits from this session.</p>
      </div>
      <a href="/upload" class="btn btn--primary g-cta" id="cta-new">✨ Create another portrait</a>
    </header>

    <!-- Desktop filter bar: one dropdown chip per facet -->
    <div class="g-filterbar" id="filterbar" hidden>
      <span class="g-filterbar__label">Filter</span>
      <div class="g-filterbar__chips" id="filter-chips"></div>
    </div>

    <!-- Mobile filter trigger: one button → bottom sheet -->
    <div class="g-mobiletrigger" id="mobile-trigger" hidden>
      <button type="button" class="g-mobiletrigger__btn" id="mobile-filter-btn">
        <span class="g-mobiletrigger__label">
          <span aria-hidden="true">⚙</span>
          <span>Filters</span>
          <span class="g-mobiletrigger__count" id="mobile-filter-count" hidden>0</span>
        </span>
        <span class="g-mobiletrigger__caret" aria-hidden="true">▸</span>
      </button>
    </div>

    <!-- Active chips row (both layouts) -->
    <div class="g-activechips" id="active-chips" hidden></div>

    <!-- Empty state -->
    <div id="empty" class="g-empty" hidden>
      <p class="display g-empty__title">No portraits yet</p>
      <p class="muted">Upload some photos and we'll generate four styles for you.</p>
      <a href="/upload" class="btn btn--primary">✨ Start now</a>
    </div>

    <!-- No-results state (after filters applied) -->
    <div id="noresults" class="g-empty g-empty--noresults" hidden>
      <p class="display g-empty__title">No matches</p>
      <p class="muted">Try removing a filter to see more portraits.</p>
      <button type="button" class="btn btn--primary" id="noresults-clear">Clear all filters</button>
    </div>

    <!-- Card grid -->
    <div class="g-grid" id="grid"></div>

    <p class="g-foot">
      Portraits are saved for this session ·
      <a href="/upload" class="g-foot__link">Make another portrait →</a>
    </p>

    <!-- Mobile bottom sheet -->
    <div class="g-sheet" id="filter-sheet" hidden role="dialog" aria-modal="true" aria-labelledby="filter-sheet-title">
      <div class="g-sheet__backdrop" data-sheet-close></div>
      <div class="g-sheet__panel">
        <div class="g-sheet__handle" aria-hidden="true"></div>
        <div class="g-sheet__head">
          <h2 class="g-sheet__title" id="filter-sheet-title">Filters</h2>
          <button type="button" class="g-sheet__clear" id="sheet-clear-all" hidden>Clear all</button>
        </div>
        <div class="g-sheet__body" id="sheet-body"></div>
        <div class="g-sheet__foot">
          <button type="button" class="g-sheet__reset" id="sheet-reset">Reset</button>
          <button type="button" class="g-sheet__apply" id="sheet-apply">Show all portraits</button>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { makeClient, getSessionId, setSessionId, disableImageGrabbers, attachImageLoading, ensureSession } from "../lib/client.ts";
  import { isSignedIn, makeAuthedClient } from "../lib/authStorage.ts";
  import { api } from "../../convex/_generated/api.js";
  import type { Id } from "../../convex/_generated/dataModel";
  import { ALL_STYLES, STYLE_LABELS, type Style } from "../../convex/styleScoring.ts";
  import { ALL_ARTISTS, ARTIST_LABELS, type Artist } from "../../convex/artistScoring.ts";
  import { getStyleDisplay, type ArtworkLookup } from "../../convex/displayLabels.ts";
  import { track } from "../lib/analytics.ts";

  // Loaded once per page (see ensureSession below). Populated for Tab 3
  // gallery items so their compound style keys
  // ("artwork:starry_night:hilltop") render as the artwork title and
  // placement label. STYLE_LABELS / ARTIST_LABELS keep handling Tab 1/2 keys
  // directly inside the filter UI because those vocabularies are static.
  let artworkLookup: ArtworkLookup = {};
  import {
    ensureCurrencyForSession,
    onCurrencyChange,
    formatMoney,
    type Currency,
  } from "../lib/currency.ts";

  // Activity / mood vocabularies match the quiz exactly. Anything outside
  // these lists falls through to the raw value at render time.
  const ACTIVITY_OPTIONS: Array<{ key: string; label: string; emoji: string }> = [
    { key: "regal",        label: "Regal",      emoji: "👑" },
    { key: "playing",      label: "Playing",    emoji: "🎾" },
    { key: "napping",      label: "Napping",    emoji: "💤" },
    { key: "adventuring",  label: "Adventure",  emoji: "🏔️" },
    { key: "tongue-out",   label: "Tongue out", emoji: "👅" },
    { key: "zoomies",      label: "Zoomies",    emoji: "💨" },
  ];
  const MOOD_OPTIONS: Array<{ key: string; label: string; emoji: string }> = [
    { key: "calm",      label: "Calm",     emoji: "😌" },
    { key: "playful",   label: "Playful",  emoji: "😄" },
    { key: "regal",     label: "Regal",    emoji: "👑" },
    { key: "quirky",    label: "Quirky",   emoji: "🤪" },
    { key: "cheeky",    label: "Cheeky",   emoji: "😏" },
    { key: "brooding",  label: "Brooding", emoji: "🌙" },
  ];
  const ACTIVITY_LABEL = (k: string) =>
    ACTIVITY_OPTIONS.find((o) => o.key === k)
      ? `${ACTIVITY_OPTIONS.find((o) => o.key === k)!.emoji} ${ACTIVITY_OPTIONS.find((o) => o.key === k)!.label}`
      : k;
  const MOOD_LABEL = (k: string) =>
    MOOD_OPTIONS.find((o) => o.key === k)
      ? `${MOOD_OPTIONS.find((o) => o.key === k)!.emoji} ${MOOD_OPTIONS.find((o) => o.key === k)!.label}`
      : k;

  type FacetKey = "style" | "artist" | "activity" | "mood";
  type FacetOption = { key: string; label: string; emoji?: string };
  type FacetGroup = { key: FacetKey; label: string; options: FacetOption[] };

  // Build the four filter groups. Style + Artist combine as a UNION when
  // matched against `item.style` (the field holds either vocabulary).
  const FACETS: FacetGroup[] = [
    {
      key: "style",
      label: "Style",
      options: ALL_STYLES.map((s) => ({ key: s, label: STYLE_LABELS[s] })),
    },
    {
      key: "artist",
      label: "Artist",
      options: ALL_ARTISTS.map((a) => ({ key: a, label: ARTIST_LABELS[a] })),
    },
    {
      key: "activity",
      label: "Activity",
      options: ACTIVITY_OPTIONS.map((o) => ({ key: o.key, label: o.label, emoji: o.emoji })),
    },
    {
      key: "mood",
      label: "Mood",
      options: MOOD_OPTIONS.map((o) => ({ key: o.key, label: o.label, emoji: o.emoji })),
    },
  ];

  const sessionId = getSessionId();
  const userScoped = isSignedIn();
  const client = userScoped ? makeAuthedClient() : makeClient();

  const grid = document.getElementById("grid")!;
  const empty = document.getElementById("empty")!;
  const noresults = document.getElementById("noresults")!;
  const meta = document.getElementById("meta")!;
  const filterbar = document.getElementById("filterbar")!;
  const filterChips = document.getElementById("filter-chips")!;
  const mobileTrigger = document.getElementById("mobile-trigger")!;
  const mobileBtn = document.getElementById("mobile-filter-btn") as HTMLButtonElement;
  const mobileCount = document.getElementById("mobile-filter-count")!;
  const activeChips = document.getElementById("active-chips")!;
  const ctaNew = document.getElementById("cta-new")!;
  const foot = document.querySelector(".g-foot") as HTMLElement;
  const sheet = document.getElementById("filter-sheet")!;
  const sheetBody = document.getElementById("sheet-body")!;
  const sheetClearAll = document.getElementById("sheet-clear-all") as HTMLButtonElement;
  const sheetReset = document.getElementById("sheet-reset") as HTMLButtonElement;
  const sheetApply = document.getElementById("sheet-apply") as HTMLButtonElement;
  const noresultsClear = document.getElementById("noresults-clear") as HTMLButtonElement;

  type Item = {
    style: string;
    imageUrl: string;
    printFileUrl?: string;
    activity?: string;
    mood?: string;
    petName?: string;
    createdAt: number;
    _index: number;
    sessionId?: string;
  };

  let allItems: Item[] = [];
  // Selection state per facet. Empty set = no filter for that facet.
  const selected: Record<FacetKey, Set<string>> = {
    style: new Set(),
    artist: new Set(),
    activity: new Set(),
    mood: new Set(),
  };
  let openFacet: FacetKey | null = null;

  // ── Currency resolution (unchanged) ───────────────────────────
  let currency: Currency = "usd";
  let fromLabel: string = "";
  async function resolveFromLabel(c: Currency): Promise<string> {
    try {
      const products = await client.query(api.products.list, {});
      const digital = products.find((p: any) => p.format === "digital");
      const cents = digital?.prices?.[c];
      if (typeof cents !== "number") return "";
      return `From ${formatMoney(cents, c)}`;
    } catch {
      return "";
    }
  }
  currency = await ensureCurrencyForSession(client, sessionId);
  fromLabel = await resolveFromLabel(currency);
  onCurrencyChange(async (next) => {
    currency = next;
    fromLabel = await resolveFromLabel(next);
    renderGrid();
  });

  // ── Data load ─────────────────────────────────────────────────
  // Pre-load the artwork title/placement lookup once so Tab 3 cards render
  // their full label inline. Public query, harmless if empty.
  artworkLookup = (await client.query(api.artworks.getLookup, {})) ?? {};

  if (userScoped) {
    const userItems = await client.query(api.sessions.getUserGallery, {});
    if (!userItems || userItems.length === 0) {
      showEmpty();
    } else {
      allItems = userItems.map((it: any) => ({
        style: it.style,
        imageUrl: it.imageUrl,
        printFileUrl: it.printFileUrl,
        activity: it.activity,
        mood: it.mood,
        petName: it.petName,
        createdAt: it.createdAt,
        sessionId: it.sessionId,
        _index: it.index,
      }));
      renderHeaderMeta(true);
      mountFilterUI();
      renderGrid();
    }
  } else if (!sessionId) {
    showEmpty();
  } else {
    const session = await client.query(api.sessions.get, { id: sessionId as any });
    const items = session?.galleryItems ?? [];
    if (items.length === 0) {
      showEmpty();
    } else {
      allItems = [...items]
        .map((it: any, i: number) => ({ ...it, _index: i }))
        .reverse();
      renderHeaderMeta(false);
      mountFilterUI();
      renderGrid();
    }
  }

  // ── Header / empty state ──────────────────────────────────────
  function renderHeaderMeta(isUserScoped: boolean) {
    const scope = isUserScoped ? "across your account" : "this session";
    meta.textContent = `${allItems.length} portrait${allItems.length === 1 ? "" : "s"} ${scope}`;
  }

  function showEmpty() {
    empty.hidden = false;
    ctaNew.style.display = "none";
    filterbar.hidden = true;
    mobileTrigger.hidden = true;
    foot.style.display = "none";
  }

  // ── Filter UI mount ───────────────────────────────────────────
  // Hide options whose key has zero matches in the user's gallery, so the
  // filter dropdowns only surface useful choices.
  function visibleOptions(group: FacetGroup): FacetOption[] {
    return group.options.filter((o) => {
      if (group.key === "style" || group.key === "artist") {
        return allItems.some((it) => it.style === o.key);
      }
      if (group.key === "activity") return allItems.some((it) => it.activity === o.key);
      if (group.key === "mood") return allItems.some((it) => it.mood === o.key);
      return false;
    });
  }

  function activeFacets(): FacetGroup[] {
    return FACETS.map((g) => ({ ...g, options: visibleOptions(g) }))
      .filter((g) => g.options.length > 0);
  }

  function mountFilterUI() {
    filterbar.hidden = false;
    mobileTrigger.hidden = false;
    renderFilterBar();
    renderActiveChips();
    renderSheet();
    wireSheet();

    // One delegated click handler closes any open desktop popover when the
    // user clicks outside it. Listen on mousedown so it fires before the
    // chip's own click toggles the popover state back open.
    document.addEventListener("mousedown", (e) => {
      if (openFacet === null) return;
      const target = e.target as Element;
      if (target.closest(".g-fchip") || target.closest(".g-fpop")) return;
      openFacet = null;
      renderFilterBar();
    });
  }

  // ── Desktop filter bar ────────────────────────────────────────
  function escapeHtml(s: string) {
    return s.replace(/[&<>"']/g, (c) => ({
      "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
    }[c]!));
  }

  function renderFilterBar() {
    filterChips.innerHTML = "";
    const facets = activeFacets();
    for (const g of facets) {
      const sel = selected[g.key];
      const isActive = sel.size > 0;
      const isOpen = openFacet === g.key;
      const wrap = document.createElement("div");
      wrap.className = "g-fchip-wrap";
      wrap.innerHTML = `
        <button type="button"
                class="g-fchip${isActive ? " g-fchip--active" : ""}${isOpen ? " g-fchip--open" : ""}"
                data-facet="${g.key}"
                aria-haspopup="true"
                aria-expanded="${isOpen}">
          <span>${escapeHtml(g.label)}</span>
          ${isActive ? `<span class="g-fchip__count">${sel.size}</span>` : ""}
          <span class="g-fchip__caret" aria-hidden="true">${isOpen ? "▴" : "▾"}</span>
        </button>
        ${isOpen ? popoverHtml(g) : ""}
      `;
      filterChips.appendChild(wrap);
    }
    // Bind chip clicks
    filterChips.querySelectorAll<HTMLButtonElement>(".g-fchip").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const key = btn.dataset.facet as FacetKey;
        openFacet = openFacet === key ? null : key;
        renderFilterBar();
      });
    });
    // Bind option toggles inside any open popover
    filterChips.querySelectorAll<HTMLLabelElement>(".g-fopt").forEach((opt) => {
      opt.addEventListener("click", (e) => {
        e.stopPropagation();
        const key = opt.dataset.facet as FacetKey;
        const val = opt.dataset.value!;
        toggleFacet(key, val);
      });
    });
    // Per-popover Clear button
    filterChips.querySelectorAll<HTMLButtonElement>(".g-fpop__clear").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const key = btn.dataset.facet as FacetKey;
        clearFacet(key);
      });
    });
  }

  function popoverHtml(group: FacetGroup): string {
    const sel = selected[group.key];
    const opts = group.options.map((o) => {
      const checked = sel.has(o.key);
      return `
        <label class="g-fopt${checked ? " g-fopt--checked" : ""}"
               data-facet="${group.key}" data-value="${escapeHtml(o.key)}">
          <span class="g-fopt__check">${checked ? "✓" : ""}</span>
          ${o.emoji ? `<span class="g-fopt__emoji">${o.emoji}</span>` : ""}
          <span class="g-fopt__label">${escapeHtml(o.label)}</span>
        </label>
      `;
    }).join("");
    return `
      <div class="g-fpop" role="listbox">
        <div class="g-fpop__head">
          <span class="g-fpop__title">${escapeHtml(group.label)}</span>
          ${sel.size > 0 ? `<button type="button" class="g-fpop__clear" data-facet="${group.key}">Clear</button>` : ""}
        </div>
        <div class="g-fpop__list">${opts}</div>
      </div>
    `;
  }

  // ── Active chips row ──────────────────────────────────────────
  function totalSelected(): number {
    return (Object.values(selected) as Set<string>[]).reduce((n, s) => n + s.size, 0);
  }

  function activeChipLabel(facet: FacetKey, value: string): { label: string; emoji?: string } {
    if (facet === "style") return { label: STYLE_LABELS[value as Style] ?? value };
    if (facet === "artist") return { label: ARTIST_LABELS[value as Artist] ?? value };
    if (facet === "activity") {
      const o = ACTIVITY_OPTIONS.find((x) => x.key === value);
      return o ? { label: o.label, emoji: o.emoji } : { label: value };
    }
    if (facet === "mood") {
      const o = MOOD_OPTIONS.find((x) => x.key === value);
      return o ? { label: o.label, emoji: o.emoji } : { label: value };
    }
    return { label: value };
  }

  function renderActiveChips() {
    const total = totalSelected();
    activeChips.hidden = total === 0;
    activeChips.innerHTML = "";
    if (total === 0) {
      mobileCount.hidden = true;
      mobileBtn.classList.remove("g-mobiletrigger__btn--active");
      return;
    }
    mobileCount.hidden = false;
    mobileCount.textContent = String(total);
    mobileBtn.classList.add("g-mobiletrigger__btn--active");
    const counter = document.createElement("span");
    counter.className = "g-activechips__counter";
    counter.textContent = `${total} active`;
    activeChips.appendChild(counter);
    (Object.keys(selected) as FacetKey[]).forEach((k) => {
      selected[k].forEach((v) => {
        const meta = activeChipLabel(k, v);
        const chip = document.createElement("button");
        chip.type = "button";
        chip.className = "g-achip";
        chip.dataset.facet = k;
        chip.dataset.value = v;
        chip.innerHTML = `
          ${meta.emoji ? `<span class="g-achip__emoji">${meta.emoji}</span>` : ""}
          <span class="g-achip__label">${escapeHtml(meta.label)}</span>
          <span class="g-achip__x" aria-hidden="true">✕</span>
          <span class="sr-only">Remove ${escapeHtml(meta.label)}</span>
        `;
        chip.addEventListener("click", () => toggleFacet(k, v));
        activeChips.appendChild(chip);
      });
    });
    const clear = document.createElement("button");
    clear.type = "button";
    clear.className = "g-activechips__clear";
    clear.textContent = "Clear all";
    clear.addEventListener("click", () => clearAll());
    activeChips.appendChild(clear);
  }

  // ── Mobile bottom sheet ───────────────────────────────────────
  function renderSheet() {
    const total = totalSelected();
    sheetClearAll.hidden = total === 0;
    sheetApply.textContent = total > 0 ? "Show matching portraits" : "Show all portraits";
    sheetBody.innerHTML = activeFacets().map(sheetGroupHtml).join("");
    sheetBody.querySelectorAll<HTMLButtonElement>(".g-spill").forEach((btn) => {
      btn.addEventListener("click", () => {
        const key = btn.dataset.facet as FacetKey;
        const val = btn.dataset.value!;
        toggleFacet(key, val);
      });
    });
  }

  function sheetGroupHtml(group: FacetGroup): string {
    const sel = selected[group.key];
    const pills = group.options.map((o) => {
      const checked = sel.has(o.key);
      return `
        <button type="button"
                class="g-spill${checked ? " g-spill--checked" : ""}"
                data-facet="${group.key}" data-value="${escapeHtml(o.key)}">
          ${o.emoji ? `<span class="g-spill__emoji">${o.emoji}</span>` : ""}
          <span>${escapeHtml(o.label)}</span>
          ${checked ? `<span class="g-spill__check" aria-hidden="true">✓</span>` : ""}
        </button>
      `;
    }).join("");
    return `
      <div class="g-sgroup">
        <div class="g-sgroup__head">
          <span class="g-sgroup__label">${escapeHtml(group.label)}</span>
          ${sel.size > 0 ? `<span class="g-sgroup__count">${sel.size} selected</span>` : ""}
        </div>
        <div class="g-sgroup__pills">${pills}</div>
      </div>
    `;
  }

  function wireSheet() {
    function openSheet() {
      sheet.hidden = false;
      // Keep body from scrolling underneath the sheet on mobile.
      document.body.style.overflow = "hidden";
    }
    function closeSheet() {
      sheet.hidden = true;
      document.body.style.overflow = "";
    }
    mobileBtn.addEventListener("click", openSheet);
    sheet.querySelectorAll<HTMLElement>("[data-sheet-close]").forEach((el) => {
      el.addEventListener("click", closeSheet);
    });
    sheetReset.addEventListener("click", () => {
      clearAll();
    });
    sheetApply.addEventListener("click", () => {
      closeSheet();
    });
    sheetClearAll.addEventListener("click", () => {
      clearAll();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !sheet.hidden) closeSheet();
    });
  }

  // ── Selection mutators ────────────────────────────────────────
  function toggleFacet(key: FacetKey, val: string) {
    if (selected[key].has(val)) {
      selected[key].delete(val);
    } else {
      selected[key].add(val);
      track("gallery_filter_applied", { facet: key, value: val });
    }
    renderFilterBar();
    renderActiveChips();
    renderSheet();
    renderGrid();
  }

  function clearFacet(key: FacetKey) {
    selected[key].clear();
    renderFilterBar();
    renderActiveChips();
    renderSheet();
    renderGrid();
  }

  function clearAll() {
    (Object.keys(selected) as FacetKey[]).forEach((k) => selected[k].clear());
    renderFilterBar();
    renderActiveChips();
    renderSheet();
    renderGrid();
  }

  noresultsClear.addEventListener("click", () => clearAll());

  // ── Card label resolution ─────────────────────────────────────
  // The `style` field on a gallery item holds either a style slug or an
  // artist slug — never both. Resolve to the right human label and to a
  // facet kind so analytics + UI can branch correctly.
  function resolveAesthetic(slug: string): { label: string; kind: "style" | "artist" | "artwork" | "unknown" } {
    if ((ALL_STYLES as readonly string[]).includes(slug)) {
      return { label: STYLE_LABELS[slug as Style], kind: "style" };
    }
    if ((ALL_ARTISTS as readonly string[]).includes(slug)) {
      return { label: ARTIST_LABELS[slug as Artist], kind: "artist" };
    }
    // Tab 3 (Famous Art) — compound key. getStyleDisplay falls back to a
    // humanised slug when the lookup is empty (e.g. catalog row was
    // disabled) so a missing artwork doesn't ship a raw `artwork:foo:bar`
    // string to the user.
    if (slug.startsWith("artwork:")) {
      return { label: getStyleDisplay(slug, artworkLookup), kind: "artwork" };
    }
    return { label: slug, kind: "unknown" };
  }

  // ── Filter logic ──────────────────────────────────────────────
  // Style + Artist combine as a UNION against item.style. Activity and
  // Mood each AND across groups. Within a group, multiple selections OR.
  function matches(it: Item): boolean {
    const aestheticPicks = new Set<string>([...selected.style, ...selected.artist]);
    if (aestheticPicks.size > 0 && !aestheticPicks.has(it.style)) return false;
    if (selected.activity.size > 0 && !(it.activity && selected.activity.has(it.activity))) return false;
    if (selected.mood.size > 0 && !(it.mood && selected.mood.has(it.mood))) return false;
    return true;
  }

  // ── Grid render ───────────────────────────────────────────────
  function renderGrid() {
    const visible = allItems.filter(matches);

    if (visible.length === 0 && allItems.length > 0) {
      grid.hidden = true;
      noresults.hidden = false;
      return;
    }
    grid.hidden = false;
    noresults.hidden = true;

    grid.innerHTML = "";
    visible.forEach((it) => {
      const card = document.createElement("article");
      card.className = "g-card";
      const aesthetic = resolveAesthetic(it.style);
      const titleText = it.petName ? `${it.petName} · ${aesthetic.label}` : aesthetic.label;
      const activityLabel = it.activity ? ACTIVITY_LABEL(it.activity) : "";
      const moodLabel = it.mood ? MOOD_LABEL(it.mood) : "";
      const showMood = moodLabel && moodLabel !== activityLabel;
      const tags =
        activityLabel || showMood
          ? `<div class="g-card__tags">
               ${activityLabel ? `<span class="g-card__tag">${escapeHtml(activityLabel)}</span>` : ""}
               ${showMood ? `<span class="g-card__tag">${escapeHtml(moodLabel)}</span>` : ""}
             </div>`
          : "";
      card.innerHTML = `
        <div class="g-card__media protected-wrap is-loading is-loading--hero">
          <img src="${it.imageUrl}" alt="" class="g-card__img protected-img is-loading-img" />
          <div class="g-card__hover">🔍 Preview</div>
          ${tags}
        </div>
        <div class="g-card__body">
          <div class="g-card__row">
            <div>
              <p class="g-card__title">${escapeHtml(titleText)}</p>
              <p class="g-card__sub">Pick your format</p>
            </div>
            <p class="g-card__price">${escapeHtml(fromLabel)}</p>
          </div>
          <button class="btn btn--primary g-card__buy" data-i="${it._index}">Buy this one</button>
        </div>
      `;
      grid.appendChild(card);
    });

    disableImageGrabbers(grid);
    attachImageLoading(grid);

    grid.querySelectorAll<HTMLButtonElement>(".g-card__buy").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const i = parseInt(btn.dataset.i!);
        const item = visible.find((v) => v._index === i);
        if (item) {
          track("portrait_added_from_gallery", { style: item.style });
        }
        btn.disabled = true;
        btn.textContent = "Loading…";
        try {
          if (userScoped && item?.sessionId) {
            const targetSessionId = await ensureSession(client);
            await client.mutation(api.sessions.useFromUserGallery, {
              targetSessionId: targetSessionId,
              sourceSessionId: item.sessionId as Id<"sessions">,
              index: item._index,
            });
            setSessionId(targetSessionId);
          } else {
            await client.mutation(api.sessions.useFromGallery, {
              id: sessionId as any,
              index: i,
            });
          }
          window.location.href = "/pdp";
        } catch (err) {
          btn.disabled = false;
          btn.textContent = "Buy this one";
          alert((err as Error).message);
        }
      });
    });
  }
</script>

