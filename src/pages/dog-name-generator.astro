---
import Layout from "../layouts/Layout.astro";

// FAQ JSON-LD — surfaced as a structured-data block in <head> via the Layout's
// `jsonld` slot. Kept in lockstep with the visible FAQ section below.
const faq = [
  {
    q: "How does the dog name generator work?",
    a: "Tell us your dog's breed (or mix), whether they're a boy or a girl, and which name styles you like — English & Germanic, Celtic, Romance, Slavic, Arabic, or East Asian. We'll match you with a shortlist of names from our curated set, each with its meaning, so you can find one that fits.",
  },
  {
    q: "Are the names suitable for any dog breed?",
    a: "Yes. We pick names by linguistic origin and gender, not by breed — so any of the names will work for any dog. We do use the breed for a couple of small touches: pre-suggesting an origin when your dog has an obvious one (like a Shiba Inu or French Bulldog), and personalising the email if you save your shortlist.",
  },
  {
    q: "What makes a good dog name?",
    a: "A good dog name is short (one or two syllables is ideal for recall), uses crisp consonants, and doesn't sound too close to a common command like 'sit' or 'no'. It should also still feel right when you call it across a park — say it out loud a few times before committing.",
  },
  {
    q: "Can I save my dog name shortlist?",
    a: "Yes. After you generate your shortlist, you can save it to a free Purrtraits account and we'll email you a copy so you can come back to it later. The generator itself is free and doesn't require an account.",
  },
  {
    q: "Will you use my email for marketing?",
    a: "No. The email you receive when you save a shortlist is transactional — it's the shortlist itself, sent because you asked for it. You're not subscribed to any marketing list.",
  },
  {
    q: "Are there cat names too?",
    a: "Not yet. We're starting with dogs and adding cats next — the structure is already there for it.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
};
---

<Layout
  title="Dog Name Generator · Find the right name for your dog · Purrtraits"
  description="Free dog name generator. Tell us your dog's breed, gender, and the name styles you like — Celtic, Romance, East Asian and more — and we'll suggest a shortlist with meanings. Save your favourites and turn your dog into a portrait."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} slot="jsonld" />

  <main class="page container dng">

    <header class="dng__hero">
      <h1 class="dng__title">Dog Name Generator</h1>
      <p class="dng__tagline">
        Find the right name for your dog — tell us their breed, whether they're
        a boy or a girl, and the kind of name you like. We'll suggest a curated
        shortlist with meanings.
      </p>
      <p class="dng__meta muted">
        Free · No account needed · Around 60 seconds
      </p>
    </header>

    <section class="dng__tool" aria-label="Dog name generator">
      <div class="quiz" id="dng-quiz" data-step="1">
        <div class="quiz__top">
          <div class="progress">
            <div class="progress__track"><div class="progress__fill" id="dng-fill" style="width:33%"></div></div>
            <span class="muted" id="dng-label">Step 1 of 3</span>
          </div>
        </div>

        <div id="dng-step"></div>

        <div class="quiz__footer">
          <button id="dng-prev" class="btn">← Previous</button>
          <button id="dng-next" class="btn btn--primary" disabled>Next →</button>
        </div>
      </div>

      <div id="dng-results" class="dng__results" hidden></div>
    </section>

    <article class="dng__editorial">
      <h2>How to choose a good dog name</h2>
      <p>
        The right name finds a balance between three things: it suits your dog,
        it works in the real world (the park, the vet's waiting room, in the
        middle of the night), and it still feels right in five years' time.
        Here's how to test the names on your shortlist before you commit.
      </p>

      <h3>Keep it short and crisp</h3>
      <p>
        Trainers consistently recommend one- or two-syllable names with a hard
        consonant — Finn, Daisy, Otis, Mei. They cut through ambient noise
        better than longer names and are easier for your dog to recognise as
        their own. Long, melodic names sound lovely on paper but tend to get
        shortened in daily life: Beatrix becomes Trixie, Theodore becomes Theo,
        Sebastian becomes Seb. If you'd shorten it anyway, you may as well
        start with the short form.
      </p>

      <h3>Avoid command rhymes</h3>
      <p>
        Stay away from anything that rhymes with the basics. <em>Kit</em>
        sounds too much like <em>sit</em>, <em>Beau</em> sounds too much like
        <em>no</em>, and anything ending in <em>-ay</em> can collide with
        <em>stay</em>. It's the kind of thing that doesn't seem like a problem
        until you're trying to recall your dog at the beach and they're hearing
        a confusing soup of similar sounds.
      </p>

      <h3>Say it out loud first</h3>
      <p>
        Try shouting the name across a room. Then say it sweetly. Then say it
        firmly. A name that only works in one tone of voice isn't going to
        survive contact with everyday life. The names that age best are the
        ones that sound natural at every volume — which is part of why classic
        UK favourites like Bella, Charlie, Luna and Milo show up at the top of
        the rankings year after year.
      </p>

      <h3>Most popular UK dog names</h3>
      <p>
        For reference, the most popular dog names in the UK over the past few
        years have included <strong>Bella</strong>, <strong>Luna</strong>,
        <strong>Daisy</strong>, <strong>Poppy</strong> and <strong>Lola</strong>
        for girls, and <strong>Charlie</strong>, <strong>Max</strong>,
        <strong>Milo</strong>, <strong>Buddy</strong> and <strong>Teddy</strong>
        for boys. They're popular for a reason — they're short, warm, and easy
        to say — but if you'd like something a bit less common, the generator
        above pulls from a wider set with cultural roots that match your dog.
      </p>

      <h3>Match the name to your dog</h3>
      <p>
        A name that nods to your dog's heritage is a quiet pleasure for the rest
        of their life — Yuki for a Shiba Inu, Bruno for a Cane Corso, Saoirse
        for an Irish setter. Worth trying the generator a few times: change the
        name style, see what comes up. And once you've chosen, you can
        <a href="/upload">turn your favourite photo of them into a portrait</a>
        with the name printed right on it — a nicer way to make it official than
        just writing it on the kibble bag.
      </p>

      <h2>Frequently asked questions</h2>
      <div class="dng__faq">
        {
          faq.map((item) => (
            <details class="dng__faq-item">
              <summary>{item.q}</summary>
              <p>{item.a}</p>
            </details>
          ))
        }
      </div>
    </article>

  </main>
</Layout>

<script>
  // Vanilla TS, mirroring the style-quiz pattern in /quiz.astro. The two
  // breed inputs are deliberately implemented independently for v1 — the
  // brief explicitly says the consolidation into a shared component is a
  // later, separate task (so the revenue-path quiz carries zero risk here).
  import { DOG_BREEDS } from "../lib/dogBreeds.ts";
  import { ConvexClient } from "convex/browser";
  import { api } from "../../convex/_generated/api.js";
  import {
    filterDogNames,
    shuffleDeterministic,
    NAME_ORIGINS,
    type NameOriginKey,
    type DogName,
  } from "../lib/dogNames.ts";
  import { originHintForBreed, originHintForBreeds } from "../lib/breedOriginHints.ts";
  import { track } from "../lib/analytics.ts";
  import { isSignedIn, getValidJwt } from "../lib/authStorage.ts";

  const PUBLIC_CONVEX_URL = import.meta.env.PUBLIC_CONVEX_URL as string;

  const MAX_CROSSBREEDS = 4;
  const MIN_CROSSBREEDS = 2;
  const MAX_STYLES = 3;
  const FIRST_NAME_COUNT = 12;
  const MORE_NAME_BATCH = 12;

  type BreedMode = "single" | "crossbreed" | "unknown";
  type Gender = "boy" | "girl" | "either";

  type Answers = {
    breedMode: BreedMode;
    breed?: string;
    breeds?: string[];
    gender?: Gender;
    styles: NameOriginKey[];
  };

  const answers: Answers = {
    breedMode: "single",
    styles: [],
  };

  // UI state held outside the answer object — what step we're on, whether
  // the step-3 hint has been auto-applied this session, etc.
  let step = 1;
  let stylesHintApplied = false;
  let lastShownCount = FIRST_NAME_COUNT;
  let lastShownNames: DogName[] = [];

  const TOTAL_STEPS = 3;

  const fill = document.getElementById("dng-fill") as HTMLDivElement;
  const stepLabel = document.getElementById("dng-label")!;
  const stepEl = document.getElementById("dng-step")!;
  const next = document.getElementById("dng-next") as HTMLButtonElement;
  const prev = document.getElementById("dng-prev") as HTMLButtonElement;
  const resultsEl = document.getElementById("dng-results")!;

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) =>
      ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c]!,
    );
  }

  // ─── Step 1: Breed ────────────────────────────────────────────────────
  function renderBreedStep() {
    const singleValue =
      answers.breedMode === "single" ? answers.breed ?? "" : "";
    stepEl.innerHTML = `
      <h2 class="dng__step-title">What breed is your dog?</h2>
      <p class="muted quiz__sub">Start typing — we'll narrow it down. Pick the closest match if it's a mix.</p>
      <div class="quiz__breed-wrap">
        <input id="dng-breed-input" class="input quiz__breed-input" type="text"
               placeholder="Start typing a breed…" autocomplete="off"
               value="${escapeHtml(singleValue)}" />
        <ul id="dng-breed-list" class="quiz__breed-list" hidden></ul>
      </div>
      <div id="dng-breed-chips" class="quiz__breed-chips" hidden></div>
      <p id="dng-breed-hint" class="quiz__breed-hint muted" hidden></p>
      <div class="quiz__breed-toggles">
        <label class="option option--toggle">
          <input id="dng-breed-pure" type="radio" name="dng-breed-mode" class="option__checkbox" />
          <span class="option__emoji">🐕</span>
          <div>
            <p class="display option__title">Purebreed</p>
            <p class="muted option__blurb">One specific breed</p>
          </div>
        </label>
        <label class="option option--toggle">
          <input id="dng-breed-cross" type="radio" name="dng-breed-mode" class="option__checkbox" />
          <span class="option__emoji">🐾</span>
          <div>
            <p class="display option__title">Crossbreed</p>
            <p class="muted option__blurb">A mix of breeds</p>
          </div>
        </label>
        <label class="option option--toggle">
          <input id="dng-breed-unknown" type="radio" name="dng-breed-mode" class="option__checkbox" />
          <span class="option__emoji">❓</span>
          <div>
            <p class="display option__title">I'm not sure</p>
            <p class="muted option__blurb">Skip this step</p>
          </div>
        </label>
      </div>
    `;

    const input = document.getElementById("dng-breed-input") as HTMLInputElement;
    const list = document.getElementById("dng-breed-list") as HTMLUListElement;
    const chips = document.getElementById("dng-breed-chips") as HTMLDivElement;
    const hint = document.getElementById("dng-breed-hint") as HTMLParagraphElement;
    const pureCb = document.getElementById("dng-breed-pure") as HTMLInputElement;
    const crossCb = document.getElementById("dng-breed-cross") as HTMLInputElement;
    const unknownCb = document.getElementById("dng-breed-unknown") as HTMLInputElement;

    pureCb.checked = answers.breedMode === "single";
    crossCb.checked = answers.breedMode === "crossbreed";
    unknownCb.checked = answers.breedMode === "unknown";

    let activeIndex = -1;

    function listOptions() {
      return Array.from(list.querySelectorAll<HTMLLIElement>(".quiz__breed-opt"));
    }
    function setActive(i: number) {
      const opts = listOptions();
      activeIndex = i;
      opts.forEach((el, idx) => el.classList.toggle("is-active", idx === i));
      if (i >= 0 && opts[i]) opts[i].scrollIntoView({ block: "nearest" });
    }
    function showMatches(query: string) {
      const q = query.trim().toLowerCase();
      if (!q) { list.hidden = true; list.innerHTML = ""; activeIndex = -1; return; }
      const taken = new Set(answers.breedMode === "crossbreed" ? answers.breeds ?? [] : []);
      const starts = DOG_BREEDS.filter((b) => !taken.has(b) && b.toLowerCase().startsWith(q));
      const contains = DOG_BREEDS.filter(
        (b) => !taken.has(b) && !b.toLowerCase().startsWith(q) && b.toLowerCase().includes(q),
      );
      const matches = [...starts, ...contains].slice(0, 8);
      if (matches.length === 0) { list.hidden = true; list.innerHTML = ""; activeIndex = -1; return; }
      list.innerHTML = matches
        .map((b) => `<li class="quiz__breed-opt" data-v="${escapeHtml(b)}">${escapeHtml(b)}</li>`)
        .join("");
      list.hidden = false;
      activeIndex = -1;
    }
    function pickBreed(picked: string) {
      if (answers.breedMode === "crossbreed") {
        const current = answers.breeds ?? [];
        if (current.includes(picked) || current.length >= MAX_CROSSBREEDS) return;
        answers.breeds = [...current, picked];
        updateBreedDisplay();
        input.value = "";
        list.hidden = true;
        renderChips();
        renderHint();
        recompute();
        input.focus();
      } else {
        answers.breed = picked;
        input.value = picked;
        list.hidden = true;
        recompute();
      }
    }
    function syncSingle() {
      const v = input.value.trim();
      const match = DOG_BREEDS.find((b) => b.toLowerCase() === v.toLowerCase());
      if (match) { answers.breed = match; delete answers.breeds; }
      else { delete answers.breed; delete answers.breeds; }
      recompute();
    }
    function renderChips() {
      const list = answers.breeds ?? [];
      if (answers.breedMode !== "crossbreed" || list.length === 0) {
        chips.hidden = true; chips.innerHTML = ""; return;
      }
      chips.hidden = false;
      chips.innerHTML = list
        .map(
          (b, i) => `
            <span class="chip-tag">
              <span>${escapeHtml(b)}</span>
              <button type="button" class="chip-tag__x" data-i="${i}" aria-label="Remove ${escapeHtml(b)}">×</button>
            </span>`,
        )
        .join("");
    }
    function renderHint() {
      if (answers.breedMode === "unknown") { hint.hidden = true; return; }
      if (answers.breedMode === "crossbreed") {
        const n = answers.breeds?.length ?? 0;
        if (n < MIN_CROSSBREEDS) {
          hint.textContent = `Pick ${MIN_CROSSBREEDS - n} more breed${MIN_CROSSBREEDS - n === 1 ? "" : "s"} to continue.`;
          hint.hidden = false;
        } else if (n >= MAX_CROSSBREEDS) {
          hint.textContent = `That's the max — ${MAX_CROSSBREEDS} breeds.`;
          hint.hidden = false;
        } else { hint.hidden = true; }
        return;
      }
      hint.hidden = true;
    }
    function recompute() {
      if (answers.breedMode === "unknown") { next.disabled = false; return; }
      if (answers.breedMode === "crossbreed") {
        const n = answers.breeds?.length ?? 0;
        next.disabled = n < MIN_CROSSBREEDS || n > MAX_CROSSBREEDS;
        return;
      }
      next.disabled = !answers.breed;
    }
    function updateBreedDisplay() {
      if (answers.breeds && answers.breeds.length >= MIN_CROSSBREEDS) {
        answers.breed = answers.breeds.join(" / ");
      } else if (answers.breedMode === "crossbreed") {
        delete answers.breed;
      }
    }
    function applyDisabled() {
      const disabled = answers.breedMode === "unknown";
      input.disabled = disabled;
      chips.classList.toggle("is-disabled", disabled);
      (input.closest(".quiz__breed-wrap") as HTMLElement | null)
        ?.classList.toggle("is-disabled", disabled);
    }

    input.addEventListener("input", () => {
      if (answers.breedMode === "unknown") return;
      showMatches(input.value);
      if (answers.breedMode !== "crossbreed") syncSingle();
    });
    input.addEventListener("focus", () => {
      if (answers.breedMode === "unknown") return;
      showMatches(input.value);
    });
    input.addEventListener("blur", () => setTimeout(() => (list.hidden = true), 120));
    input.addEventListener("keydown", (e) => {
      if (answers.breedMode === "unknown") return;
      if (e.key === "ArrowDown" || e.key === "ArrowUp") {
        if (list.hidden) showMatches(input.value);
        const opts = listOptions();
        if (opts.length === 0) return;
        e.preventDefault();
        const last = opts.length - 1;
        if (e.key === "ArrowDown") setActive(activeIndex < 0 ? 0 : (activeIndex + 1) % opts.length);
        else setActive(activeIndex < 0 ? last : (activeIndex - 1 + opts.length) % opts.length);
        return;
      }
      if (e.key === "Escape") {
        if (!list.hidden) { e.preventDefault(); list.hidden = true; activeIndex = -1; }
        return;
      }
      if (e.key === "Enter") {
        const opts = listOptions();
        if (!list.hidden && activeIndex >= 0 && opts[activeIndex]?.dataset.v) {
          e.preventDefault(); pickBreed(opts[activeIndex].dataset.v!); return;
        }
        if (answers.breedMode === "crossbreed") { e.preventDefault(); return; }
        if (!next.disabled) next.click();
      }
    });
    list.addEventListener("mousedown", (e) => {
      const t = (e.target as HTMLElement).closest<HTMLLIElement>(".quiz__breed-opt");
      if (!t?.dataset.v) return;
      e.preventDefault();
      pickBreed(t.dataset.v);
    });
    chips.addEventListener("click", (e) => {
      const t = (e.target as HTMLElement).closest<HTMLButtonElement>(".chip-tag__x");
      if (!t) return;
      const i = Number(t.dataset.i);
      if (Number.isNaN(i)) return;
      const cur = answers.breeds ?? [];
      const nxt = cur.filter((_, idx) => idx !== i);
      if (nxt.length === 0) delete answers.breeds; else answers.breeds = nxt;
      updateBreedDisplay();
      renderChips(); renderHint(); recompute();
    });

    function applyMode(mode: BreedMode) {
      answers.breedMode = mode;
      // Re-pre-select styles next time step 3 is visited.
      stylesHintApplied = false;
      if (mode === "crossbreed") {
        if (answers.breed && !answers.breeds) answers.breeds = [answers.breed];
        input.value = "";
        delete answers.breed;
        updateBreedDisplay();
      } else if (mode === "unknown") {
        delete answers.breed; delete answers.breeds; input.value = "";
      } else {
        delete answers.breeds; delete answers.breed; input.value = "";
      }
      list.hidden = true;
      applyDisabled(); renderChips(); renderHint(); recompute();
    }
    pureCb.addEventListener("change", () => { if (pureCb.checked) applyMode("single"); });
    crossCb.addEventListener("change", () => { if (crossCb.checked) applyMode("crossbreed"); });
    unknownCb.addEventListener("change", () => { if (unknownCb.checked) applyMode("unknown"); });

    applyDisabled(); renderChips(); renderHint();
    if (answers.breedMode === "single") syncSingle(); else recompute();
    if (answers.breedMode !== "unknown") input.focus();
  }

  // ─── Step 2: Gender ───────────────────────────────────────────────────
  function renderGenderStep() {
    const options: Array<{ v: Gender; e: string; t: string; b: string }> = [
      { v: "boy",    e: "💙", t: "Boy",    b: "He / him" },
      { v: "girl",   e: "💖", t: "Girl",   b: "She / her" },
      { v: "either", e: "✨", t: "Either", b: "Show me unisex options" },
    ];
    stepEl.innerHTML = `
      <h2 class="dng__step-title">Is your dog a boy or a girl?</h2>
      <p class="muted quiz__sub">We'll filter names to match.</p>
      <div class="quiz__grid">
        ${options
          .map(
            (o) => `
              <button class="option ${answers.gender === o.v ? "option--active" : ""}" data-v="${o.v}">
                <span class="option__emoji">${o.e}</span>
                <div>
                  <p class="display option__title">${o.t}</p>
                  <p class="muted option__blurb">${o.b}</p>
                </div>
              </button>`,
          )
          .join("")}
      </div>
    `;
    stepEl.querySelectorAll<HTMLButtonElement>(".option").forEach((btn) => {
      btn.addEventListener("click", () => {
        answers.gender = btn.dataset.v as Gender;
        stepEl.querySelectorAll(".option").forEach((el) => el.classList.toggle("option--active", el === btn));
        next.disabled = false;
      });
    });
    next.disabled = !answers.gender;
  }

  // ─── Step 3: Name style (multi-select, capped at 3) ───────────────────
  function renderStyleStep() {
    // First entry to step 3 after a breed change: try the auto-pre-select.
    if (!stylesHintApplied) {
      stylesHintApplied = true;
      if (answers.styles.length === 0) {
        const hinted = answers.breedMode === "crossbreed"
          ? originHintForBreeds(answers.breeds)
          : answers.breedMode === "single"
            ? originHintForBreed(answers.breed)
            : null;
        if (hinted) answers.styles = [hinted];
      }
    }

    stepEl.innerHTML = `
      <h2 class="dng__step-title">What style of name do you like?</h2>
      <p class="muted quiz__sub">Pick up to ${MAX_STYLES}. We'll mix names from your choices.</p>
      <div class="dng__styles">
        ${NAME_ORIGINS
          .map(
            (o) => `
              <button class="dng__style ${answers.styles.includes(o.key) ? "dng__style--active" : ""}" data-v="${o.key}">
                <div class="dng__style-head">
                  <span class="dng__style-label">${escapeHtml(o.label)}</span>
                  <span class="dng__style-tick" aria-hidden="true">✓</span>
                </div>
                <p class="dng__style-blurb muted">${escapeHtml(o.blurb)}</p>
                <p class="dng__style-examples muted">${o.examples.map((x) => escapeHtml(x)).join(" · ")}</p>
              </button>`,
          )
          .join("")}
      </div>
      <p class="dng__style-count muted" id="dng-style-count"></p>
    `;
    const countEl = document.getElementById("dng-style-count")!;
    function updateCount() {
      const n = answers.styles.length;
      countEl.textContent = n === 0
        ? `Pick at least one to continue.`
        : `${n} selected${n >= MAX_STYLES ? ` (max ${MAX_STYLES})` : ""}.`;
      next.disabled = n === 0;
      next.textContent = "See my names →";
    }
    stepEl.querySelectorAll<HTMLButtonElement>(".dng__style").forEach((btn) => {
      btn.addEventListener("click", () => {
        const key = btn.dataset.v as NameOriginKey;
        const idx = answers.styles.indexOf(key);
        if (idx >= 0) {
          answers.styles.splice(idx, 1);
          btn.classList.remove("dng__style--active");
        } else {
          if (answers.styles.length >= MAX_STYLES) return;
          answers.styles.push(key);
          btn.classList.add("dng__style--active");
        }
        updateCount();
      });
    });
    updateCount();
  }

  function showStep(n: number) {
    step = n;
    fill.style.width = `${(n / TOTAL_STEPS) * 100}%`;
    stepLabel.textContent = `Step ${n} of ${TOTAL_STEPS}`;
    prev.style.visibility = n === 1 ? "hidden" : "visible";
    next.textContent = n === TOTAL_STEPS ? "See my names →" : "Next →";
    if (n === 1) renderBreedStep();
    else if (n === 2) renderGenderStep();
    else renderStyleStep();
  }

  // ─── Results ──────────────────────────────────────────────────────────

  function buildHeading(): string {
    const breedPart = answers.breedMode === "unknown" || !answers.breed
      ? "your dog"
      : `your ${escapeHtml(answers.breed)}`;
    return `Name shortlist for ${breedPart}`;
  }

  function originLabel(key: string): string {
    const o = NAME_ORIGINS.find((x) => x.key === key);
    return o?.label ?? key;
  }

  function renderResults() {
    const gender: Gender = answers.gender!;
    const all = filterDogNames({ gender, origins: answers.styles });
    // Seed off the input so the order is stable per (gender, origins) pick.
    const seed =
      gender.length * 1009 +
      answers.styles.join(",").length * 1117 +
      answers.styles.reduce((s, k) => s + k.length * 31, 0);
    const shuffled = shuffleDeterministic(all, seed);
    lastShownNames = shuffled;
    lastShownCount = Math.min(FIRST_NAME_COUNT, shuffled.length);

    const styleLabels = answers.styles.map((k) => escapeHtml(originLabel(k))).join(", ");

    resultsEl.hidden = false;
    resultsEl.innerHTML = `
      <h2 class="dng__results-title">${buildHeading()}</h2>
      <p class="muted dng__results-meta">${styleLabels} · ${gender === "either" ? "Any" : gender === "boy" ? "Boy" : "Girl"}</p>
      <ul class="dng__name-list" id="dng-name-list"></ul>
      <p class="dng__more-wrap">
        <button class="btn" id="dng-more" ${shuffled.length <= lastShownCount ? "hidden" : ""}>
          Show more names
        </button>
      </p>
      <section class="dng__save-card" aria-label="Email your shortlist">
        <h3>Get the top 20 emailed to you</h3>
        <p class="muted dng__save-blurb">
          We'll send the top 20 names with their meanings — somewhere safe to
          come back to when you're choosing.
        </p>
        <form id="dng-save-form" class="dng__save-form" novalidate>
          <label class="auth__field" id="dng-email-field">
            <span>Your email</span>
            <input id="dng-email-input" name="email" type="email" autocomplete="email" required placeholder="you@example.com" />
          </label>
          <label class="dng__consent" id="dng-consent-field">
            <input id="dng-consent-input" type="checkbox" name="consent" />
            <span class="dng__consent-text">
              Email me the list, plus occasional Purrtraits tips and offers
              I can unsubscribe from anytime.
            </span>
          </label>
          <button class="btn btn--primary" id="dng-save-btn" type="submit">
            Email me the top 20 →
          </button>
        </form>
        <p class="muted dng__save-status" id="dng-save-status" hidden></p>
      </section>
      <p class="dng__followup muted">
        Once you've picked their name, you can
        <a href="/upload">turn their photo into a portrait</a> with the name on it.
      </p>
    `;

    renderShownNames();

    document.getElementById("dng-more")?.addEventListener("click", () => {
      const before = lastShownCount;
      lastShownCount = Math.min(lastShownCount + MORE_NAME_BATCH, lastShownNames.length);
      const after = lastShownCount;
      renderShownNames();
      const more = document.getElementById("dng-more") as HTMLButtonElement | null;
      if (more && lastShownCount >= lastShownNames.length) more.hidden = true;
      track("name_shortlist_show_more", {
        from_count: before,
        to_count: after,
        total_available: lastShownNames.length,
      });
    });

    // If the user is already signed in, hide the email field — we'll use
    // their account email server-side. The consent checkbox stays visible
    // so signed-in users can still choose whether to subscribe to the list.
    const emailField = document.getElementById("dng-email-field") as HTMLLabelElement;
    const emailInput = document.getElementById("dng-email-input") as HTMLInputElement;
    if (isSignedIn()) {
      emailField.hidden = true;
      emailInput.required = false;
      const btn = document.getElementById("dng-save-btn") as HTMLButtonElement;
      btn.textContent = "Email me the top 20 →";
    }

    document.getElementById("dng-save-form")?.addEventListener("submit", (e) => {
      e.preventDefault();
      void onSaveSubmit();
    });

    resultsEl.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  function renderShownNames() {
    const ul = document.getElementById("dng-name-list");
    if (!ul) return;
    ul.innerHTML = lastShownNames
      .slice(0, lastShownCount)
      .map(
        (n) => `
          <li class="dng__name">
            <span class="dng__name-name">${escapeHtml(n.name)}</span>
            <span class="dng__name-meta muted">${escapeHtml(originLabel(n.origin))} · ${escapeHtml(n.meaning)}</span>
          </li>`,
      )
      .join("");
  }

  // ─── Save flow ────────────────────────────────────────────────────────
  // v2 (email-only, no sign-up detour): on submit we save the shortlist,
  // schedule the templated email, and — if the user ticked the consent
  // checkbox — schedule a Brevo contact-list add. All inline on the page,
  // no redirect.

  function setSaveStatus(msg: string, tone: "ok" | "info" | "err" = "info") {
    const el = document.getElementById("dng-save-status") as HTMLParagraphElement | null;
    if (!el) return;
    el.hidden = false;
    el.textContent = msg;
    el.dataset.tone = tone;
  }

  async function onSaveSubmit() {
    const btn = document.getElementById("dng-save-btn") as HTMLButtonElement;
    const defaultLabel = "Email me the top 20 →";
    btn.disabled = true;
    btn.textContent = "Sending…";

    const emailInput = document.getElementById("dng-email-input") as HTMLInputElement;
    const consentInput = document.getElementById("dng-consent-input") as HTMLInputElement;
    const signedIn = isSignedIn();
    const email = emailInput?.value.trim() || undefined;
    const marketingConsent = !!consentInput?.checked;

    if (!signedIn && (!email || !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email))) {
      setSaveStatus("Enter a valid email so we can send you the list.", "err");
      btn.disabled = false;
      btn.textContent = defaultLabel;
      return;
    }

    const namesPayload = lastShownNames.map((n) => ({
      name: n.name,
      origin: n.origin,
      gender: n.gender,
      meaning: n.meaning,
    }));
    const inputs = {
      breed: answers.breed,
      breeds: answers.breeds,
      breedMode: answers.breedMode,
      gender: answers.gender!,
      styles: answers.styles.slice(),
    };

    try {
      const client = new ConvexClient(PUBLIC_CONVEX_URL);
      if (signedIn) client.setAuth(() => getValidJwt());
      await client.mutation(api.dogShortlists.saveShortlist, {
        inputs,
        names: namesPayload,
        email,
        marketingConsent,
      });
      track("name_shortlist_save", {
        mode: signedIn ? "signed_in" : "email_only",
        name_count: namesPayload.length,
        marketing_consent: marketingConsent,
      });
      // Determine the recipient email to echo back in the confirmation.
      // For signed-in users with no email field filled in, fall back to a
      // generic message — we can't read their account email client-side
      // without an extra round-trip.
      const recipient = email ?? "your inbox";
      renderSaveSuccess(recipient);
    } catch (err) {
      console.error("Save shortlist failed", err);
      setSaveStatus("Couldn't send your shortlist — please try again.", "err");
      btn.disabled = false;
      btn.textContent = defaultLabel;
    }
  }

  // Replaces the save card's content with a clean confirmation view.
  // One-way transition — the form is gone for the rest of the page lifetime.
  // A reload (or running the quiz again) starts fresh.
  function renderSaveSuccess(recipient: string) {
    const card = document.querySelector(".dng__save-card") as HTMLElement | null;
    if (!card) return;
    card.classList.add("dng__save-card--success");
    card.innerHTML = `
      <div class="dng__save-success" role="status" aria-live="polite">
        <div class="dng__save-success-icon" aria-hidden="true">✓</div>
        <h3 class="dng__save-success-title">Sent — check your inbox</h3>
        <p class="dng__save-success-msg">
          Your shortlist is on its way to <strong>${escapeHtml(recipient)}</strong>.
          Give it a minute or two to arrive.
        </p>
        <p class="muted dng__save-success-hint">
          Didn't see it? Check your spam folder, or
          <a href="/dog-name-generator">run the generator again</a>
          for a different set of names.
        </p>
      </div>
    `;
    card.scrollIntoView({ behavior: "smooth", block: "center" });
  }

  // ─── Wiring ───────────────────────────────────────────────────────────

  next.addEventListener("click", () => {
    // Emit per-step events matching the style quiz's shape.
    if (step === 1) {
      const mode = answers.breedMode === "single"
        ? "single"
        : answers.breedMode === "crossbreed"
          ? "crossbreed"
          : "unknown";
      track("name_quiz_step_complete", {
        step_number: 1,
        step_name: "breed",
        answer: answers.breed ?? "unknown",
        breed_mode: mode,
        breed_count: answers.breedMode === "crossbreed" ? (answers.breeds?.length ?? 0) : (answers.breed ? 1 : 0),
      });
    } else if (step === 2) {
      track("name_quiz_step_complete", {
        step_number: 2,
        step_name: "gender",
        answer: answers.gender,
      });
    } else if (step === 3) {
      track("name_quiz_step_complete", {
        step_number: 3,
        step_name: "styles",
        answer: answers.styles.join(","),
        style_count: answers.styles.length,
      });
    }

    if (step < TOTAL_STEPS) { showStep(step + 1); return; }

    // Final step → compute and render results.
    track("name_quiz_complete", {
      breed: answers.breed,
      breed_mode: answers.breedMode,
      gender: answers.gender,
      styles: answers.styles.join(","),
      style_count: answers.styles.length,
    });
    // Hide quiz, show results.
    const quiz = document.getElementById("dng-quiz") as HTMLDivElement;
    quiz.hidden = true;
    renderResults();
  });

  prev.addEventListener("click", () => {
    if (step > 1) showStep(step - 1);
  });

  // Init.
  track("name_quiz_start");
  showStep(1);
</script>

