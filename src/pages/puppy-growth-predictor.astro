    "German Wirehaired Pointer": { wMin: 23,  wMax: 32,  hMin: 56, hMax: 66, size: "large", full: 16 },
    "Old English Sheepdog":      { wMin: 27,  wMax: 45,  hMin: 53, hMax: 61, size: "large", full: 18 },
    "Airedale Terrier":          { wMin: 23,  wMax: 32,  hMin: 56, hMax: 61, size: "large", full: 15 },
    "Goldendoodle":              { wMin: 20,  wMax: 36,  hMin: 51, hMax: 66, size: "large", full: 16 },
    "Labradoodle":               { wMin: 20,  wMax: 30,  hMin: 53, hMax: 65, size: "large", full: 16 },
    "Bernedoodle":               { wMin: 25,  wMax: 40,  hMin: 50, hMax: 70, size: "large", full: 18 },
    "Bouvier des Flandres":      { wMin: 32,  wMax: 50,  hMin: 59, hMax: 70, size: "large", full: 17 },
    "Cane Corso":                { wMin: 40,  wMax: 50,  hMin: 60, hMax: 70, size: "large", full: 19 },
    "Dogo Argentino":            { wMin: 36,  wMax: 45,  hMin: 60, hMax: 68, size: "large", full: 18 },
    "Giant Schnauzer":           { wMin: 25,  wMax: 48,  hMin: 60, hMax: 70, size: "large", full: 18 },

    // giant
    "Great Dane":                { wMin: 50,  wMax: 82,  hMin: 71, hMax: 86, size: "giant", full: 22 },
    "Saint Bernard":             { wMin: 55,  wMax: 90,  hMin: 66, hMax: 76, size: "giant", full: 22 },
    "Mastiff":                   { wMin: 54,  wMax: 100, hMin: 70, hMax: 84, size: "giant", full: 22 },
    "Bullmastiff":               { wMin: 45,  wMax: 59,  hMin: 61, hMax: 69, size: "giant", full: 20 },
    "Tibetan Mastiff":           { wMin: 32,  wMax: 73,  hMin: 61, hMax: 76, size: "giant", full: 24 },
    "Neapolitan Mastiff":        { wMin: 50,  wMax: 70,  hMin: 60, hMax: 75, size: "giant", full: 20 },
    "Dogue de Bordeaux":         { wMin: 45,  wMax: 60,  hMin: 58, hMax: 69, size: "giant", full: 20 },
    "Newfoundland":              { wMin: 45,  wMax: 70,  hMin: 66, hMax: 71, size: "giant", full: 22 },
    "Bernese Mountain Dog":      { wMin: 32,  wMax: 52,  hMin: 58, hMax: 70, size: "giant", full: 20 },
    "Greater Swiss Mountain Dog": { wMin: 38, wMax: 64,  hMin: 60, hMax: 72, size: "giant", full: 20 },
    "Great Pyrenees":            { wMin: 38,  wMax: 60,  hMin: 65, hMax: 81, size: "giant", full: 22 },
    "Irish Wolfhound":           { wMin: 48,  wMax: 70,  hMin: 76, hMax: 88, size: "giant", full: 22 },
    "Scottish Deerhound":        { wMin: 34,  wMax: 50,  hMin: 71, hMax: 81, size: "giant", full: 20 },
    "Leonberger":                { wMin: 41,  wMax: 77,  hMin: 65, hMax: 80, size: "giant", full: 22 },
    "Komondor":                  { wMin: 36,  wMax: 60,  hMin: 65, hMax: 80, size: "giant", full: 22 },
    "Kuvasz":                    { wMin: 32,  wMax: 52,  hMin: 66, hMax: 76, size: "giant", full: 22 },
  };

  // Fallback when a breed isn't in BREED_DATA: a generic average for
  // each size class. Used by inferBreedStats below.
  const SIZE_DEFAULTS: Record<SizeId, BreedStats> = {
    toy:    { wMin: 2,   wMax: 4,    hMin: 18, hMax: 28, size: "toy",    full: 10 },
    small:  { wMin: 5,   wMax: 10,   hMin: 25, hMax: 38, size: "small",  full: 12 },
    medium: { wMin: 11,  wMax: 23,   hMin: 38, hMax: 56, size: "medium", full: 14 },
    large:  { wMin: 24,  wMax: 40,   hMin: 55, hMax: 68, size: "large",  full: 16 },
    giant:  { wMin: 41,  wMax: 75,   hMin: 66, hMax: 85, size: "giant",  full: 22 },
  };

  // Best-effort size class for breeds we don't have hand-tuned data for.
  // Keyword-based: giant hints win first, then toy, then large hints,
  // then small; everything else lands at medium.
  function inferSize(name: string): SizeId {
    const n = name.toLowerCase();
    if (/\b(mastiff|wolfhound|leonberger|kuvasz|komondor|bernese|swiss mountain|pyrenees|saint|st\.|newfoundland|deerhound|borzoi|otterhound|dane|great)\b/.test(n)) return "giant";
    if (/\b(toy|teacup|tiny|miniature|mini|chin|papillon|maltese|pekingese|pomeranian|chihuahua|brussels|affenpinscher|havanese|coton|chinese crested|english toy|xolo|biewer|silky|sloughi)\b/.test(n)) return "toy";
    if (/\b(retriever|shepherd|setter|pointer|husky|malamute|akita|boxer|doberman|rottweiler|ridgeback|weimaraner|vizsla|samoyed|chow|standard poodle|airedale|collie|bouvier|cane corso|dogo|giant schnauzer|catahoula|bluetick|coonhound|foxhound|harrier|saluki|afghan|ibizan|pharaoh)\b/.test(n)) return "large";
    if (/\b(terrier|spaniel|beagle|corgi|dachshund|pug|bulldog|schipperke|frise|shih tzu|lhasa|whippet|basenji|shiba|sheltie|scottie|cavalier|cockapoo|cavapoo|maltipoo|miniature poodle|miniature schnauzer|miniature pinscher|rat terrier|tibetan|chin|griffon|lowchen)\b/.test(n)) return "small";
    return "medium";
  }

  function breedStats(name: string): BreedStats {
    return BREED_DATA[name] ?? SIZE_DEFAULTS[inferSize(name)];
  }

  // Aggregate stats across N selected breeds. For crossbreeds we average
  // each numeric range and derive the size class from the averaged adult
  // weight — so a Chihuahua × Great Dane lands in medium/large territory
  // rather than being mis-classified as toy or giant on its own.
  type AggregateStats = BreedStats & { displayName: string; isCross: boolean };

  function aggregateStats(names: string[]): AggregateStats {
    if (names.length === 0) {
      // Defensive default — UI prevents this, but render() shouldn't crash.
      return { ...SIZE_DEFAULTS.medium, displayName: "Your pup", isCross: false };
    }
    if (names.length === 1) {
      return { ...breedStats(names[0]!), displayName: names[0]!, isCross: false };
    }
    const infos = names.map(breedStats);
    const avg = (xs: number[]) => xs.reduce((a, b) => a + b, 0) / xs.length;
    const wMin = avg(infos.map((i) => i.wMin));
    const wMax = avg(infos.map((i) => i.wMax));
    const hMin = avg(infos.map((i) => i.hMin));
    const hMax = avg(infos.map((i) => i.hMax));
    const full = Math.round(avg(infos.map((i) => i.full)));
    const adult = (wMin + wMax) / 2;
    const size: SizeId =
      adult < 4 ? "toy" : adult < 11 ? "small" : adult < 24 ? "medium" : adult < 41 ? "large" : "giant";
    return { wMin, wMax, hMin, hMax, size, full, displayName: names.join(" × "), isCross: true };
  }

  // Breeds available in the search dropdown. Exclude the "Other / Unsure"
  // sentinel from the canonical list — this calculator needs a real breed
  // to predict against, and the user explicitly opted out of an unknown
  // option.
  const SEARCH_BREEDS = DOG_BREEDS.filter((b) => b !== "Other / Unsure");
  const MIN_BREEDS = 1;
  const MAX_BREEDS = 4;

  // % of adult weight at age (months), per size class. Vet/breeder averages.
  const GROWTH_CURVE: Record<SizeId, [number, number][]> = {
    toy:    [[0, 8], [1, 18], [2, 35], [3, 55], [4, 70], [6, 85], [8, 95], [10, 100]],
    small:  [[0, 7], [1, 15], [2, 30], [3, 45], [4, 60], [6, 78], [9, 93], [12, 100]],
    medium: [[0, 5], [1, 12], [2, 22], [3, 32], [4, 45], [6, 62], [9, 82], [12, 95], [15, 100]],
    large:  [[0, 3], [1, 8],  [2, 15], [3, 22], [4, 32], [6, 50], [9, 70], [12, 85], [15, 95], [18, 100]],
    giant:  [[0, 2], [1, 5],  [2, 10], [3, 15], [4, 22], [6, 35], [9, 55], [12, 72], [15, 85], [18, 95], [24, 100]],
  };

  function curvePctAt(size: SizeId, months: number): number {
    const pts = GROWTH_CURVE[size];
    if (months <= pts[0]![0]) return pts[0]![1];
    if (months >= pts[pts.length - 1]![0]) return 100;
    for (let i = 0; i < pts.length - 1; i++) {
      const [x1, y1] = pts[i]!, [x2, y2] = pts[i + 1]!;
      if (months >= x1 && months <= x2) {
        const t = (months - x1) / (x2 - x1);
        return y1 + (y2 - y1) * t;
      }
    }
    return 100;
  }

  type Prediction = {
    pct: number;
    predicted: number;
    min: number; max: number;
    height: number;
    fullGrownAt: number;
    monthsToGo: number;
    sizeClass: SizeId;
  };

  function predict(stats: BreedStats, ageMonths: number, currentKg: number): Prediction {
    const pct = curvePctAt(stats.size, ageMonths);
    const breedAvg = (stats.wMin + stats.wMax) / 2;
    // Trust puppy formula more after ~4 months; trust breed avg earlier on.
    const fromPuppy = currentKg > 0 ? (currentKg / Math.max(pct, 4)) * 100 : breedAvg;
    const w = Math.max(0, Math.min(0.8, (ageMonths - 1) / 8));
    const predicted = breedAvg * (1 - w) + fromPuppy * w;
    const spread = Math.max(0.08, (stats.wMax - stats.wMin) / breedAvg / 2.4);
    return {
      pct,
      predicted,
      min: predicted * (1 - spread),
      max: predicted * (1 + spread),
      height: (stats.hMin + stats.hMax) / 2,
      fullGrownAt: stats.full,
      monthsToGo: Math.max(0, stats.full - ageMonths),
      sizeClass: stats.size,
    };
  }

  const SIZE_LABEL: Record<SizeId, string> = {
    toy: "Toy", small: "Small", medium: "Medium", large: "Large", giant: "Giant",
  };

  function fmt(v: number, d = 1): string {
    if (!isFinite(v)) return "—";
    if (d === 0) return Math.round(v).toString();
    return (Math.round(v * 10) / 10).toFixed(d);
  }

  // ─── State ────────────────────────────────────────────────────
  // selectedBreeds: 1 entry = purebreed prediction, 2-4 entries = cross.
  // Keep it as a deduped, order-preserving array — the order shows up in
  // the result label (e.g. "Labrador × Poodle").
  let selectedBreeds: string[] = ["Golden Retriever"];
  let ageMonths = 4;
  let currentKg = 11;
  let unit: "kg" | "lb" = "kg";

  const KG_PER_LB = 0.45359237;
  const toDisplayWeight = (kg: number) => (unit === "kg" ? kg : kg / KG_PER_LB);
  const fromDisplayWeight = (v: number) => (unit === "kg" ? v : v * KG_PER_LB);
  const weightUnitLabel = () => (unit === "kg" ? "kg" : "lb");

  // ─── Element refs ─────────────────────────────────────────────
  const $ = <T extends HTMLElement = HTMLElement>(id: string) =>
    document.getElementById(id) as T;

  const breedInput     = $<HTMLInputElement>("pgp-breed-input");
  const breedList      = $<HTMLUListElement>("pgp-breed-list");
  const breedChipsEl   = $("pgp-breed-chips");
  const breedHint      = $("pgp-breed-hint");
  const breedCounter   = $("pgp-breed-counter");
  const ageInput       = $<HTMLInputElement>("pgp-age-input");
  const weightInput    = $<HTMLInputElement>("pgp-weight-input");
  const ageOut         = $("pgp-age");
  const weightOut      = $("pgp-weight");
  const weightUnitOut  = $("pgp-weight-unit");
  const ageFill        = $("pgp-age-fill");
  const ageThumb       = $("pgp-age-thumb");
  const weightFill     = $("pgp-weight-fill");
  const weightThumb    = $("pgp-weight-thumb");
  const weightMarks    = $("pgp-weight-marks");

  const breedNameOut   = $("pgp-breed-name");
  const sizePillOut    = $("pgp-size-pill");
  const predictedOut   = $("pgp-predicted");
  const predictedUnit  = $("pgp-predicted-unit");
  const rangeOut       = $("pgp-range");
  const heightOut      = $("pgp-height");
  const heightSubOut   = $("pgp-height-sub");
  const monthsToGoOut  = $("pgp-months-to-go");
  const grownSubOut    = $("pgp-grown-sub");

  const todayLabelOut  = $("pgp-today-label");
  const adultLabelOut  = $("pgp-adult-label");
  const todayFill      = $("pgp-today-fill");
  const todayValOut    = $("pgp-today-val");
  const adultValOut    = $("pgp-adult-val");
  const multOut        = $("pgp-mult");

  const chartSubOut    = $("pgp-chart-sub");
  const chartSvg       = document.getElementById("pgp-chart") as unknown as SVGSVGElement;

  // ─── Chart renderer ───────────────────────────────────────────
  // Renders gridlines, axis ticks, the breed-size growth curve, and a
  // "you are here" marker. Called on every render() so the marker glides
  // (via CSS transition on the marker group) when inputs change.
  const SVG_NS = "http://www.w3.org/2000/svg";
  function el<K extends keyof SVGElementTagNameMap>(
    tag: K,
    attrs: Record<string, string | number> = {},
    text?: string,
  ): SVGElementTagNameMap[K] {
    const node = document.createElementNS(SVG_NS, tag);
    for (const k in attrs) node.setAttribute(k, String(attrs[k]));
    if (text !== undefined) node.textContent = text;
    return node;
  }

  function renderChart(size: SizeId, age: number, pct: number) {
    chartSvg.innerHTML = "";

    const W_TOTAL = 1160, H_TOTAL = 340;
    const padL = 56, padR = 28, padT = 24, padB = 44;
    const W = W_TOTAL - padL - padR, H = H_TOTAL - padT - padB;

    const pts = GROWTH_CURVE[size];
    const xMax = pts[pts.length - 1]![0];
    const px = (m: number) => padL + (m / xMax) * W;
    const py = (p: number) => padT + (1 - p / 100) * H;

    // Gridlines + y-axis labels.
    [0, 25, 50, 75, 100].forEach((p) => {
      chartSvg.appendChild(el("line", {
        x1: padL, x2: padL + W, y1: py(p), y2: py(p),
        stroke: "#EADFC9", "stroke-width": 1,
        "stroke-dasharray": p === 100 ? "0" : "2 4",
      }));
      chartSvg.appendChild(el("text", {
        x: padL - 10, y: py(p) + 4, "text-anchor": "end",
        "font-family": "DM Sans, sans-serif", "font-size": 11, fill: "#9C8878",
      }, `${p}%`));
    });

    // X ticks + axis label.
    pts.forEach(([m]) => {
      chartSvg.appendChild(el("line", {
        x1: px(m), x2: px(m), y1: padT + H, y2: padT + H + 5, stroke: "#C4A882",
      }));
      chartSvg.appendChild(el("text", {
        x: px(m), y: padT + H + 22, "text-anchor": "middle",
        "font-family": "DM Sans, sans-serif", "font-size": 11, fill: "#7A6558",
      }, String(m)));
    });
    chartSvg.appendChild(el("text", {
      x: padL + W / 2, y: H_TOTAL - 8, "text-anchor": "middle",
      "font-family": "DM Sans, sans-serif", "font-size": 11,
      "letter-spacing": 1.2, fill: "#7A6558",
    }, "AGE · MONTHS"));

    // Curve path — smooth bezier through points.
    let d = `M ${px(pts[0]![0])} ${py(pts[0]![1])}`;
    for (let i = 1; i < pts.length; i++) {
      const [x1, y1] = pts[i - 1]!, [x2, y2] = pts[i]!;
      const cx = (px(x1) + px(x2)) / 2;
      d += ` C ${cx} ${py(y1)}, ${cx} ${py(y2)}, ${px(x2)} ${py(y2)}`;
    }
    const fillPath = el("path", {
      d: `${d} L ${px(xMax)} ${py(0)} L ${px(0)} ${py(0)} Z`,
      fill: "#F7E8EE", opacity: 0.6,
      class: "pgp__chart-fill",
    });
    chartSvg.appendChild(fillPath);
    const linePath = el("path", {
      d, stroke: "#D88A9A", "stroke-width": 2.5, fill: "none",
      class: "pgp__chart-line",
    });
    chartSvg.appendChild(linePath);

    // Marker — line + outer ring + inner dot + callout. Wrapped in a
    // group with a CSS transition so it glides between positions.
    const markerX = px(Math.min(age, xMax));
    const markerY = py(pct);

    const marker = el("g", { class: "pgp__marker" });
    marker.appendChild(el("line", {
      x1: markerX, x2: markerX, y1: markerY, y2: padT + H,
      stroke: "#D88A9A", "stroke-width": 1.5, "stroke-dasharray": "3 4",
    }));
    marker.appendChild(el("circle", {
      cx: markerX, cy: markerY, r: 14, fill: "#fff",
      stroke: "#D88A9A", "stroke-width": 2.5,
    }));
    marker.appendChild(el("circle", {
      cx: markerX, cy: markerY, r: 6, fill: "#D88A9A",
    }));

    // Callout — flip to the left side of the marker if it would overflow.
    const calloutW = 170, calloutH = 56;
    const flip = markerX + 18 + calloutW > padL + W;
    const cx = flip ? markerX - 18 - calloutW : markerX + 18;
    const cy = Math.max(padT, markerY - 38);
    const callout = el("g", {
      transform: `translate(${cx}, ${cy})`,
    });
    callout.appendChild(el("rect", {
      width: calloutW, height: calloutH, rx: 10, fill: "#2D1F1A",
    }));
    callout.appendChild(el("text", {
      x: 14, y: 22, "font-family": "DM Sans, sans-serif",
      "font-size": 10, "letter-spacing": 1.5, fill: "#FBEEF1",
    }, "YOU ARE HERE"));
    callout.appendChild(el("text", {
      x: 14, y: 44, "font-family": "Caveat, cursive",
      "font-size": 22, "font-weight": 700, fill: "#fff",
    }, `${fmt(pct, 0)}% grown`));
    marker.appendChild(callout);

    chartSvg.appendChild(marker);

    // First render after mount → set the intro's initial "hidden" state
    // (line collapsed to a single dash offset, fill + marker invisible).
    // The IntersectionObserver below transitions these to visible the
    // first time the chart card enters the viewport.
    if (!chartIntroDone) prepareChartIntro(linePath, fillPath, marker);
  }

  // ─── Scroll-triggered intro for the curve ─────────────────────
  // The curve "draws itself" by animating stroke-dashoffset from the
  // path's total length down to 0. Fill and marker cross-fade in on a
  // small stagger so the line lands before the dot pops on.
  let chartIntroDone = false;
  const prefersReducedMotion = window.matchMedia?.("(prefers-reduced-motion: reduce)").matches;

  function prepareChartIntro(line: SVGPathElement, fill: SVGPathElement, marker: SVGGElement) {
    if (prefersReducedMotion) { chartIntroDone = true; return; }
    const len = line.getTotalLength();
    line.style.strokeDasharray = String(len);
    line.style.strokeDashoffset = String(len);
    fill.style.opacity = "0";
    marker.style.opacity = "0";
  }

  function playChartIntro() {
    if (chartIntroDone) return;
    chartIntroDone = true;
    const line = chartSvg.querySelector<SVGPathElement>(".pgp__chart-line");
    const fill = chartSvg.querySelector<SVGPathElement>(".pgp__chart-fill");
    const marker = chartSvg.querySelector<SVGGElement>(".pgp__marker");
    if (!line || !fill || !marker) return;
    line.style.transition = "stroke-dashoffset 1600ms cubic-bezier(0.6,0,0.3,1)";
    fill.style.transition = "opacity 700ms ease 400ms";
    marker.style.transition = "opacity 500ms ease 1300ms";
    // Reflow so the from/to states actually animate.
    void line.getBoundingClientRect();
    line.style.strokeDashoffset = "0";
    fill.style.opacity = "0.6";
    marker.style.opacity = "1";
  }

  // ─── Bar fill width ───────────────────────────────────────────
  // Today bar is sized as a fraction of adult; adult bar is the full
  // track width (it's the "100%" reference) styled with a pink gradient.
  function setTodayBar(todayKg: number, adultKg: number) {
    const ratio = adultKg > 0
      ? Math.max(0.05, Math.min(1, todayKg / adultKg))
      : 0;
    todayFill.style.width = `${ratio * 100}%`;
  }

  // ─── Slider visuals ───────────────────────────────────────────
  function syncSliderVisual(
    input: HTMLInputElement,
    fill: HTMLElement,
    thumb: HTMLElement,
  ) {
    const min = parseFloat(input.min);
    const max = parseFloat(input.max);
    const val = parseFloat(input.value);
    const pct = ((val - min) / (max - min)) * 100;
    fill.style.width = `${pct}%`;
    thumb.style.left = `calc(${pct}% - 11px)`;
  }

  // ─── Flash animation re-trigger ───────────────────────────────
  // Numbers flash pink briefly on change. We toggle the class off+on
  // around an offsetWidth read so the browser replays the keyframe.
  function flash(node: HTMLElement) {
    node.classList.remove("pgp-num-flash");
    void node.offsetWidth;
    node.classList.add("pgp-num-flash");
  }

  let lastPredicted = -1, lastSize: SizeId | "" = "";

  function render() {
    const agg = aggregateStats(selectedBreeds);
    const r = predict(agg, ageMonths, currentKg);

    breedNameOut.textContent = agg.displayName;
    sizePillOut.textContent = `${SIZE_LABEL[r.sizeClass]}${agg.isCross ? " mix" : " breed"}`;

    const predictedDisp = toDisplayWeight(r.predicted);
    const minDisp       = toDisplayWeight(r.min);
    const maxDisp       = toDisplayWeight(r.max);
    const todayDisp     = toDisplayWeight(currentKg);
    const u             = weightUnitLabel();

    predictedOut.textContent     = fmt(predictedDisp);
    predictedUnit.textContent    = u;
    rangeOut.textContent         = `Expected range ${fmt(minDisp)} – ${fmt(maxDisp)} ${u}`;
    heightOut.textContent        = `${fmt(r.height, 0)} cm`;
    heightSubOut.textContent     = `at the shoulder · ${fmt(agg.hMin, 0)}–${fmt(agg.hMax, 0)} cm`;
    monthsToGoOut.textContent    = r.monthsToGo < 0.5 ? "Almost there" : `~${fmt(r.monthsToGo, 0)} mo`;
    grownSubOut.textContent      = r.monthsToGo < 0.5 ? "Already at adult size" : `around ${r.fullGrownAt} months old`;

    todayLabelOut.textContent    = `${fmt(ageMonths, ageMonths % 1 === 0 ? 0 : 1)} mo old`;
    adultLabelOut.textContent    = r.monthsToGo < 0.5 ? "already" : `~${r.fullGrownAt} mo`;
    todayValOut.textContent      = `${fmt(todayDisp)} ${u}`;
    adultValOut.textContent      = `${fmt(predictedDisp)} ${u}`;
    const mult = r.predicted / Math.max(currentKg, 0.1);
    multOut.textContent          = `×${fmt(mult, mult < 10 ? 1 : 0)}`;

    setTodayBar(currentKg, r.predicted);

    chartSubOut.textContent = agg.isCross
      ? `Your ${SIZE_LABEL[r.sizeClass].toLowerCase()} mix should reach about 100% of adult weight by month ${agg.full}.`
      : `${agg.displayName}s reach about 100% of their adult weight by month ${agg.full}.`;

    renderChart(r.sizeClass, ageMonths, r.pct);

    // Flash big number + size pill when the underlying value or class changes.
    if (Math.abs(r.predicted - lastPredicted) > 0.05 || r.sizeClass !== lastSize) {
      flash(predictedOut);
      sizePillOut.classList.remove("pgp-pop");
      void sizePillOut.offsetWidth;
      sizePillOut.classList.add("pgp-pop");
    }
    lastPredicted = r.predicted;
    lastSize      = r.sizeClass;
  }

  // ─── Slider bounds (shared by init + breed changes + unit flip) ──
  // Recompute slider max from whichever stats are currently active so
  // big breeds (Great Dane) and tiny ones (Chihuahua) both get a sane
  // weight axis. Age max scales with typical full-grown age + a buffer.
  function applySliderBounds() {
    const agg = aggregateStats(selectedBreeds);
    const ageMax = Math.max(18, agg.full + 2);
    const kgMax  = Math.max(20, agg.wMax * 1.1);
    ageInput.max = String(ageMax);
    if (ageMonths > ageMax) { ageMonths = ageMax; ageInput.value = String(ageMax); }
    weightInput.min  = String(toDisplayWeight(0.5).toFixed(1));
    weightInput.max  = String(toDisplayWeight(kgMax).toFixed(1));
    weightInput.step = unit === "kg" ? "0.1" : "0.2";
    const kgVal = Math.min(currentKg, kgMax);
    if (kgVal !== currentKg) currentKg = kgVal;
    weightInput.value = String(toDisplayWeight(currentKg).toFixed(1));
    syncSliderVisual(ageInput, ageFill, ageThumb);
    syncSliderVisual(weightInput, weightFill, weightThumb);
    refreshWeightMarks();
  }

  // ─── Breed chips + search controller ──────────────────────────
  // Single source of truth = selectedBreeds[]. renderChips() and
  // renderBreedUi() paint from that array; everything else just
  // mutates the array and calls these.
  function renderChips() {
    breedChipsEl.innerHTML = selectedBreeds
      .map((b) => `
        <span class="pgp__chip" data-breed="${escapeHtml(b)}">
          <span>${escapeHtml(b)}</span>
          <button type="button" class="pgp__chip-x" aria-label="Remove ${escapeHtml(b)}">×</button>
        </span>`)
      .join("");
  }

  function renderBreedUi() {
    const n = selectedBreeds.length;
    breedCounter.textContent = `${n} / ${MAX_BREEDS}`;
    breedInput.disabled = n >= MAX_BREEDS;
    breedInput.placeholder = n === 0
      ? "Search breeds…"
      : n >= MAX_BREEDS
        ? "That's the max — 4 breeds"
        : n === 1
          ? "Add another for a crossbreed…"
          : "Add another breed…";
    if (n === 0) {
      breedHint.textContent = "Pick at least one breed to forecast.";
    } else if (n === 1) {
      breedHint.textContent = "Got a crossbreed? Add up to 4 breeds to predict the mix.";
    } else if (n >= MAX_BREEDS) {
      breedHint.textContent = "That's the max — remove a chip to swap in another.";
    } else {
      breedHint.textContent = `${n} breeds selected — add up to ${MAX_BREEDS - n} more for the mix.`;
    }
  }

  function addBreed(name: string) {
    if (selectedBreeds.includes(name) || selectedBreeds.length >= MAX_BREEDS) return;
    selectedBreeds = [...selectedBreeds, name];
    breedInput.value = "";
    closeBreedList();
    renderChips();
    renderBreedUi();
    applySliderBounds();
    render();
    if (selectedBreeds.length < MAX_BREEDS) breedInput.focus();
  }

  function removeBreed(name: string) {
    selectedBreeds = selectedBreeds.filter((b) => b !== name);
    renderChips();
    renderBreedUi();
    // Re-derive slider bounds, then re-render. With 0 breeds, render()
    // still works via aggregateStats's defensive fallback.
    if (selectedBreeds.length >= MIN_BREEDS) applySliderBounds();
    render();
  }

  // Suggestion dropdown
  let activeSuggestionIdx = -1;

  function suggestionItems() {
    return Array.from(breedList.querySelectorAll<HTMLLIElement>(".pgp__breed-opt"));
  }

  function highlightSuggestion(i: number) {
    const opts = suggestionItems();
    activeSuggestionIdx = i;
    opts.forEach((el, idx) => el.classList.toggle("is-active", idx === i));
    if (i >= 0 && opts[i]) opts[i].scrollIntoView({ block: "nearest" });
  }

  function closeBreedList() {
    breedList.hidden = true;
    breedList.innerHTML = "";
    activeSuggestionIdx = -1;
    breedInput.setAttribute("aria-expanded", "false");
  }

  function openBreedList(matches: string[]) {
    breedList.innerHTML = matches
      .map((b) => `<li class="pgp__breed-opt" role="option" data-v="${escapeHtml(b)}">${escapeHtml(b)}</li>`)
      .join("");
    breedList.hidden = false;
    activeSuggestionIdx = -1;
    breedInput.setAttribute("aria-expanded", "true");
  }

  function updateSuggestions() {
    if (selectedBreeds.length >= MAX_BREEDS) { closeBreedList(); return; }
    const q = breedInput.value.trim().toLowerCase();
    if (!q) { closeBreedList(); return; }
    const taken = new Set(selectedBreeds);
    // Prioritise prefix matches over substring matches so typing "lab"
    // shows Labrador Retriever before Black Russian Terrier etc.
    const starts = SEARCH_BREEDS.filter(
      (b) => !taken.has(b) && b.toLowerCase().startsWith(q),
    );
    const contains = SEARCH_BREEDS.filter(
      (b) => !taken.has(b) && !b.toLowerCase().startsWith(q) && b.toLowerCase().includes(q),
    );
    const matches = [...starts, ...contains].slice(0, 8);
    if (matches.length === 0) { closeBreedList(); return; }
    openBreedList(matches);
  }

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) =>
      ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c]!,
    );
  }

  breedInput.addEventListener("input", updateSuggestions);
  breedInput.addEventListener("focus", updateSuggestions);
  breedInput.addEventListener("blur", () => {
    // Delay so a click on a list item registers before we tear the list down.
    setTimeout(() => closeBreedList(), 120);
  });
  breedInput.addEventListener("keydown", (e) => {
    const opts = suggestionItems();
    if (e.key === "ArrowDown") {
      if (breedList.hidden) { updateSuggestions(); return; }
      e.preventDefault();
      highlightSuggestion(Math.min(activeSuggestionIdx + 1, opts.length - 1));
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      highlightSuggestion(Math.max(activeSuggestionIdx - 1, 0));
    } else if (e.key === "Enter") {
      if (!breedList.hidden && activeSuggestionIdx >= 0) {
        e.preventDefault();
        const v = opts[activeSuggestionIdx]?.dataset.v;
        if (v) addBreed(v);
      } else if (!breedList.hidden && opts[0]?.dataset.v) {
        // Enter with no explicit highlight picks the top suggestion.
        e.preventDefault();
        addBreed(opts[0].dataset.v);
      }
    } else if (e.key === "Escape") {
      closeBreedList();
    } else if (e.key === "Backspace" && breedInput.value === "" && selectedBreeds.length > 0) {
      // Empty backspace pops the last chip — common combo-box pattern.
      removeBreed(selectedBreeds[selectedBreeds.length - 1]!);
    }
  });

  breedList.addEventListener("mousedown", (e) => {
    const target = (e.target as HTMLElement).closest<HTMLLIElement>(".pgp__breed-opt");
    if (!target?.dataset.v) return;
    // mousedown (not click) so the input's blur handler doesn't close the
    // list before our selection registers.
    e.preventDefault();
    addBreed(target.dataset.v);
  });

  breedChipsEl.addEventListener("click", (e) => {
    const target = (e.target as HTMLElement).closest<HTMLButtonElement>(".pgp__chip-x");
    if (!target) return;
    const chip = target.closest<HTMLElement>(".pgp__chip");
    const b = chip?.dataset.breed;
    if (b) removeBreed(b);
  });

  ageInput.addEventListener("input", () => {
    ageMonths = parseFloat(ageInput.value);
    ageOut.textContent = String(ageMonths % 1 === 0 ? ageMonths : ageMonths.toFixed(1));
    syncSliderVisual(ageInput, ageFill, ageThumb);
    render();
  });

  weightInput.addEventListener("input", () => {
    currentKg = fromDisplayWeight(parseFloat(weightInput.value));
    weightOut.textContent = fmt(toDisplayWeight(currentKg));
    syncSliderVisual(weightInput, weightFill, weightThumb);
    render();
  });

  // Weight unit toggle: rescale the slider's min/max/step/value into the
  // display unit so the range covers the same physical span (0.5 kg →
  // wMax * 1.1) in lb too. State is still kept in kg internally.
  function applyUnit(next: "kg" | "lb") {
    if (next === unit) return;
    unit = next;
    document.querySelectorAll<HTMLButtonElement>(".pgp__unit-btn").forEach((b) => {
      const active = b.dataset.unit === unit;
      b.classList.toggle("pgp__unit-btn--active", active);
      b.setAttribute("aria-checked", String(active));
    });
    weightUnitOut.textContent = ` ${weightUnitLabel()}`;
    applySliderBounds();
    weightOut.textContent = fmt(toDisplayWeight(currentKg));
    render();
  }

  function refreshWeightMarks() {
    const agg = aggregateStats(selectedBreeds);
    const kgMax = Math.max(20, agg.wMax * 1.1);
    const marks = [0.5, kgMax * 0.25, kgMax * 0.5, kgMax * 0.75 + 0.1].map((kg) =>
      `${fmt(toDisplayWeight(kg), 0)}`
    );
    // Last mark gets a "+" suffix.
    marks[marks.length - 1] = `${marks[marks.length - 1]}+`;
    weightMarks.innerHTML = marks.map((m) => `<span>${m}</span>`).join("");
  }

  document.querySelectorAll<HTMLButtonElement>(".pgp__unit-btn").forEach((b) => {
    b.addEventListener("click", () => applyUnit((b.dataset.unit as "kg" | "lb")));
  });

  // ─── Initial paint ────────────────────────────────────────────
  // Seed slider domains for the default breed, then run one render so
  // the chart, bars and stats match the SSR'd placeholder values.
  (function init() {
    renderChips();
    renderBreedUi();
    applySliderBounds();
    render();
  })();

  // Trigger the curve's draw-in the first time the chart scrolls into
  // view. The chart sits below the fold by design, so animating on
  // page load would burn the effect before the user ever sees it.
  const chartCard = document.querySelector(".pgp__chart-card");
  if (chartCard && "IntersectionObserver" in window && !prefersReducedMotion) {
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          playChartIntro();
          io.disconnect();
          break;
        }
      }
    }, { threshold: 0.2 });
    io.observe(chartCard);
  } else {
    // No IntersectionObserver support → reveal immediately rather than
    // leaving the curve hidden behind dashoffset. (Reduced-motion users
    // never had the chart hidden — prepareChartIntro short-circuits.)
    playChartIntro();
  }
</script>

