---
import Layout from "../layouts/Layout.astro";
import AdUnit from "../components/AdUnit.astro";
---

<Layout title="Generating your portraits · Purrtraits">
  <!-- Desktop sticky anchor leaderboard. Lives outside <main> so it can
       stick to the top of the viewport above the page chrome on scroll. -->
  <div class="gen-anchor">
    <AdUnit
      viewport="desktop"
      slot="7436328426"
      width={728}
      height={90}
      label="purrtraits_generate_viewport_anchor_leaderboard_728x90"
      sticky="top"
    />
  </div>

  <main class="page container">
    <div class="gen-shell">
      <!-- Desktop left skyscraper — sticky with the loader. Hidden under
           1200px so it doesn't crush the loader column. -->
      <aside class="gen-rail gen-rail--left">
        <AdUnit
          viewport="desktop"
          slot="7194672341"
          width={160}
          height={600}
          label="purrtraits_generate_railleft_skyscraper_160x600"
          sticky="rail"
        />
      </aside>

      <div class="gen">
        <div class="protected-wrap gen__pet-wrap is-loading">
          <img id="pet-preview" class="gen__pet protected-img is-loading-img" alt="" />
        </div>
        <h1 id="title">Painting your portraits…</h1>
        <p class="muted" id="subtitle">Our AI is brushing 3 unique styles. About 30 seconds.</p>
        <div class="gen__dots" id="dots"></div>

        <div class="gen__grid" id="gen-grid">
          <div class="gen__card"><div class="shimmer gen__shimmer"></div></div>
          <div class="gen__card"><div class="shimmer gen__shimmer"></div></div>
          <div class="gen__card"><div class="shimmer gen__shimmer"></div></div>
        </div>

        <!-- Mobile mid-content MPU — sits below the skeleton tiles, in the
             user's eyeline during the ~30s wait. -->
        <div class="ad-band ad-band--mid">
          <AdUnit
            viewport="mobile"
            slot="7649967912"
            width={300}
            height={250}
            label="purrtraits_generate_midcontent_mpu_mobile_300x250"
          />
        </div>

        <div id="error" class="gen__error" hidden>
          <p class="display">Something went wrong</p>
          <p class="muted" id="error-msg"></p>
          <button class="btn" onclick="window.location.reload()">Try again</button>
          <a href="/upload" class="btn">Use different photos</a>
        </div>
      </div>

      <aside class="gen-rail gen-rail--right">
        <AdUnit
          viewport="desktop"
          slot="7762708042"
          width={160}
          height={600}
          label="purrtraits_generate_railright_skyscraper_160x600"
          sticky="rail"
        />
      </aside>
    </div>
  </main>

  <!-- Mobile sticky bottom anchor banner. Pinned to the bottom of the
       viewport during the wait. -->
  <div class="gen-anchor-bottom">
    <AdUnit
      viewport="mobile"
      slot="9448248242"
      width={320}
      height={50}
      label="purrtraits_generate_viewport_anchor_banner_mobile_320x50"
      sticky="bottom"
    />
  </div>
</Layout>

<script>
  import { makeClient, getSessionId, requireOrRedirect, attachImageLoading } from "../lib/client.ts";
  import { isSignedIn, makeAuthedClient } from "../lib/authStorage.ts";
  import { api } from "../../convex/_generated/api.js";
  import { track } from "../lib/analytics.ts";
  import { STYLE_LABELS, type Style } from "../../convex/styleScoring.ts";

  const sessionId = getSessionId();
  if (!requireOrRedirect(sessionId, "/upload")) {
    // redirected
  } else if (!isSignedIn()) {
    // The fal action requires auth; bounce through /sign-up first. Style
    // selections + photos persist on the session, so the user resumes here
    // after signing up.
    window.location.href = "/sign-up?next=/generate";
  } else {
    // The pre-fal queries can stay un-authed (sessions.get is public), but
    // we use the authed client throughout to avoid juggling two clients.
    const client = makeAuthedClient();
    // Un-authed lookup of the session is fine and keeps the initial page
    // load fast; the action call is the one that actually requires auth.
    const readClient = makeClient();
    const session = await readClient.query(api.sessions.get, { id: sessionId as any });
    if (!session?.petPhotoUrls?.length || !session?.quizAnswers) {
      window.location.href = session?.petPhotoUrls?.length ? "/quiz" : "/upload";
    } else if (!session.selectedStyles || session.selectedStyles.length !== 3) {
      window.location.href = "/style-pick";
    } else {
      const preview = document.getElementById("pet-preview") as HTMLImageElement;
      attachImageLoading();
      preview.src = session.petPhotoUrls[0];

      const chosen = session.selectedStyles as Style[];

      // Render shimmer cards labelled with the styles the user actually picked.
      const grid = document.getElementById("gen-grid")!;
      grid.innerHTML = chosen
        .map(
          (s) => `
            <div class="gen__card">
              <div class="shimmer gen__shimmer"></div>
              <p class="display gen__label">${STYLE_LABELS[s] ?? s}</p>
            </div>`,
        )
        .join("");

      const petName = session.quizAnswers?.name?.trim();
      if (petName) {
        document.title = `Painting ${petName} · Purrtraits`;
        const titleEl = document.getElementById("title")!;
        titleEl.textContent = `Painting ${petName}…`;
        const sub = document.getElementById("subtitle")!;
        sub.textContent = `Our AI is brushing 3 unique styles for ${petName}. About 30 seconds.`;
      }

      // Friendly progress dots while we wait — Nano Banana usually finishes
      // in 15–25s. We don't have streaming progress, so we just animate.
      const dots = document.getElementById("dots")!;
      let frame = 0;
      const total = 5;
      const renderDots = () => {
        dots.innerHTML = "";
        for (let i = 0; i < total; i++) {
          const d = document.createElement("span");
          d.className = "dot" + (i <= frame ? " dot--on" : "");
          dots.appendChild(d);
        }
      };
      renderDots();
      const tick = setInterval(() => {
        frame = (frame + 1) % total;
        renderDots();
      }, 400);

      try { track("generation_started", { styles: chosen }); } catch { /* noop */ }

      try {
        const result = await client.action(api.fal.generatePortraits, {
          sessionId: sessionId as any,
          styles: chosen,
        });
        clearInterval(tick);
        if (result.count > 0) {
          window.location.href = "/reveal";
        } else {
          showError("No portraits came back. Please try again.");
        }
      } catch (err) {
        clearInterval(tick);
        showError((err as Error).message ?? "Generation failed");
      }
    }
  }

  function showError(msg: string) {
    const title = document.getElementById("title")!;
    const subtitle = document.getElementById("subtitle")!;
    const dots = document.getElementById("dots")!;
    const error = document.getElementById("error")!;
    const errorMsg = document.getElementById("error-msg")!;
    title.textContent = "Hmm — let's try that again";
    subtitle.textContent = "";
    dots.style.display = "none";
    error.hidden = false;
    errorMsg.textContent = msg;
  }
</script>

<style>
  .gen {
    max-width: 820px; margin: 0 auto; text-align: center;
    display: flex; flex-direction: column; align-items: center; gap: 16px;
  }
  .gen__pet-wrap {
    width: 96px; height: 96px; border-radius: 50%; overflow: hidden;
    border: 3px solid var(--c-pink-light);
  }
  .gen__pet {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .gen__dots { display: flex; gap: 8px; margin: 8px 0 16px; }
  .dot { width: 10px; height: 10px; border-radius: 50%; background: var(--c-stroke-light); transition: background .2s; }
  .dot--on { background: var(--c-pink); }

  .gen__grid {
    display: grid; gap: 16px;
    grid-template-columns: 1fr;
    width: 100%;
  }
  @media (min-width: 600px) { .gen__grid { grid-template-columns: repeat(3, 1fr); } }
  .gen__card { border: 1.5px solid var(--c-stroke-light); border-radius: var(--r-md); overflow: hidden; }
  .gen__shimmer { width: 100%; aspect-ratio: 4/5; }
  .gen__label { padding: 10px 12px; background: var(--c-white); text-align: left; font-size: 16px; }

  .gen__error {
    margin-top: 16px; display: flex; flex-direction: column; gap: 12px; align-items: center;
    padding: 24px; background: var(--c-pink-light); border: 1px solid var(--c-pink); border-radius: var(--r-md);
  }
  /* Make sure [hidden] beats the display:flex rule above. Without this the
     error box always shows during the loading state. */
  .gen__error[hidden] { display: none; }

  /* Sticky desktop anchor at the top of the viewport. The cream background
     + soft border match the page chrome so the slot reads as part of the
     site frame rather than floating content. Hidden on mobile via AdUnit. */
  .gen-anchor {
    position: sticky; top: 0; z-index: 30;
    background: var(--c-cream);
    border-bottom: 1px solid var(--c-stroke-light);
  }
  .gen-anchor :global(.ad-unit) { padding: 8px 0; }

  /* 3-column flex shell: left rail · loader · right rail. Rails are only
     visible at >=1200px (loader stays alone below that). */
  .gen-shell {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 24px;
    width: 100%;
  }
  .gen-rail {
    display: none; /* hidden by default; revealed at >=1200px below */
    flex-shrink: 0;
  }
  .gen-rail :global(.ad-unit) {
    position: sticky;
    top: 112px; /* clears the sticky anchor + a small gutter */
  }
  @media (min-width: 1200px) {
    .gen-rail { display: block; }
  }

  /* Mobile sticky anchor banner pinned to the bottom of the viewport.
     Hidden on desktop via AdUnit. */
  .gen-anchor-bottom {
    position: sticky; bottom: 0; z-index: 30;
    background: var(--c-cream);
    border-top: 1px solid var(--c-stroke-light);
  }
  .gen-anchor-bottom :global(.ad-unit) { padding: 6px 0; }

  .ad-band { display: flex; justify-content: center; }
  .ad-band--mid { padding: 24px 0 8px; }
</style>
