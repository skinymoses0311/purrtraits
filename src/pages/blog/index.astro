---
import Layout from "../../layouts/Layout.astro";
import FramedPlate from "../../components/blog/FramedPlate.astro";
import { getCollection } from "astro:content";
import type { ImageMetadata } from "astro";

// The Gallery Wall is data-driven from BOTH the breeds and photo-tips
// collections. Each plate links to its post and uses the post's hero image;
// PetArt is the fallback when a post hasn't specified one.

// ── Breeds collection ───────────────────────────────────────────
const allBreedPosts = await getCollection("blog");
const breedPosts = allBreedPosts.filter((p) => p.data.category === "breeds");

// Featured first, then newest publishDate. Stable for ties.
const sortedBreeds = [...breedPosts].sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return b.data.publishDate.getTime() - a.data.publishDate.getTime();
});

// ── Photo Tips collection ───────────────────────────────────────
const photoTipsPosts = await getCollection("photoTips");

// Filename order: leading "01-" through "10-" prefix on each .md file.
// Astro exposes the absolute path as `filePath`; we read the basename's
// numeric prefix off it.
function filePrefix(p: { filePath?: string }): number {
  const fp = p.filePath ?? "";
  const basename = fp.split(/[\\/]/).pop() ?? "";
  const m = /^(\d+)/.exec(basename);
  return m ? parseInt(m[1], 10) : 9999;
}
const sortedPhotoTips = [...photoTipsPosts].sort(
  (a, b) => filePrefix(a) - filePrefix(b),
);

// Photo-tips hero paths are stored as raw strings (e.g.
// "src/assets/blog/<slug>/01-hero.jpg") so we can route them through Vite's
// glob URL map at render time — same lookup the article template uses.
// `?url` returns a plain URL string (no Sharp re-encode; the JPGs are
// already sized).
const ptImgMap = import.meta.glob<string>(
  "/src/assets/blog/**/*.{jpg,jpeg,png,webp}",
  { eager: true, query: "?url", import: "default" },
);
function ptHeroUrl(file: string): string | undefined {
  const key = file.startsWith("/") ? file : `/${file}`;
  return ptImgMap[key];
}

// ── Unified wall item ───────────────────────────────────────────
// Both kinds of post are normalized into this shape before being zipped into
// slot geometry. Breeds carry an `image` (ImageMetadata, optimized by Astro);
// Photo Tips carry an `imageUrl` (plain string URL from import.meta.glob).
type WallItem = {
  href: string;
  image?: ImageMetadata;
  imageUrl?: string;
  alt: string;
  kicker: string;
  kickerColour: string;
  no: string;
  label: string;
  heroVariant?: number;
  heroBreed?: "pointy" | "floppy";
};

const breedItems: WallItem[] = sortedBreeds.map((p) => ({
  href: `/blog/breeds/${p.id}`,
  image: p.data.heroImage,
  alt: p.data.heroAlt ?? `${p.data.title} ${p.data.subtitle}`,
  kicker: "BREED SPOTLIGHT",
  kickerColour: "#D88A9A", // pinkDeep
  no: `No. ${p.data.issueNo} · ${p.data.readTime}`,
  label: p.data.subtitle,
  heroVariant: p.data.heroVariant,
  heroBreed: p.data.heroBreed,
}));

const photoTipsItems: WallItem[] = sortedPhotoTips.map((p) => {
  // Match the breed-plate format (e.g. "No. 14 · 11 min") — unpadded.
  const issueNum = String(filePrefix(p));
  const readMin = p.data.wordCount
    ? Math.max(3, Math.round(p.data.wordCount / 225))
    : 5;
  return {
    href: `/blog/photo-tips/${p.data.slug}`,
    imageUrl: ptHeroUrl(p.data.images.hero.file),
    alt: p.data.images.hero.alt,
    kicker: "PHOTO TIPS",
    kickerColour: "#9FB39A", // sage
    no: `No. ${issueNum} · ${readMin} min`,
    label: p.data.title,
  };
});

// Round-robin interleave starting with a breed, so the feature slot (gw-1)
// is always a breed cover-story. Falls through cleanly if either list is
// shorter than the other.
const interleaved: WallItem[] = [];
const maxLen = Math.max(breedItems.length, photoTipsItems.length);
for (let i = 0; i < maxLen; i++) {
  if (breedItems[i]) interleaved.push(breedItems[i]);
  if (photoTipsItems[i]) interleaved.push(photoTipsItems[i]);
}

// ── Curated slot geometry — 20 plates across 5 rows ─────────────
type Wood = "natural" | "gold" | "white" | "dark";
type Slot = { height: number; wood: Wood; tilt: number };
const slots: Slot[] = [
  // Row 1 — feature + two stacks (5)
  { height: 520, wood: "gold",    tilt: -0.5 },
  { height: 260, wood: "natural", tilt:  0.3 },
  { height: 220, wood: "white",   tilt: -0.4 },
  { height: 300, wood: "dark",    tilt:  0.5 },
  { height: 180, wood: "natural", tilt: -0.2 },
  // Row 2 — three, even (3)
  { height: 340, wood: "natural", tilt:  0.4 },
  { height: 400, wood: "gold",    tilt: -0.3 },
  { height: 320, wood: "white",   tilt:  0.5 },
  // Row 3 — four small plates (4)
  { height: 240, wood: "natural", tilt: -0.3 },
  { height: 240, wood: "white",   tilt:  0.2 },
  { height: 240, wood: "gold",    tilt: -0.4 },
  { height: 240, wood: "dark",    tilt:  0.3 },
  // Row 4 — four medium plates (4)
  { height: 260, wood: "white",   tilt:  0.4 },
  { height: 260, wood: "dark",    tilt: -0.3 },
  { height: 260, wood: "natural", tilt:  0.5 },
  { height: 260, wood: "gold",    tilt: -0.2 },
  // Row 5 — four small plates (4)
  { height: 220, wood: "gold",    tilt: -0.4 },
  { height: 220, wood: "natural", tilt:  0.3 },
  { height: 220, wood: "white",   tilt: -0.5 },
  { height: 220, wood: "dark",    tilt:  0.2 },
];

const wall = interleaved.slice(0, slots.length).map((item, i) => ({
  ...item,
  ...slots[i],
  id: `gw-${i}`,
}));

// Split by row for the staged grids the design uses.
const row1 = wall.slice(0, 5);  // feature + 2 stacks
const row2 = wall.slice(5, 8);  // three even
const row3 = wall.slice(8, 12); // four small
const row4 = wall.slice(12, 16); // four medium
const row5 = wall.slice(16, 20); // four small

// ── Category chips ──────────────────────────────────────────────
type ChipColour = "ink" | "pinkDeep" | "sage" | "ochre";
const colourHex: Record<ChipColour, string> = {
  ink: "#1F1612",
  pinkDeep: "#D88A9A",
  sage: "#9FB39A",
  ochre: "#D9A867",
};
const totals = {
  breeds: breedPosts.length,
  "photo-tips": photoTipsPosts.length,
  decor: allBreedPosts.filter((p) => p.data.category === "decor").length,
  gifts: allBreedPosts.filter((p) => p.data.category === "gifts").length,
  personality: allBreedPosts.filter((p) => p.data.category === "personality").length,
};
const totalAll = Object.values(totals).reduce((a, b) => a + b, 0);
const chips: { label: string; active: boolean; colour: ChipColour }[] = [
  { label: `ALL · ${totalAll}`, active: true, colour: "ink" },
  ...(totals.breeds        > 0 ? [{ label: `BREEDS · ${totals.breeds}`,            active: false, colour: "pinkDeep" as ChipColour }] : []),
  ...(totals["photo-tips"] > 0 ? [{ label: `PHOTO TIPS · ${totals["photo-tips"]}`, active: false, colour: "sage"     as ChipColour }] : []),
  ...(totals.decor         > 0 ? [{ label: `HOME & DÉCOR · ${totals.decor}`,       active: false, colour: "ochre"    as ChipColour }] : []),
  ...(totals.gifts         > 0 ? [{ label: `GIFTS · ${totals.gifts}`,              active: false, colour: "pinkDeep" as ChipColour }] : []),
  ...(totals.personality   > 0 ? [{ label: `PERSONALITY · ${totals.personality}`,  active: false, colour: "sage"     as ChipColour }] : []),
];
---

<Layout
  title="The Wall — Purrtraits Blog"
  description="A curated exhibit of breed spotlights, photo tips, décor and gift guides from the Purrtraits studio. Walk the room."
>
  <div class="gw">
    <!-- Header -->
    <section class="gw-head">
      <div class="gw-head__eyebrow">THE QUARTERLY · A CURATED EXHIBIT · MAY MMXXVI</div>
      <h1 class="gw-head__title"><em>The Wall.</em></h1>
      <p class="gw-head__lede">
        {totalAll} plates hung this season. Each is an article — on a breed, a photographic angle,
        a wall to hang it on, a dog to commission a painting of. Walk the room.
      </p>
      <div class="gw-chips">
        {
          chips.map((c) => (
            <button
              class:list={["gw-chip", { "gw-chip--active": c.active }]}
              style={`--chip-c:${colourHex[c.colour]};`}
            >
              {c.label}
            </button>
          ))
        }
      </div>
    </section>

    <!-- The Wall -->
    <section class="gw-wall">
      <div class="gw-rail"></div>

      <!-- Row 1 — feature + two stacks -->
      {
        row1.length > 0 && (
          <div class="gw-row gw-row--1">
            {row1[0] && (
              <FramedPlate
                id={row1[0].id}
                height={row1[0].height}
                wood={row1[0].wood}
                tilt={row1[0].tilt}
                kicker={row1[0].kicker}
                kickerColour={row1[0].kickerColour}
                no={row1[0].no}
                label={row1[0].label}
                image={row1[0].image}
                imageUrl={row1[0].imageUrl}
                alt={row1[0].alt}
                variant={row1[0].heroVariant}
                breed={row1[0].heroBreed}
                href={row1[0].href}
              />
            )}
            {(row1[1] || row1[2]) && (
              <div class="gw-stack">
                {[row1[1], row1[2]].map((s) =>
                  s ? (
                    <FramedPlate
                      id={s.id}
                      height={s.height}
                      wood={s.wood}
                      tilt={s.tilt}
                      kicker={s.kicker}
                      kickerColour={s.kickerColour}
                      no={s.no}
                      label={s.label}
                      image={s.image}
                      imageUrl={s.imageUrl}
                      alt={s.alt}
                      variant={s.heroVariant}
                      breed={s.heroBreed}
                      href={s.href}
                    />
                  ) : null,
                )}
              </div>
            )}
            {(row1[3] || row1[4]) && (
              <div class="gw-stack">
                {[row1[3], row1[4]].map((s) =>
                  s ? (
                    <FramedPlate
                      id={s.id}
                      height={s.height}
                      wood={s.wood}
                      tilt={s.tilt}
                      kicker={s.kicker}
                      kickerColour={s.kickerColour}
                      no={s.no}
                      label={s.label}
                      image={s.image}
                      imageUrl={s.imageUrl}
                      alt={s.alt}
                      variant={s.heroVariant}
                      breed={s.heroBreed}
                      href={s.href}
                    />
                  ) : null,
                )}
              </div>
            )}
          </div>
        )
      }

      <!-- Pull-quote -->
      <figure class="gw-quote">
        <div class="gw-quote__kicker">A NOTE FROM THE CURATOR</div>
        <blockquote class="gw-quote__text">
          "The right plate often becomes obvious only when you see the dog you know rendered in
          a way you don't."
        </blockquote>
        <figcaption class="gw-quote__by">— Marcus Tate, on the cover story</figcaption>
      </figure>

      <!-- Row 2 — three, even -->
      {
        row2.length > 0 && (
          <div class:list={["gw-row", `gw-row--2`, `gw-row--cols-${row2.length}`]}>
            {row2.map((s) => (
              <FramedPlate
                id={s.id}
                height={s.height}
                wood={s.wood}
                tilt={s.tilt}
                kicker={s.kicker}
                kickerColour={s.kickerColour}
                no={s.no}
                label={s.label}
                image={s.image}
                imageUrl={s.imageUrl}
                alt={s.alt}
                variant={s.heroVariant}
                breed={s.heroBreed}
                href={s.href}
              />
            ))}
          </div>
        )
      }

      <!-- Row 3 — small plates, up to four -->
      {
        row3.length > 0 && (
          <div class:list={["gw-row", `gw-row--3`, `gw-row--cols-${row3.length}`]}>
            {row3.map((s) => (
              <FramedPlate
                id={s.id}
                height={s.height}
                wood={s.wood}
                tilt={s.tilt}
                kicker={s.kicker}
                kickerColour={s.kickerColour}
                no={s.no}
                label={s.label}
                image={s.image}
                imageUrl={s.imageUrl}
                alt={s.alt}
                variant={s.heroVariant}
                breed={s.heroBreed}
                href={s.href}
              />
            ))}
          </div>
        )
      }

      <!-- Row 4 — medium plates, up to four -->
      {
        row4.length > 0 && (
          <div class:list={["gw-row", `gw-row--4`, `gw-row--cols-${row4.length}`]}>
            {row4.map((s) => (
              <FramedPlate
                id={s.id}
                height={s.height}
                wood={s.wood}
                tilt={s.tilt}
                kicker={s.kicker}
                kickerColour={s.kickerColour}
                no={s.no}
                label={s.label}
                image={s.image}
                imageUrl={s.imageUrl}
                alt={s.alt}
                variant={s.heroVariant}
                breed={s.heroBreed}
                href={s.href}
              />
            ))}
          </div>
        )
      }

      <!-- Row 5 — small plates, up to four -->
      {
        row5.length > 0 && (
          <div class:list={["gw-row", `gw-row--5`, `gw-row--cols-${row5.length}`]}>
            {row5.map((s) => (
              <FramedPlate
                id={s.id}
                height={s.height}
                wood={s.wood}
                tilt={s.tilt}
                kicker={s.kicker}
                kickerColour={s.kickerColour}
                no={s.no}
                label={s.label}
                image={s.image}
                imageUrl={s.imageUrl}
                alt={s.alt}
                variant={s.heroVariant}
                breed={s.heroBreed}
                href={s.href}
              />
            ))}
          </div>
        )
      }

      <div class="gw-more">
        <button class="gw-more__btn">WALK THE NEXT ROOM →</button>
        <div class="gw-more__sub">134 more plates in the archive</div>
      </div>
    </section>

    <!-- Commission strip -->
    <section class="gw-commission">
      <div>
        <div class="gw-commission__kicker">FROM THE STUDIO</div>
        <div class="gw-commission__title">A wall is only as good as the dog hanging on it.</div>
        <p class="gw-commission__body">
          Upload one photograph and commission a plate of your own. Painted, framed, posted within
          seven days.
        </p>
      </div>
      <div class="gw-commission__cta">
        <a href="/quiz" class="gw-btn gw-btn--pink">Take the style quiz →</a>
        <a href="/upload" class="gw-btn gw-btn--ghost">From £29 →</a>
      </div>
    </section>
  </div>
</Layout>

<style>
  .gw {
    /* Editorial palette — distinct from the main-site tokens. */
    --blog-ink: #1f1612;
    --blog-paper: #f4ecdd;
    --blog-wall: #e4d2b6;
    --blog-pink: #e5a6b3;
    --blog-mute: #6a5040;
    --blog-serif: Georgia, "Times New Roman", serif;
    background: var(--blog-wall);
    color: var(--blog-ink);
    font-family: var(--font-body);
  }

  /* ── Header ─────────────────────────────────────────────── */
  .gw-head {
    text-align: center;
    padding: 56px 24px 24px;
    max-width: 1320px;
    margin: 0 auto;
  }
  .gw-head__eyebrow {
    font-size: 11px;
    letter-spacing: 2.5px;
    color: #5c4030;
    font-weight: 700;
  }
  .gw-head__title {
    font-family: var(--blog-serif);
    font-weight: 400;
    color: var(--blog-ink);
    line-height: 0.98;
    margin-top: 14px;
    letter-spacing: -2.5px;
    font-size: clamp(52px, 9vw, 96px);
  }
  .gw-head__title em { font-style: italic; }
  .gw-head__lede {
    font-family: var(--blog-serif);
    font-style: italic;
    color: #5c4030;
    max-width: 680px;
    margin: 18px auto 0;
    line-height: 1.5;
    font-size: clamp(14px, 2.2vw, 18px);
  }
  .gw-chips {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 28px;
    flex-wrap: wrap;
  }
  .gw-chip {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 1.8px;
    font-weight: 700;
    color: var(--chip-c);
    background: transparent;
    border: 1px solid var(--chip-c);
    border-radius: 999px;
    padding: 8px 16px;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .gw-chip--active {
    color: #fff;
    background: var(--blog-ink);
    border-color: var(--blog-ink);
  }

  /* ── Wall ───────────────────────────────────────────────── */
  .gw-wall {
    position: relative;
    max-width: 1320px;
    margin: 0 auto;
    padding: 48px 40px 56px;
  }
  .gw-rail {
    position: absolute;
    top: 0;
    left: 40px;
    right: 40px;
    height: 1px;
    background: #9a7b58;
    box-shadow: 0 2px 0 rgba(180, 140, 90, 0.3);
  }
  .gw-row {
    display: grid;
    gap: 56px;
    align-items: start;
  }
  .gw-row--1 { grid-template-columns: 1.4fr 1fr 1fr; }
  .gw-row--2 { margin-top: 16px; }
  /* row 2 keeps the design's asymmetric 1 / 1.2 / 1 when it has all three; for
     fewer slots it falls back to equal columns so we don't leave empty space. */
  .gw-row--2.gw-row--cols-3 { grid-template-columns: 1fr 1.2fr 1fr; }
  .gw-row--2.gw-row--cols-2 { grid-template-columns: 1fr 1fr; }
  .gw-row--2.gw-row--cols-1 { grid-template-columns: 1fr; }
  .gw-row--3 { gap: 40px; margin-top: 72px; }
  .gw-row--3.gw-row--cols-4 { grid-template-columns: repeat(4, 1fr); }
  .gw-row--3.gw-row--cols-3 { grid-template-columns: repeat(3, 1fr); }
  .gw-row--3.gw-row--cols-2 { grid-template-columns: repeat(2, 1fr); }
  .gw-row--3.gw-row--cols-1 { grid-template-columns: 1fr; }
  /* Extended rows for the 20-plate wall: same column-count rules as row 3
     so partial rows stay balanced. Larger top-margin between rows gives the
     wall some breathing room as it gets longer. */
  .gw-row--4,
  .gw-row--5 { gap: 40px; margin-top: 72px; }
  .gw-row--4.gw-row--cols-4 { grid-template-columns: repeat(4, 1fr); }
  .gw-row--4.gw-row--cols-3 { grid-template-columns: repeat(3, 1fr); }
  .gw-row--4.gw-row--cols-2 { grid-template-columns: repeat(2, 1fr); }
  .gw-row--4.gw-row--cols-1 { grid-template-columns: 1fr; }
  .gw-row--5.gw-row--cols-4 { grid-template-columns: repeat(4, 1fr); }
  .gw-row--5.gw-row--cols-3 { grid-template-columns: repeat(3, 1fr); }
  .gw-row--5.gw-row--cols-2 { grid-template-columns: repeat(2, 1fr); }
  .gw-row--5.gw-row--cols-1 { grid-template-columns: 1fr; }
  .gw-stack {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  /* ── Pull-quote ─────────────────────────────────────────── */
  .gw-quote {
    margin: 80px auto 56px;
    max-width: 880px;
    text-align: center;
    padding: 32px 0;
    border-top: 1px solid #9a7b58;
    border-bottom: 1px solid #9a7b58;
  }
  .gw-quote__kicker {
    font-size: 10px;
    letter-spacing: 3px;
    color: #5c4030;
    font-weight: 700;
  }
  .gw-quote__text {
    font-family: var(--blog-serif);
    font-style: italic;
    color: var(--blog-ink);
    line-height: 1.25;
    margin: 14px 0 0;
    letter-spacing: -0.3px;
    font-size: clamp(19px, 3.4vw, 30px);
  }
  .gw-quote__by {
    font-family: var(--blog-serif);
    font-size: 14px;
    font-style: italic;
    color: #5c4030;
    margin-top: 14px;
  }

  /* ── More ───────────────────────────────────────────────── */
  .gw-more {
    text-align: center;
    margin-top: 64px;
  }
  .gw-more__btn {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    color: #fff;
    background: var(--blog-ink);
    border: none;
    border-radius: 999px;
    padding: 14px 36px;
    cursor: pointer;
    letter-spacing: 2px;
  }
  .gw-more__sub {
    font-family: var(--blog-serif);
    font-size: 13px;
    font-style: italic;
    color: #5c4030;
    margin-top: 14px;
  }

  /* ── Commission strip ───────────────────────────────────── */
  .gw-commission {
    background: var(--blog-ink);
    color: var(--blog-paper);
    padding: 56px 40px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 32px;
    align-items: center;
  }
  .gw-commission__kicker {
    font-size: 11px;
    letter-spacing: 3px;
    color: var(--blog-pink);
    font-weight: 700;
  }
  .gw-commission__title {
    font-family: var(--blog-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--blog-paper);
    line-height: 1;
    margin-top: 10px;
    letter-spacing: -1.2px;
    max-width: 760px;
    font-size: clamp(30px, 4.6vw, 48px);
  }
  .gw-commission__body {
    font-family: var(--blog-serif);
    font-size: clamp(14px, 2vw, 16px);
    color: #d8c8b0;
    line-height: 1.55;
    margin-top: 14px;
    font-style: italic;
    max-width: 620px;
  }
  .gw-commission__cta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .gw-btn {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    border-radius: 999px;
    padding: 14px 28px;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
  }
  .gw-btn--pink { color: #fff; background: var(--blog-pink); border: none; }
  .gw-btn--ghost { color: var(--blog-paper); background: transparent; border: 1px solid var(--blog-paper); font-weight: 600; }

  /* ── Plate reveal + hover (progressive enhancement) ─────── */
  .gw :global(.gw-plate) {
    transform: translateY(48px) rotate(0deg);
    opacity: 0;
    transition:
      opacity 1s cubic-bezier(0.22, 1, 0.36, 1),
      transform 1.1s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform;
  }
  .gw :global(.gw-plate.in) {
    opacity: 1;
    transform: translateY(0) rotate(var(--gw-tilt, 0deg));
  }
  .gw :global(.gw-frame) {
    box-shadow:
      0 24px 40px -16px rgba(40, 28, 16, 0.45),
      0 6px 14px rgba(40, 28, 16, 0.22);
    transition: box-shadow 0.35s ease, transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }
  @media (hover: hover) {
    .gw :global(a.gw-plate.in:hover) {
      transform: translateY(-6px) rotate(calc(var(--gw-tilt, 0deg) * 0.3));
      z-index: 2;
    }
    .gw :global(a.gw-plate.in:hover .gw-frame) {
      box-shadow:
        0 36px 60px -20px rgba(40, 28, 16, 0.55),
        0 12px 24px rgba(40, 28, 16, 0.28);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gw :global(.gw-plate) {
      opacity: 1 !important;
      transform: rotate(var(--gw-tilt, 0deg)) !important;
      transition: none !important;
    }
  }

  /* ── Responsive collapse ────────────────────────────────── */
  @media (max-width: 900px) {
    .gw-head { padding: 32px 18px 12px; }
    .gw-head__title { letter-spacing: -1.5px; }
    .gw-head__lede { max-width: 100%; }
    .gw-chips {
      justify-content: flex-start;
      flex-wrap: nowrap;
      overflow-x: auto;
      margin-top: 18px;
      padding-bottom: 4px;
    }
    .gw-wall { padding: 24px 20px 0; }
    .gw-rail { left: 20px; right: 20px; }
    .gw-row,
    .gw-row--1,
    .gw-row--2,
