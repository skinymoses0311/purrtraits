</style>

<script>
  // Rise + hover reveal, mirroring the design's IntersectionObserver. Plates
  // start translated/rotated-flat and settle into their tilt as they enter.
  const obs = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.add("in");
          obs.unobserve(e.target);
        }
      }
    },
    { threshold: 0.06, rootMargin: "0px 0px -4% 0px" },
  );
  document.querySelectorAll(".gw-plate").forEach((el) => obs.observe(el));
</script>
