---
import Layout from "../../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import PinPhoto from "../../../components/blog/spec/PinPhoto.astro";
import Caption from "../../../components/blog/spec/Caption.astro";
import PinLegend from "../../../components/blog/spec/PinLegend.astro";
import Diagram from "../../../components/blog/spec/diagrams/Diagram.astro";
import { parseBody, splitBoldLeader } from "../../../lib/photoTipsParse";

// ── Routing ─────────────────────────────────────────────────────
// Use the manifest's `slug` field as the URL — it's what the
// `related` cross-links in other posts point at, and it's the
// stable identifier the design refers to (not the filename).
export async function getStaticPaths() {
  const posts = await getCollection("photoTips");
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const d = post.data;

// ── Asset lookup ────────────────────────────────────────────────
// Manifest paths look like "src/assets/blog/<slug>/<id>.jpg". The
// glob keys come from Vite as "/src/assets/blog/<slug>/<id>.jpg",
// so we prefix with a slash. Eager+url gives a plain string URL
// (no Sharp re-encode — these JPGs are already sized).
const imgMap = import.meta.glob<string>(
  "/src/assets/blog/**/*.{jpg,jpeg,png,webp}",
  { eager: true, query: "?url", import: "default" },
);
const url = (file: string): string => {
  const key = file.startsWith("/") ? file : `/${file}`;
  const u = imgMap[key];
  if (!u) {
    throw new Error(
      `[photo-tips] missing asset for "${file}" (post: ${d.slug}). ` +
        `Expected key "${key}" in import.meta.glob map.`,
    );
  }
  return u;
};

// ── Body ────────────────────────────────────────────────────────
const parsed = parseBody(post.body ?? "");

// Map pairs and diagrams by step number for O(1) lookup inside the
// step loop.
const pairByStep = new Map(d.images.pairs.map((p) => [p.step, p]));
const diagramByStep = new Map(d.diagrams.map((dg) => [dg.step, dg]));

// ── TOC ─────────────────────────────────────────────────────────
const toc: { mark: string; title: string; href: string }[] = [];
if (parsed.whyThisMatters) {
  toc.push({ mark: "00", title: "Why this matters", href: "#why-this-matters" });
}
if (parsed.procedure) {
  for (const s of parsed.procedure.steps) {
    toc.push({ mark: s.no, title: s.title, href: `#step-${s.no}` });
  }
}
if (parsed.commonMistakes) {
  toc.push({ mark: "—", title: parsed.commonMistakes.title, href: "#common-mistakes" });
}
if (parsed.checklist) {
  toc.push({ mark: "✓", title: "Pre-flight checklist", href: "#checklist" });
}
toc.push({ mark: "→", title: "Ready to upload", href: "#ready" });

// Step prose split: first paragraph becomes the "action" line
// (a stand-in for the design's DO row), the rest is the explainer.
function splitStepProse(html: string): { action: string; rest: string } {
  const match = /^<p>([\s\S]*?)<\/p>([\s\S]*)$/.exec(html.trim());
  if (!match) return { action: "", rest: html };
  return { action: match[1], rest: match[2].trim() };
}

// Common-mistakes title/desc per card. Front-matter thumbs (post 01
// only) are zipped with the bullets in body order; if thumbs are
// absent, the cards render with a placeholder ✗ square so the grid
// still reads as a grid.
const commonMistakeCards =
  parsed.commonMistakes?.bullets?.map((line, i) => {
    const { title, rest } = splitBoldLeader(line);
    const thumb = d.images.commonMistakeThumbs[i];
    return { code: `E${String(i + 1).padStart(2, "0")}`, title, desc: rest, thumb };
  }) ?? [];

// Related links: photo-tips → /blog/photo-tips/<slug>, breed →
// /blog/breeds/<slug>. The breed slugs in these manifests are all
// already-published breed posts, so the links resolve.
const relatedHref = (r: { type: string; slug: string }): string =>
  r.type === "breed" ? `/blog/breeds/${r.slug}` : `/blog/photo-tips/${r.slug}`;

// Issue display: front-matter has "TBC" while posts are in draft —
// fall back to the post's filename prefix (01-… → "001"). The glob
// loader uses the front-matter `slug` as `post.id`, so we read the
// numeric prefix off `post.filePath` instead, which Astro exposes
// as the absolute path of the source markdown file.
const issueDisplay = (() => {
  if (d.issue && d.issue !== "TBC") return d.issue.padStart(3, "0");
  const fp = post.filePath ?? "";
  const basename = fp.split(/[\\/]/).pop() ?? "";
  const m = /^(\d+)/.exec(basename);
  return m ? m[1].padStart(3, "0") : "—";
})();

// Author initial for the avatar disc.
const authorInitial = d.author.slice(0, 1).toUpperCase();

// Reading time estimate — wordCount / 225 wpm.
const readMinutes = d.wordCount ? Math.max(3, Math.round(d.wordCount / 225)) : 6;
---

<Layout title={d.metaTitle} description={d.metaDescription} noindex={false}>
  <article class="ps">
    <!-- Crumb -->
    <div class="ps-crumb">
      BLOG · PHOTO TIPS · {issueDisplay} / HOW-TO
    </div>

    <!-- HEADER: H1 + spec table -->
    <header class="ps-header">
      <div class="ps-header__left">
        <span class="ps-header__pill">HOW-TO · {readMinutes} MIN READ</span>
        <h1 class="ps-h1">{d.title}</h1>
        <p class="ps-header__lede">{d.metaDescription}</p>
      </div>
      <aside class="ps-spec">
        <div class="ps-spec__head">
          <span>SPEC SHEET</span>
          <span class="ps-spec__no">NO. {issueDisplay}</span>
        </div>
        {d.specTable.map((row) => (
          <div class="ps-spec__row">
            <span class="ps-spec__k">{row.label}</span>
            <span class="ps-spec__v">{row.value}</span>
          </div>
        ))}
        <div class="ps-spec__author">
          <span class="ps-spec__avatar">{authorInitial}</span>
          <div>
            <div class="ps-spec__author-name">{d.author}</div>
            <div class="ps-spec__author-meta">STUDIO PHOTOGRAPHER</div>
          </div>
        </div>
      </aside>
    </header>

    <!-- HERO -->
    <div class="ps-hero">
      <div class="ps-hero__frame">
        <img
          src={url(d.images.hero.file)}
          srcset={`${url(d.images.hero.file)} 1x, ${url(d.images.hero.file2x)} 2x`}
          alt={d.images.hero.alt}
          loading="eager"
          decoding="async"
        />
        <span class="ps-hero__badge">{d.images.hero.badge}</span>
      </div>
    </div>

    <!-- TWO-COL: TOC sidebar + main -->
    <div class="ps-body">
      <!-- SIDEBAR -->
      <aside class="ps-aside">
        <div class="ps-aside__sticky">
          <nav class="ps-toc" aria-label="Contents">
            <div class="ps-toc__head">CONTENTS</div>
            {toc.map((row, i) => (
              <a
                class:list={["ps-toc__row", { "ps-toc__row--last": i === toc.length - 1 }]}
                href={row.href}
              >
                <span class="ps-toc__mark">{row.mark}</span>
                <span class="ps-toc__title">{row.title}</span>
              </a>
            ))}
          </nav>
          <div class="ps-aside__cta">
            <div class="ps-aside__kicker">REFERENCE</div>
            <div class="ps-aside__title">Done reading?<br />Try a photo now.</div>
            <div class="ps-aside__sub">Free preview in 60 seconds.</div>
            <a href="/upload" class="ps-aside__btn">UPLOAD A PHOTO →</a>
          </div>
          <div class="ps-ad ps-ad--mrec">
            <span class="ps-ad__label">ADVERTISEMENT</span>
            <span class="ps-ad__txt">300 × 250</span>
          </div>
        </div>
      </aside>

      <!-- MAIN -->
      <main class="ps-article">
        {parsed.intro && (
          <div class="ps-intro" set:html={parsed.intro} />
        )}

        {parsed.whyThisMatters && (
          <section id="why-this-matters">
            <header class="ps-h2-block">
              <div class="ps-h2-block__kicker">CONTEXT · 00</div>
              <h2 class="ps-h2">{parsed.whyThisMatters.title}</h2>
            </header>
            <div class="ps-why">
              <div class="ps-why__prose" set:html={parsed.whyThisMatters.html} />
              {d.stats.length > 0 && (
                <div class="ps-stats">
                  <div class="ps-stats__head">INTERNAL DATA · {new Date().getFullYear()}</div>
                  {d.stats.map((s, i) => (
                    <div class:list={["ps-stats__row", { "ps-stats__row--first": i === 0 }]}>
                      <div class="ps-stats__v">{s.value}</div>
                      <div class="ps-stats__l">{s.label}</div>
                    </div>
                  ))}
                </div>
              )}
            </div>
          </section>
        )}

        {parsed.procedure && (
          <section>
            <header class="ps-h2-block">
              <div class="ps-h2-block__kicker">
                PROCEDURE · 01–{String(parsed.procedure.steps.length).padStart(2, "0")}
              </div>
              <h2 class="ps-h2">{parsed.procedure.h2Title}</h2>
            </header>
            {parsed.procedure.intro && (
              <div class="ps-proc-intro" set:html={parsed.procedure.intro} />
            )}

            {parsed.procedure.steps.map((step) => {
              const { action, rest } = splitStepProse(step.html);
              const pair = pairByStep.get(step.no);
              const dg = diagramByStep.get(step.no);
              return (
                <div class="ps-step" id={`step-${step.no}`}>
                  <div class="ps-step__head">
                    <div class="ps-step__no">
                      <span class="ps-step__label">STEP</span>
                      <span class="ps-step__num">{step.no}</span>
                    </div>
                    <div class="ps-step__title-block">
                      <h3 class="ps-step__title">{step.title}</h3>
                    </div>
                  </div>

                  {action && (
                    <div class="ps-step__action">
                      <span class="ps-step__action-verb">DO</span>
                      <span class="ps-step__action-body" set:html={action} />
                    </div>
                  )}

                  {pair && (
                    <div class="ps-pair">
                      <div class="ps-pair__cell">
                        <PinPhoto
                          src={url(pair.good.file)}
                          src2x={url(pair.good.file2x)}
                          alt={pair.good.alt}
                          status={pair.good.status}
                          pins={pair.good.pins.map((p) => ({ n: p.n, x: p.x, y: p.y, note: p.note }))}
                        />
                        <Caption no={`${pair.step}a`} label={pair.good.caption} status={pair.good.status} />
                        {pair.good.pins.length > 0 && (
                          <PinLegend
                            status={pair.good.status}
                            items={pair.good.pins.map((p) => ({ n: p.n, note: p.note }))}
                          />
                        )}
                      </div>
                      <div class="ps-pair__cell">
                        <PinPhoto
                          src={url(pair.bad.file)}
                          src2x={url(pair.bad.file2x)}
                          alt={pair.bad.alt}
                          status={pair.bad.status}
                          pins={pair.bad.pins.map((p) => ({ n: p.n, x: p.x, y: p.y, note: p.note }))}
                        />
                        <Caption no={`${pair.step}b`} label={pair.bad.caption} status={pair.bad.status} />
                        {pair.bad.pins.length > 0 && (
                          <PinLegend
                            status={pair.bad.status}
                            items={pair.bad.pins.map((p) => ({ n: p.n, note: p.note }))}
                          />
                        )}
                      </div>
                    </div>
                  )}

                  {dg && <Diagram archetype={dg.archetype} label={dg.label} />}

                  {rest && <div class="ps-step__prose" set:html={rest} />}
                </div>
              );
            })}
          </section>
        )}

        {parsed.commonMistakes && (
          <section id="common-mistakes">
            <header class="ps-h2-block">
              <div class="ps-h2-block__kicker">ERRATA</div>
              <h2 class="ps-h2">{parsed.commonMistakes.title}</h2>
            </header>
            {commonMistakeCards.length > 0 ? (
              <div class="ps-mistakes">
                {commonMistakeCards.map((card) => (
                  <div class="ps-mistake">
                    <div class="ps-mistake__thumb">
                      {card.thumb ? (
                        <img
                          src={url(card.thumb.file)}
                          srcset={`${url(card.thumb.file)} 1x, ${url(card.thumb.file2x)} 2x`}
                          alt={card.title}
                          loading="lazy"
                          decoding="async"
                        />
                      ) : (
                        <div class="ps-mistake__thumb-placeholder">✗</div>
                      )}
                      <div class="ps-mistake__x">✗</div>
                    </div>
                    <div class="ps-mistake__body">
                      <div class="ps-mistake__code">{card.code}</div>
                      <div class="ps-mistake__title">{card.title}</div>
                      <div class="ps-mistake__desc">{card.desc}</div>
                    </div>
                  </div>
                ))}
              </div>
            ) : (
              <div class="ps-mistakes-prose" set:html={parsed.commonMistakes.html} />
            )}
          </section>
        )}

        {parsed.checklist && (
          <section id="checklist">
            <header class="ps-h2-block">
              <div class="ps-h2-block__kicker">REFERENCE · TEAR-OUT</div>
              <h2 class="ps-h2">Pre-flight checklist</h2>
              <div class="ps-h2-block__tag">Screenshot this. We made it for that.</div>
            </header>
            <div class="ps-check">
              <div class="ps-check__perf"></div>
              <div class="ps-check__corner">
                PURRTRAITS<br /><span>v.2026.05</span>
              </div>
              <div class="ps-check__pill">PRE-FLIGHT CHECKLIST</div>
              <h3 class="ps-check__title">Before you upload,<br />run these checks.</h3>
              <div class="ps-check__grid">
                {(parsed.checklist.bullets ?? []).map((line, i) => {
                  const { title, rest } = splitBoldLeader(line);
                  const text = rest ? `${title} — ${rest}` : title;
                  return (
                    <div class="ps-check__row">
                      <span class="ps-check__box">✓</span>
                      <div>
                        <div class="ps-check__n">{String(i + 1).padStart(2, "0")}</div>
                        <div class="ps-check__t">{text}</div>
                      </div>
                    </div>
                  );
                })}
              </div>
              <div class="ps-check__foot">
                <div>
                  <div class="ps-check__foot-k">NEXT STEP</div>
                  <div class="ps-check__foot-t">Upload at purrtraits.com/upload</div>
                </div>
                <a href="/upload" class="ps-check__cta">get the shot →</a>
              </div>
            </div>
          </section>
        )}

        {parsed.inlineCta && (
          <div class="ps-inline">
            <div>
              <div class="ps-inline__kicker">CHECKLIST DONE? §</div>
              <div class="ps-inline__title">Get a preview before you commit.</div>
              <div class="ps-inline__body" set:html={parsed.inlineCta} />
            </div>
            <a href="/upload" class="ps-inline__btn">UPLOAD A PHOTO →</a>
          </div>
        )}

        {parsed.readyToUpload && (
          <section id="ready" class="ps-fin">
            <div class="ps-fin__mark">FIN · {issueDisplay}</div>
            <h2 class="ps-fin__h2">Ready to upload?</h2>
            <div class="ps-fin__body" set:html={parsed.readyToUpload} />
            <div class="ps-fin__cta">
              <a href="/upload" class="ps-fin__btn">UPLOAD YOUR PHOTO →</a>
              <a href="/gallery" class="ps-fin__btn ps-fin__btn--ghost">SEE SAMPLE STYLES</a>
            </div>
          </section>
        )}
      </main>
    </div>

    <!-- RELATED -->
    {d.related.length > 0 && (
      <section class="ps-related">
        <div class="ps-related__head">FURTHER READING</div>
        <div class="ps-related__grid">
          {d.related.map((r) => (
            <a class="ps-rel" href={relatedHref(r)}>
              <div class="ps-rel__art" aria-hidden="true"></div>
              <div class="ps-rel__kicker">
                {r.type === "breed" ? "BREED SPOTLIGHT" : "PHOTO TIPS"}
              </div>
              <div class="ps-rel__title">{r.title}</div>
              <div class="ps-rel__meta">READ →</div>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</Layout>

<style is:global>
  /* ── Spec Sheet design tokens ──────────────────────────────── */
  /* These are defined globally only on .ps so the scoped child
     components (PinPhoto, Caption, PinLegend, Diagram) can
     reference --ps-mono / --ps-ink / --ps-ink-mute. */
  .ps {
    --ps-mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    --ps-ink: #2D1F1A;
    --ps-ink-soft: #5C4A3F;
    --ps-ink-mute: #8A7766;
    --ps-cream: #FFFDF8;
    --ps-cream-deep: #F2EBE0;
    --ps-stroke: #C4A882;
    --ps-pink: #E8A4B8;
    --ps-pink-deep: #D88A9A;
    --ps-pink-soft: #F7E8EE;
  }
</style>

<style>
  /* ── Article wrapper ───────────────────────────────────────── */
  .ps {
    background: var(--ps-cream);
    color: var(--ps-ink);
    font-family: var(--font-body);
    display: block;
  }

  /* ── Crumb + header ────────────────────────────────────────── */
  .ps-crumb {
    padding: 24px 56px 0;
    font-family: var(--ps-mono);
    font-size: 10px;
    letter-spacing: 1.8px;
    color: var(--ps-ink-mute);
    font-weight: 700;
  }

  .ps-header {
    padding: 18px 56px 0;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 48px;
    align-items: end;
  }
  .ps-header__pill {
    display: inline-block;
    padding: 5px 10px;
    background: var(--ps-ink);
    color: var(--ps-cream);
    font-family: var(--ps-mono);
    font-size: 10px;
    letter-spacing: 2px;
    font-weight: 700;
  }
  .ps-h1 {
    font-family: var(--font-body);
    font-size: clamp(38px, 6vw, 84px);
    font-weight: 800;
    color: var(--ps-ink);
    line-height: 0.95;
    margin-top: 14px;
    letter-spacing: -2px;
  }
  .ps-header__lede {
    font-family: var(--font-body);
    font-size: 18px;
    color: var(--ps-ink-soft);
    margin-top: 18px;
    line-height: 1.5;
    max-width: 540px;
  }

  /* ── Spec table ────────────────────────────────────────────── */
  .ps-spec {
    border: 1px solid var(--ps-ink);
    background: #fff;
  }
  .ps-spec__head {
    padding: 10px 16px;
    border-bottom: 1.5px solid var(--ps-ink);
    font-family: var(--ps-mono);
    font-size: 10px;
    letter-spacing: 2px;
    font-weight: 700;
    color: var(--ps-ink);
    display: flex;
    justify-content: space-between;
  }
  .ps-spec__no { color: var(--ps-pink-deep); }
  .ps-spec__row {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    padding: 10px 16px;
    border-bottom: 1px dashed var(--ps-ink-mute);
  }
  .ps-spec__k {
    font-family: var(--ps-mono);
    font-size: 10px;
    color: var(--ps-ink-mute);
    letter-spacing: 1px;
    font-weight: 700;
  }
  .ps-spec__v {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--ps-ink);
    font-weight: 600;
  }
  .ps-spec__author {
    padding: 14px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .ps-spec__avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--ps-pink-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 700;
    color: var(--ps-pink-deep);
  }
  .ps-spec__author-name {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    color: var(--ps-ink);
  }
  .ps-spec__author-meta {
    font-family: var(--ps-mono);
    font-size: 10px;
    color: var(--ps-ink-mute);
    margin-top: 1px;
  }

  /* ── Hero ──────────────────────────────────────────────────── */
  .ps-hero { padding: 36px 56px 0; }
  .ps-hero__frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #E4D2B6;
  }
  .ps-hero__frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ps-hero__badge {
    position: absolute;
    top: 18px;
    right: 18px;
    padding: 8px 12px;
    background: rgba(20, 15, 12, 0.78);
    color: #F8EAD0;
    font-family: var(--ps-mono);
    font-size: 10px;
    letter-spacing: 1.5px;
  }

  /* ── Body grid ─────────────────────────────────────────────── */
  .ps-body {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 48px;
    padding: 48px 56px 0;
    align-items: start;
  }
  .ps-article { min-width: 0; }
  .ps-aside { align-self: stretch; }
  .ps-aside__sticky {
    position: sticky;
    top: 88px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* ── TOC ───────────────────────────────────────────────────── */
  .ps-toc {
    border: 2px solid var(--ps-ink);
    background: #fff;
    padding: 18px 18px;
  }
  .ps-toc__head {
    font-family: var(--ps-mono);
    font-size: 9px;
    letter-spacing: 2px;
    color: var(--ps-ink);
    font-weight: 700;
    border-bottom: 1.5px solid var(--ps-ink);
    padding-bottom: 8px;
    margin-bottom: 8px;
  }
  .ps-toc__row {
    display: flex;
    gap: 10px;
    padding: 7px 0;
    border-bottom: 1px dashed var(--ps-stroke);
    text-decoration: none;
    color: inherit;
  }
  .ps-toc__row--last { border-bottom: none; }
  .ps-toc__row:hover .ps-toc__title { color: var(--ps-pink-deep); }
  .ps-toc__mark {
    font-family: var(--ps-mono);
    font-size: 10px;
    color: var(--ps-pink-deep);
    font-weight: 700;
    width: 18px;
  }
  .ps-toc__title {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--ps-ink);
    font-weight: 500;
    transition: color 0.15s;
  }

  /* ── Sidebar CTA + ad ──────────────────────────────────────── */
  .ps-aside__cta {
    border: 1px solid var(--ps-ink);
    background: var(--ps-pink-soft);
    padding: 16px 16px;
  }
  .ps-aside__kicker {
    font-family: var(--ps-mono);
    font-size: 9px;
