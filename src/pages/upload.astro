---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Upload your pet's photos · Purrtraits">
  <main class="page container">
    <a href="/" class="back-link muted">← Back</a>

    <div class="upload">
      <div class="upload__intro">
        <h1>Upload your pet's photos</h1>
        <p class="muted">
          Add 1–5 clear photos of your pet. More angles = a better likeness in the final art. 🐶🐱
        </p>
      </div>

      <div class="upload__layout">
        <div class="upload__col">
          <div class="dropzone" id="dropzone">
            <input id="file" type="file" accept="image/*" multiple hidden />
            <label for="file" class="dropzone__label">
              <div class="dropzone__icon">📷</div>
              <p class="display dropzone__title" id="dz-title">Tap or drop photos here</p>
              <p class="muted dropzone__hint">JPG or PNG · up to 10MB each · max 5 photos</p>
            </label>
          </div>

          <ul class="thumbs" id="thumbs"></ul>

          <div id="status" class="status muted" aria-live="polite"></div>
          <button id="continue" class="btn btn--primary btn--block" disabled>
            Continue to style quiz →
          </button>
        </div>

        <aside class="upload__tips">
          <h3 class="display">Tips for best results</h3>
          <ul class="tips">
            <li><span class="tick">✓</span> Good lighting — natural is best</li>
            <li><span class="tick">✓</span> Clear face, looking forward</li>
            <li><span class="tick">✓</span> No sunglasses or hats</li>
            <li><span class="tick">✓</span> Single pet, not a group shot</li>
            <li><span class="tick">✓</span> 2–3 different angles work great</li>
          </ul>
        </aside>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { makeClient, ensureSession } from "../lib/client.ts";
  import { api } from "../../convex/_generated/api.js";
  import type { Id } from "../../convex/_generated/dataModel";

  const MAX_PHOTOS = 5;
  const MAX_BYTES = 10 * 1024 * 1024;

  const client = makeClient();
  const fileInput = document.getElementById("file") as HTMLInputElement;
  const dropzone = document.getElementById("dropzone")!;
  const thumbs = document.getElementById("thumbs")!;
  const dzTitle = document.getElementById("dz-title")!;
  const continueBtn = document.getElementById("continue") as HTMLButtonElement;
  const status = document.getElementById("status")!;

  type Photo = { url: string; index: number };
  // Mirror of session.petPhotoUrls so we can render thumbs locally without
  // re-fetching after every upload.
  let photos: Photo[] = [];
  let sessionId: Id<"sessions"> | null = null;

  // If the user finished a previous flow in this session and is back at
  // /upload, treat that as "start a new portrait". We clear photos/quiz/
  // generations but preserve the session id so the gallery survives.
  {
    const existing = (await import("../lib/client.ts")).getSessionId();
    if (existing) {
      const session = await client.query(api.sessions.get, { id: existing });
      if (session?.generations) {
        await client.mutation(api.sessions.clearCurrentFlow, { id: existing });
      }
    }
  }

  function setStatus(msg: string, kind: "info" | "error" = "info") {
    status.textContent = msg;
    status.style.color = kind === "error" ? "#b14" : "var(--c-text)";
  }

  function refresh() {
    thumbs.innerHTML = "";
    photos.forEach((p, i) => {
      const li = document.createElement("li");
      li.className = "thumb-item";
      li.innerHTML = `
        <img src="${p.url}" alt="Pet photo ${i + 1}" />
        <button class="thumb-item__remove" data-i="${i}" aria-label="Remove">×</button>
      `;
      thumbs.appendChild(li);
    });
    thumbs.querySelectorAll<HTMLButtonElement>(".thumb-item__remove").forEach((btn) => {
      btn.addEventListener("click", () => removePhoto(parseInt(btn.dataset.i!)));
    });
    continueBtn.disabled = photos.length === 0;
    dzTitle.textContent =
      photos.length === 0
        ? "Tap or drop photos here"
        : photos.length >= MAX_PHOTOS
          ? "Maximum reached"
          : `Add another (${photos.length}/${MAX_PHOTOS})`;
    dropzone.classList.toggle("dropzone--full", photos.length >= MAX_PHOTOS);
  }

  async function removePhoto(index: number) {
    if (!sessionId) return;
    await client.mutation(api.sessions.removePhoto, { id: sessionId, index });
    photos.splice(index, 1);
    // Re-index remaining
    photos = photos.map((p, i) => ({ ...p, index: i }));
    refresh();
  }

  async function handleFiles(files: FileList | File[]) {
    const list = Array.from(files);
    if (list.length === 0) return;

    if (!sessionId) sessionId = await ensureSession(client);

    for (const file of list) {
      if (photos.length >= MAX_PHOTOS) {
        setStatus(`Max ${MAX_PHOTOS} photos.`, "error");
        break;
      }
      if (!file.type.startsWith("image/")) {
        setStatus(`${file.name}: not an image.`, "error");
        continue;
      }
      if (file.size > MAX_BYTES) {
        setStatus(`${file.name}: bigger than 10MB.`, "error");
        continue;
      }
      try {
        setStatus(`Uploading ${file.name}…`);
        const uploadUrl = await client.mutation(api.files.generateUploadUrl, {});
        const res = await fetch(uploadUrl, {
          method: "POST",
          headers: { "Content-Type": file.type },
          body: file,
        });
        if (!res.ok) throw new Error(`upload failed (${res.status})`);
        const { storageId } = await res.json();
        const { url } = await client.mutation(api.sessions.addPhoto, {
          id: sessionId,
          storageId: storageId as any,
        });
        photos.push({ url, index: photos.length });
        refresh();
        setStatus(`✓ ${photos.length} photo${photos.length === 1 ? "" : "s"} ready`);
      } catch (err) {
        setStatus(`Upload failed: ${(err as Error).message}`, "error");
      }
    }
  }

  // ----- Dropzone wiring -----
  ["dragover", "dragenter"].forEach((evt) =>
    dropzone.addEventListener(evt, (e) => {
      e.preventDefault();
      dropzone.classList.add("dropzone--hover");
    }),
  );
  ["dragleave", "drop"].forEach((evt) =>
    dropzone.addEventListener(evt, (e) => {
      e.preventDefault();
      dropzone.classList.remove("dropzone--hover");
    }),
  );
  dropzone.addEventListener("drop", (e) => {
    const files = (e as DragEvent).dataTransfer?.files;
    if (files) handleFiles(files);
  });
  fileInput.addEventListener("change", () => {
    if (fileInput.files) handleFiles(fileInput.files);
    fileInput.value = ""; // allow re-selecting same file
  });

  continueBtn.addEventListener("click", () => {
    if (photos.length === 0) return;
    window.location.href = "/quiz";
  });
</script>

<style>
  .back-link { display: inline-block; margin-bottom: 16px; }
  .upload__intro { text-align: center; margin-bottom: 32px; }
  .upload__layout { display: grid; gap: 32px; grid-template-columns: 1fr; }
  @media (min-width: 900px) {
    .upload__layout { grid-template-columns: 1.2fr 1fr; gap: 48px; align-items: start; }
  }

  .dropzone {
    background: var(--c-pink-light); border: 2px dashed var(--c-pink); border-radius: var(--r-md);
    transition: background .15s ease;
  }
  .dropzone--hover { background: #f6dde6; }
  .dropzone--full { opacity: .55; pointer-events: none; }
  .dropzone__label {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 6px; padding: 40px 24px; min-height: 220px; cursor: pointer;
  }
  .dropzone__icon { font-size: 44px; }
  .dropzone__title { font-size: 22px; }
  .dropzone__hint { font-size: 14px; }

  .thumbs {
    list-style: none; display: grid; gap: 10px;
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    margin-top: 16px;
  }
  .thumb-item {
    position: relative; aspect-ratio: 1; border-radius: var(--r-sm);
    overflow: hidden; border: 1.5px solid var(--c-stroke-light);
  }
  .thumb-item img { width: 100%; height: 100%; object-fit: cover; }
  .thumb-item__remove {
    position: absolute; top: 4px; right: 4px;
    width: 26px; height: 26px; border-radius: 50%;
    background: rgba(0,0,0,.65); color: white; border: 0; cursor: pointer;
    font-size: 16px; line-height: 1;
  }

  .status { font-size: 14px; min-height: 1.4em; margin: 12px 0; text-align: center; }

  .upload__tips { padding: 24px; border-left: 1px solid var(--c-stroke-light); }
  @media (max-width: 899px) {
    .upload__tips { border-left: 0; padding: 16px 0; border-top: 1px solid var(--c-stroke-light); }
  }
  .tips { list-style: none; display: flex; flex-direction: column; gap: 12px; margin-top: 16px; }
  .tips li { display: flex; gap: 12px; align-items: center; color: var(--c-text); }
  .tick {
    flex-shrink: 0; width: 24px; height: 24px; border-radius: 50%; background: var(--c-pink);
    color: white; display: inline-flex; align-items: center; justify-content: center; font-size: 13px;
  }
</style>
