---
const path = Astro.url.pathname;
---

<nav class="nav">
  <div class="container nav__inner">
    <a href="/" class="logo">
      <span class="logo__paw">🐾</span>
      <span class="logo__text">Purrtraits</span>
    </a>

    <div class="nav__links">
      <a href="/#how" class:list={["nav__link", { active: path === "/" }]}>How it works</a>
      <a href="/gallery" class:list={["nav__link", { active: path === "/gallery" }]}>My gallery</a>
      <a href="/upload" class="btn btn--primary nav__cta" id="nav-create-cta">Create Portrait</a>
    </div>

    <div class="nav__right">
      <!-- Auth widget: replaced at runtime once we know the user's state.
           Hidden until the script runs so we don't flash "Sign in" for a
           returning authed user, or "Account" for a fresh anonymous one. -->
      <div class="nav__auth" id="nav-auth" hidden></div>
      <a href="/cart" class="nav__cart" id="nav-cart" aria-label="Cart" hidden>
        <span class="nav__cart-icon">🛒</span>
        <span class="nav__cart-badge" id="nav-cart-badge" hidden>0</span>
      </a>
      <button class="nav__menu" aria-label="Menu" id="nav-menu-btn">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<style>
  .nav {
    background: var(--c-cream);
    border-bottom: 1.5px solid var(--c-stroke-light);
    position: sticky; top: 0; z-index: 50;
  }
  .nav__inner {
    display: flex; align-items: center; justify-content: space-between;
    height: 64px;
  }
  .logo {
    display: flex; align-items: center; gap: 8px;
    font-family: var(--font-display); font-size: 28px; font-weight: 700; color: var(--c-dark);
  }
  .logo__paw {
    width: 32px; height: 32px; border-radius: 50%; background: var(--c-pink);
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 18px;
  }
  .nav__links { display: none; align-items: center; gap: 28px; }
  .nav__links.is-open {
    display: flex; flex-direction: column; align-items: flex-start; gap: 0;
    position: absolute; top: 64px; left: 0; right: 0;
    background: var(--c-cream); border-bottom: 1.5px solid var(--c-stroke-light);
    padding: 12px 0; z-index: 49;
  }
  .nav__links.is-open .nav__link {
    width: 100%; padding: 12px 20px;
  }
  .nav__links.is-open .nav__cta {
    margin: 8px 20px 4px;
  }
  .nav__link { font-family: var(--font-display); font-size: 17px; color: var(--c-text); }
  .nav__link:hover { color: var(--c-dark); }
  .nav__cta { padding: 8px 18px; font-size: 16px; }

  .nav__right {
    display: flex; align-items: center; gap: 12px;
  }
  .nav__cart {
    position: relative;
    width: 38px; height: 38px; border-radius: 50%;
    border: 1.5px solid var(--c-stroke-light);
    display: inline-flex; align-items: center; justify-content: center;
    background: transparent; transition: border-color .15s ease, transform .08s ease;
    isolation: isolate;
  }
  /* The explicit display: inline-flex above otherwise wins over [hidden]'s
     default `display: none`, leaving the cart icon visible while signed out. */
  .nav__cart[hidden] { display: none; }
  .nav__cart:hover { border-color: var(--c-stroke); transform: translateY(-1px); }
  .nav__cart-icon { position: relative; z-index: 1; font-size: 17px; line-height: 1; }
  .nav__cart-badge {
    position: absolute; top: -5px; right: -5px;
    min-width: 18px; height: 18px; padding: 0 5px;
    border-radius: 100px; background: var(--c-pink); color: white;
    display: inline-flex; align-items: center; justify-content: center;
    font-family: var(--font-body); font-size: 10px; font-weight: 700;
    line-height: 1;
    z-index: 2;
    transform-origin: center;
  }
  .nav__cart::after {
    content: "";
    position: absolute; inset: 0;
    border-radius: 50%;
    background: var(--c-pink-light);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
  }
  .nav__cart.is-bumping::after { animation: cart-pulse 600ms ease-out; }
  .nav__cart.is-bumping .nav__cart-badge { animation: badge-pop 320ms ease-out; }
  @keyframes cart-pulse {
    0%   { opacity: .9; transform: scale(1); }
    100% { opacity: 0;  transform: scale(1.7); }
  }
  @keyframes badge-pop {
    0%   { transform: scale(1); }
    40%  { transform: scale(1.3); }
    100% { transform: scale(1); }
  }

  .nav__menu {
    display: flex; flex-direction: column; gap: 4px;
    background: none; border: 0; cursor: pointer; padding: 8px;
  }
  .nav__menu span {
    display: block; width: 22px; height: 2px; background: var(--c-dark); border-radius: 1px;
  }
  @media (min-width: 768px) {
    .nav__links { display: flex; }
    .nav__links.is-open { position: static; flex-direction: row; padding: 0; border: none; }
    .nav__links.is-open .nav__link { width: auto; padding: 0; }
    .nav__links.is-open .nav__cta { margin: 0; }
    .nav__menu { display: none; }
    .nav__inner { height: 72px; }
  }
</style>

<style is:global>
  /* The auth widget HTML is injected via innerHTML at runtime, so it
     doesn't carry Astro's per-component class hash. These rules need to
     match dynamically-added DOM, hence is:global. */
  .nav__auth { display: inline-flex; align-items: center; }
  .nav__signin {
    font-family: var(--font-display);
    font-size: 16px;
    color: var(--c-text);
    padding: 6px 14px;
    border-radius: 100px;
    border: 1.5px solid var(--c-stroke-light);
    transition: border-color .15s ease, background .15s ease;
  }
  .nav__signin:hover {
    border-color: var(--c-pink);
    background: var(--c-pink-light);
    color: var(--c-dark);
  }

  .nav__account { position: relative; }
  /* <summary> defaults to display:list-item, which renders a disclosure
     triangle via ::marker. Force it back to flex to drop the marker box;
     ::-webkit-details-marker handles older Safari. */
  .nav__account-trigger {
    display: inline-flex; align-items: center; gap: 8px;
    cursor: pointer;
    padding: 4px 10px 4px 4px;
    border-radius: 100px;
    border: 1.5px solid var(--c-stroke-light);
    background: var(--c-white);
    list-style: none;
    transition: border-color .15s ease;
  }
  .nav__account-trigger::-webkit-details-marker,
  .nav__account-trigger::marker { display: none; content: ""; }
  .nav__account[open] .nav__account-trigger,
  .nav__account-trigger:hover { border-color: var(--c-pink); }
  .nav__account-avatar {
    width: 28px; height: 28px; border-radius: 50%;
    background: var(--c-pink); color: white;
    font-family: var(--font-display); font-size: 14px; font-weight: 700;
    display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .nav__account-email {
    font-family: var(--font-body); font-size: 13px; color: var(--c-text);
    max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .nav__account-menu {
    position: absolute; top: calc(100% + 8px); right: 0;
    min-width: 220px;
    background: var(--c-white);
    border: 1.5px solid var(--c-stroke-light);
    border-radius: 12px;
    box-shadow: 0 6px 20px rgba(0,0,0,.08);
    padding: 14px;
    display: flex; flex-direction: column; gap: 10px;
    z-index: 60;
  }
  .nav__account-meta {
    font-size: 13px; color: var(--c-light); line-height: 1.4; margin: 0;
  }
  .nav__account-meta strong {
    color: var(--c-dark); font-weight: 600;
    word-break: break-all;
  }
  .nav__account-link {
    font-family: inherit; font-size: 14px; color: var(--c-dark);
    padding: 8px 14px; border-radius: 100px;
    background: var(--c-white); border: 1.5px solid var(--c-stroke-light);
    text-align: center;
    transition: background .15s ease, border-color .15s ease;
  }
  .nav__account-link:hover { background: var(--c-pink-light); border-color: var(--c-pink); }

  .nav__account-signout {
    font-family: inherit; font-size: 14px;
    padding: 8px 14px; border-radius: 100px;
    background: var(--c-fill); border: 1.5px solid var(--c-stroke-light);
    cursor: pointer;
    transition: background .15s ease, border-color .15s ease;
  }
  .nav__account-signout:hover { background: var(--c-pink-light); border-color: var(--c-pink); }

  @media (max-width: 600px) {
    .nav__account-email { display: none; }
  }
</style>

<script>
  import { makeClient, getSessionId } from "../lib/client.ts";
  import {
    isSignedIn,
    makeAuthedClient,
    clearAuthLocalStorage,
  } from "../lib/authStorage.ts";
  import { setUserId } from "../lib/analytics.ts";
  import { api } from "../../convex/_generated/api.js";

  const btn = document.getElementById('nav-menu-btn');
  const links = btn?.closest('nav')?.querySelector('.nav__links');
  btn?.addEventListener('click', () => {
    links?.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', String(links?.classList.contains('is-open')));
  });
  links?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      links.classList.remove('is-open');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });

  // Cart icon is only shown to signed-in users — reveal it here before
  // wiring the live badge so the icon and its counter appear together.
  const cartLink = document.getElementById('nav-cart') as HTMLAnchorElement | null;
  if (cartLink && isSignedIn()) cartLink.hidden = false;

  // Live cart badge — subscribes to api.cart.count so add/remove on any tab
  // is reflected without a page reload.
  const badge = document.getElementById('nav-cart-badge') as HTMLElement | null;
  const sessionId = getSessionId();
  if (badge && sessionId && isSignedIn()) {
    const client = makeClient();
    // Sentinel — the first callback delivers the existing count on page
    // load and shouldn't animate; only subsequent increases should.
    let previousCount = -1;
    if (cartLink) {
      cartLink.addEventListener('animationend', () => {
        cartLink.classList.remove('is-bumping');
      });
    }
    client.onUpdate(api.cart.count, { sessionId: sessionId as any }, (n: number) => {
      if (n > 0) {
        badge.hidden = false;
        badge.textContent = String(n);
      } else {
        badge.hidden = true;
      }
      if (previousCount >= 0 && n > previousCount && cartLink) {
        // Force reflow so re-adding the class restarts the animation
        // when items are added in quick succession.
        cartLink.classList.remove('is-bumping');
        void cartLink.offsetWidth;
        cartLink.classList.add('is-bumping');
      }
      previousCount = n;
    });
  }

  // "Create Portrait" CTA gating — when a signed-in user has used all
  // 3 generations, point them at their gallery to complete a purchase
  // (which resets the budget) instead of dropping them into a flow that
  // will dead-end at the generate step.
  const createCta = document.getElementById('nav-create-cta') as HTMLAnchorElement | null;
  if (createCta && isSignedIn()) {
    const authedForCta = makeAuthedClient();
    authedForCta
      .query(api.sessions.getMyRegensRemaining, {})
      .then((remaining) => {
        if ((remaining ?? 0) <= 0) {
          createCta.href = '/gallery';
          createCta.textContent = 'View my gallery';
        }
      })
      .catch(() => { /* leave CTA as default */ });
  }

  // Auth widget — vanilla so the nav stays free of React. Renders one of:
  //   - "Sign in" link (anonymous)
  //   - email + sign-out button (authed)
  // Looks at the JWT in localStorage written by the React island on
  // /sign-up, then verifies via api.users.me to pick up the email/avatar.
  const authEl = document.getElementById('nav-auth') as HTMLElement | null;
  if (authEl) {
    if (!isSignedIn()) {
      // Anonymous: link to /sign-up with the current path as ?next= so the
      // user comes back where they were once they sign in.
      const next = encodeURIComponent(window.location.pathname + window.location.search);
      authEl.innerHTML = `<a href="/sign-up?next=${next}" class="nav__signin">Sign in</a>`;
      authEl.hidden = false;
    } else {
      const client = makeAuthedClient();
      client
        .query(api.users.me, {})
        .then((me) => {
          if (!me) {
            // JWT present but server says no user — token may be stale.
            // Treat as anonymous for the UI; sign-out call would fail.
            clearAuthLocalStorage();
            const next = encodeURIComponent(window.location.pathname + window.location.search);
            authEl.innerHTML = `<a href="/sign-up?next=${next}" class="nav__signin">Sign in</a>`;
            authEl.hidden = false;
            return;
          }
          // Push the resolved Convex userId into the dataLayer on every
          // authed page load so GA4 can stitch sessions to a stable id.
          if (me._id) setUserId(String(me._id));
          const display = me.email ?? me.name ?? "Account";
          authEl.innerHTML = `
            <details class="nav__account">
              <summary class="nav__account-trigger" aria-label="Account menu">
                <span class="nav__account-avatar" aria-hidden="true">${display.slice(0, 1).toUpperCase()}</span>
                <span class="nav__account-email">${display}</span>
              </summary>
              <div class="nav__account-menu" role="menu">
                <p class="nav__account-meta">Signed in as<br/><strong>${display}</strong></p>
                <a href="/orders" class="nav__account-link" role="menuitem">My orders</a>
                <button class="nav__account-signout" id="nav-signout">Sign out</button>
              </div>
            </details>
          `;
          authEl.hidden = false;
          document
            .getElementById('nav-signout')
            ?.addEventListener('click', async () => {
              try {
                // Server-side: invalidate the auth session/refresh token so
                // a stolen JWT can't outlive its window of usefulness.
                await client.action(api.auth.signOut, {});
              } catch {
                // Best-effort: even if the server call fails (e.g. expired
                // token), nuking local tokens is enough for the UX.
              }
              clearAuthLocalStorage();
              window.location.href = '/';
            });
        })
        .catch(() => {
          // Network blip / token issue — fall back to the signed-out CTA
          // rather than blank space.
          const next = encodeURIComponent(window.location.pathname + window.location.search);
          authEl.innerHTML = `<a href="/sign-up?next=${next}" class="nav__signin">Sign in</a>`;
          authEl.hidden = false;
        });
    }
  }
</script>
