---
// Fig. — Phone camera settings panel. Shows a stylised phone-camera
// HUD with four toggles annotated: FOCUS LOCK · ON, EXPOSURE LOCK ·
// ON, PORTRAIT MODE · OFF, FLASH · OFF. Each toggle has a
// PASS/FAIL tag.
---

<svg viewBox="0 0 900 280" style="width:100%; display:block; height:auto;" aria-hidden="true">
  {/* phone bezel */}
  <rect x="280" y="20" width="340" height="240" rx="22" fill="#2D1F1A" />
  {/* screen */}
  <rect x="296" y="36" width="308" height="208" rx="10" fill="#3D2E22" />

  {/* viewfinder content: dog silhouette */}
  <g transform="translate(450, 130)">
    <ellipse cx="0" cy="36" rx="60" ry="20" fill="#8A6850" />
    <ellipse cx="-10" cy="6" rx="24" ry="22" fill="#8A6850" />
    <path d="M -32 -16 L -36 -32 L -18 -6 Z M 6 -16 L 10 -32 L -10 -6 Z" fill="#8A6850" />
    <circle cx="-18" cy="6" r="2" fill="#fff" />
    <circle cx="-6" cy="6" r="2" fill="#fff" />
  </g>

  {/* focus box (locked) */}
  <rect x="412" y="100" width="76" height="76" fill="none" stroke="#6FA877" stroke-width="1.5" />
  <text x="450" y="92" font-family="ui-monospace, Menlo, Consolas, monospace" font-size="9" fill="#6FA877" font-weight="700" text-anchor="middle">AE / AF LOCK</text>

  {/* settings row at top of screen */}
  <g transform="translate(310, 50)">
    {[
      ["FLASH", "OFF", "#6FA877"],
      ["HDR", "AUTO", "#6FA877"],
      ["LIVE", "OFF", "#6FA877"],
      ["PORTRAIT", "OFF", "#6FA877"],
    ].map(([k, v, c], i) => (
      <g transform={`translate(${i * 70}, 0)`}>
        <rect x="0" y="0" width="64" height="16" rx="3" fill="rgba(0,0,0,0.4)" />
        <text x="32" y="12" font-family="ui-monospace, Menlo, Consolas, monospace" font-size="8" fill={c} font-weight="700" text-anchor="middle">{k} · {v}</text>
      </g>
    ))}
  </g>

  {/* shutter button */}
  <circle cx="450" cy="222" r="14" fill="none" stroke="#fff" stroke-width="2" />
  <circle cx="450" cy="222" r="9" fill="#fff" />

  {/* call-outs on the left */}
  <g transform="translate(40, 70)">
    {[
      ["FOCUS LOCK", "Tap-and-hold the dog's eye", "#6FA877", "PASS"],
      ["EXPOSURE LOCK", "Pulls the slider down for dark coats", "#6FA877", "PASS"],
    ].map(([k, d, c, s], i) => (
      <g transform={`translate(0, ${i * 60})`}>
        <text x="0" y="0" font-family="ui-monospace, Menlo, Consolas, monospace" font-size="11" fill={c} font-weight="700">{k} · {s}</text>
        <text x="0" y="16" font-family="DM Sans, sans-serif" font-size="11" fill="#8A7766">{d}</text>
        <line x1="170" y1="-4" x2="276" y2="40" stroke={c} stroke-width="1" stroke-dasharray="3 3" />
      </g>
    ))}
  </g>
  <g transform="translate(640, 70)">
    {[
      ["FLASH", "Off, always", "#C8826E", "OFF"],
      ["PORTRAIT MODE", "Fake blur softens the dog's edge", "#C8826E", "OFF"],
    ].map(([k, d, c, s], i) => (
      <g transform={`translate(0, ${i * 60})`}>
        <text x="0" y="0" font-family="ui-monospace, Menlo, Consolas, monospace" font-size="11" fill={c} font-weight="700" text-anchor="end" transform="translate(180, 0)">{k} · {s}</text>
        <text x="0" y="16" font-family="DM Sans, sans-serif" font-size="11" fill="#8A7766" text-anchor="end" transform="translate(180, 16)">{d}</text>
        <line x1="0" y1="-4" x2="-50" y2="40" stroke={c} stroke-width="1" stroke-dasharray="3 3" transform="translate(180, 0)" />
      </g>
    ))}
  </g>
</svg>
