---
// Fig. — Multiple angles. Overhead plan view: a dog in the centre
// and five camera positions arrayed around it — front, two
// three-quarters, side profile, behind. The first four are PASS
// (highlighted), the rear is FAIL (a back-of-head is rarely useful).
---

<svg viewBox="0 0 900 320" style="width:100%; display:block; height:auto;" aria-hidden="true">
  {/* arena */}
  <circle cx="450" cy="160" r="130" fill="#F2EBE0" stroke="#C4A882" stroke-width="1" stroke-dasharray="3 3" />

  {/* dog (overhead) — nose pointing up */}
  <g transform="translate(450, 160)">
    <ellipse cx="0" cy="0" rx="22" ry="36" fill="#5C4A3F" />
    <circle cx="0" cy="-22" r="14" fill="#5C4A3F" />
    <circle cx="0" cy="-34" r="3" fill="#2D1F1A" />
    <text x="0" y="56" font-family="ui-monospace, Menlo, Consolas, monospace" font-size="9" fill="#8A7766" text-anchor="middle">DOG</text>
  </g>

  {/* camera positions */}
  {[
    { label: "FRONT", n: "01", color: "#6FA877", x: 0, y: -160, angle: 0 },
    { label: "3/4 LEFT", n: "02", color: "#6FA877", x: -120, y: -100, angle: -36 },
    { label: "PROFILE", n: "03", color: "#6FA877", x: -160, y: 30, angle: -78 },
    { label: "3/4 RIGHT", n: "04", color: "#6FA877", x: 120, y: -100, angle: 36 },
    { label: "BEHIND — SKIP", n: "—", color: "#C8826E", x: 0, y: 160, angle: 180 },
  ].map(({ label, n, color, x, y }) => {
    const cx = 450 + x;
    const cy = 160 + y;
    return (
      <g>
        {/* sight line to dog */}
        <line x1={cx} y1={cy} x2={450} y2={160} stroke={color} stroke-width="1" stroke-dasharray={color === "#C8826E" ? "4 3" : "0"} opacity="0.7" />
        {/* camera dot */}
        <rect x={cx - 14} y={cy - 9} width="28" height="18" rx="3" fill={color} />
        <circle cx={cx} cy={cy} r="5" fill="#fff" />
        {/* number badge */}
        <circle cx={cx + 18} cy={cy - 16} r="9" fill={color} stroke="#2D1F1A" stroke-width="0.6" />
        <text x={cx + 18} y={cy - 13} font-family="ui-monospace, Menlo, Consolas, monospace" font-size="9" fill="#fff" font-weight="700" text-anchor="middle">{n}</text>
        {/* label */}
        <text x={cx} y={cy + (y > 0 ? 30 : -18)} font-family="ui-monospace, Menlo, Consolas, monospace" font-size="10" fill={color} font-weight="700" text-anchor="middle">{label}</text>
      </g>
    );
  })}

  {/* legend on right */}
  <g transform="translate(720, 80)">
    <text x="0" y="0" font-family="ui-monospace, Menlo, Consolas, monospace" font-size="10" fill="#2D1F1A" font-weight="700">SEND 3–5 FRAMES</text>
    <text x="0" y="22" font-family="DM Sans, sans-serif" font-size="11" fill="#8A7766">01 · the look</text>
    <text x="0" y="40" font-family="DM Sans, sans-serif" font-size="11" fill="#8A7766">02 · the form</text>
    <text x="0" y="58" font-family="DM Sans, sans-serif" font-size="11" fill="#8A7766">03 · the muzzle</text>
    <text x="0" y="76" font-family="DM Sans, sans-serif" font-size="11" fill="#8A7766">04 · the other side</text>
    <text x="0" y="98" font-family="DM Sans, sans-serif" font-size="11" fill="#C8826E">— no back-of-head</text>
  </g>
</svg>
