---
// Fig. — Exposure for a black coat. Three vignettes, each with a
// dog silhouette + a tone-strip histogram below: UNDER (silhouette,
// detail lost), CORRECT (separation, fur visible), OVER (eyes
// blown, blacks turn grey). The histogram bars cluster differently
// in each.
---

<svg viewBox="0 0 900 270" style="width:100%; display:block; height:auto;" aria-hidden="true">
  {[
    { label: "UNDER — FAIL", color: "#C8826E", note: "black coat dissolves", bg: "#1A1410", fg: "#3A2A20", hist: [0, 0, 0, 2, 8, 14, 4, 0, 0, 0] },
    { label: "+1 EV — PASS", color: "#6FA877", note: "fur reads, eyes alive", bg: "#3D2E22", fg: "#7A5A40", hist: [0, 0, 2, 6, 10, 8, 6, 4, 2, 0] },
    { label: "OVER — FAIL", color: "#C8826E", note: "blacks turn grey, eyes blown", bg: "#7A6850", fg: "#A88860", hist: [0, 0, 0, 0, 2, 4, 8, 12, 6, 2] },
  ].map(({ label, color, note, bg, fg, hist }, i) => {
    const x = 30 + i * 290;
    const y = 20;
    const w = 250;
    const h = 150;
    const cx = x + w / 2;
    const cy = y + h * 0.55;
    return (
      <g>
        {/* vignette */}
        <rect x={x} y={y} width={w} height={h} fill={bg} stroke={color} stroke-width="2" />
        {/* dog silhouette */}
        <g transform={`translate(${cx}, ${cy})`}>
          <ellipse cx="0" cy="22" rx="44" ry="16" fill={fg} />
          <ellipse cx="-8" cy="-2" rx="20" ry="18" fill={fg} />
          <path d="M -28 -18 L -32 -32 L -16 -10 Z M 4 -18 L 8 -32 L -8 -10 Z" fill={fg} />
          {/* eye highlights */}
          {i !== 0 && <circle cx="-14" cy="-2" r={i === 2 ? 2.4 : 1.5} fill="#fff" />}
          {i !== 0 && <circle cx="-2" cy="-2" r={i === 2 ? 2.4 : 1.5} fill="#fff" />}
        </g>

        {/* histogram */}
        <g transform={`translate(${x}, ${y + h + 14})`}>
          <rect x="0" y="0" width={w} height="42" fill="#fff" stroke="#C4A882" stroke-width="0.6" />
          {hist.map((v, k) => (
            <rect x={4 + k * ((w - 8) / hist.length)} y={42 - v * 2} width={(w - 8) / hist.length - 2} height={v * 2} fill={color} opacity="0.85" />
          ))}
        </g>

        <text x={cx} y={y + h + 76} font-family="ui-monospace, Menlo, Consolas, monospace" font-size="11" fill={color} font-weight="700" text-anchor="middle">{label}</text>
        <text x={cx} y={y + h + 90} font-family="DM Sans, sans-serif" font-size="10" fill="#8A7766" text-anchor="middle">{note}</text>
      </g>
    );
  })}
</svg>
