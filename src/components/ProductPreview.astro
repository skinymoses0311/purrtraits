---
// Renders a realistic product mockup of an artwork URL, styled per format.
// Pure CSS — no Gelato API call required.
//
// Aspect-ratio handling:
//   The Gelato products we sell are 3:4 portrait, but Nano Banana's edit
//   endpoint doesn't expose an aspect_ratio parameter and tends to return
//   ~4:5 or 1:1 outputs depending on the input photos. Rather than forcing
//   a hard crop into 3:4 (which lopped the sides off the artwork and any
//   signatures within it), we let the artwork itself dictate the preview's
//   aspect ratio and have the frame wrap snugly around it. The actual print
//   on Gelato may be subtly cropped or letterboxed by their pre-print step
//   if the source isn't 3:4 — that's a separate concern for fulfilment.
//
// Carousel:
//   For physical formats the preview becomes a multi-slide carousel: slide 0
//   is the live CSS mockup of the customer's portrait, slides 1+ are real
//   lifestyle/detail photographs of the product. Slide counts per format
//   live in SLIDE_COUNTS in the script below. Controls are hidden for the
//   digital format and the carousel auto-resets to slide 0 whenever the
//   format changes.
---

<figure class="pp" id="product-preview" data-slide="0">
  <div class="pp__viewport">
    <button type="button" class="pp__nav pp__nav--prev" id="pp-prev" aria-label="Previous mockup">‹</button>
    <button type="button" class="pp__nav pp__nav--next" id="pp-next" aria-label="Next mockup">›</button>

    <div class="pp__slide pp__slide--mockup" data-slide="0">
      <div class="pp__stage">
        <div class="pp__frame">
          <div class="pp__mat">
            <div class="pp__canvas-wrap">
              <img id="pp-img" alt="Your portrait" class="pp__art protected-img" />
              <div class="pp__glass"></div>
            </div>
          </div>
        </div>
        <div class="pp__shadow"></div>
      </div>
    </div>

    <div class="pp__slide pp__slide--photo" data-photo-format="framed" data-slide="1">
      <img src="/frame-mockups/gallery-natural.jpg" alt="Gallery wall of natural-wood framed prints in a styled bedroom" class="pp__photo" loading="lazy" />
    </div>
    <div class="pp__slide pp__slide--photo" data-photo-format="framed" data-slide="2">
      <img src="/frame-mockups/gallery-white.jpg" alt="Gallery wall of framed prints above a sideboard" class="pp__photo" loading="lazy" />
    </div>
    <div class="pp__slide pp__slide--photo" data-photo-format="framed" data-slide="3">
      <img src="/frame-mockups/frame-corner-detail.jpg" alt="Close-up showing the natural-wood, dark-wood and black frame finishes" class="pp__photo" loading="lazy" />
    </div>

    <div class="pp__slide pp__slide--photo" data-photo-format="canvas" data-slide="1">
      <img src="/canvas-mockups/canvas-corner-detail.jpg" alt="Close-up of a canvas print corner showing the gallery-wrapped stretched edge" class="pp__photo" loading="lazy" />
    </div>
    <div class="pp__slide pp__slide--photo" data-photo-format="canvas" data-slide="2">
      <img src="/canvas-mockups/canvas-texture.jpg" alt="Close-up showing the woven canvas surface texture and print detail" class="pp__photo" loading="lazy" />
    </div>

    <div class="pp__slide pp__slide--photo" data-photo-format="poster" data-slide="1">
      <img src="/poster-mockups/poster-paper-stock.jpg" alt="Corner of a poster printed on premium 200 gsm matte paper" class="pp__photo" loading="lazy" />
    </div>
    <div class="pp__slide pp__slide--photo" data-photo-format="poster" data-slide="2">
      <img src="/poster-mockups/poster-texture.jpg" alt="Close-up showing the matte paper texture of a printed poster" class="pp__photo" loading="lazy" />
    </div>
  </div>

  <div class="pp__dots" id="pp-dots" role="tablist" aria-label="Mockup carousel"></div>

  <figcaption id="pp-caption" class="muted pp__caption">Preview · scaled down for screen</figcaption>
</figure>

<style>
  .pp {
    margin: 0; padding: 24px 0; display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 16px;
    aspect-ratio: 1 / 1;
    background: var(--c-fill);
    border-radius: var(--r-md); border: 1px solid var(--c-stroke-light);
  }
  /* The framed format casts the heaviest drop shadow (~34px below the frame),
     so we add extra margin under the stage to keep the shadow out of the caption. */
  .pp[data-format="framed"] .pp__stage { margin-bottom: 8px; }

  /* ---- Carousel viewport — wraps the slides + nav arrows. The viewport
     flex-grows inside the square figure so the slide area is whatever
     vertical space is left after the dots + caption row. Spans full width
     of .pp (no horizontal padding) so the nav arrows sit at the same
     horizontal offset on both slide types. ---- */
  .pp__viewport {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    flex: 1;
    min-height: 0;
  }

  /* Slides: only the active one is visible. Each photo slide is tagged with
     the format it belongs to so canvas/poster don't accidentally show frame
     photos (and vice-versa). */
  .pp__slide { display: none; }
  /* Slide 0 fills the viewport and centers the artwork. The artwork keeps
     its natural aspect ratio — we letterbox the container, not the image. */
  .pp__slide--mockup {
    width: 100%;
    height: 100%;
  }
  .pp[data-slide="0"] .pp__slide--mockup {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pp[data-format="framed"][data-slide="1"] .pp__slide[data-photo-format="framed"][data-slide="1"],
  .pp[data-format="framed"][data-slide="2"] .pp__slide[data-photo-format="framed"][data-slide="2"],
  .pp[data-format="framed"][data-slide="3"] .pp__slide[data-photo-format="framed"][data-slide="3"],
  .pp[data-format="canvas"][data-slide="1"] .pp__slide[data-photo-format="canvas"][data-slide="1"],
  .pp[data-format="canvas"][data-slide="2"] .pp__slide[data-photo-format="canvas"][data-slide="2"],
  .pp[data-format="poster"][data-slide="1"] .pp__slide[data-photo-format="poster"][data-slide="1"],
  .pp[data-format="poster"][data-slide="2"] .pp__slide[data-photo-format="poster"][data-slide="2"] { display: block; }

  /* Photo slides are 1:1 like the source assets — sized by viewport height
     so the square stays square inside the wider-than-tall viewport, with
     the beige panel showing on either side rather than the photo getting
     cover-cropped top/bottom. */
  .pp__slide--photo {
    height: 100%;
    aspect-ratio: 1 / 1;
  }
  .pp__photo {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--r-md);
  }

  /* Photo slides keep .pp's padding + gap intact so the viewport (and the
     nav arrows centered on it) stay at the same vertical position as
     slide 0. Only the decorative background/border is stripped so the
     product photos read as standalone images rather than panel inserts. */
  .pp[data-format="framed"]:not([data-slide="0"]),
  .pp[data-format="canvas"]:not([data-slide="0"]),
  .pp[data-format="poster"]:not([data-slide="0"]) {
    background: transparent;
    border-color: transparent;
  }
  /* Caption only describes the mockup, so hide it on the lifestyle slides.
     visibility: hidden (not display: none) preserves its row so the
     viewport height — and therefore the nav arrow Y — is identical
     across slide types. */
  .pp:not([data-slide="0"]) .pp__caption { visibility: hidden; }

  /* ---- Nav arrows + dots: visible for any physical format. ---- */
  .pp__nav, .pp__dots { display: none; }
  .pp[data-format="framed"] .pp__nav,
  .pp[data-format="canvas"] .pp__nav,
  .pp[data-format="poster"] .pp__nav { display: grid; }
  .pp[data-format="framed"] .pp__dots,
  .pp[data-format="canvas"] .pp__dots,
  .pp[data-format="poster"] .pp__dots { display: flex; }

  .pp__nav {
    position: absolute; top: 50%; transform: translateY(-50%);
    z-index: 2;
    place-items: center;
    width: 36px; height: 36px;
    padding: 0;
    border: 1px solid var(--c-stroke-light);
    border-radius: 50%;
    background: rgba(255,255,255,.9);
    color: var(--c-text);
    font-size: 22px; line-height: 1;
    cursor: pointer;
    transition: background .15s ease, transform .15s ease;
  }
  .pp__nav:hover { background: rgba(255,255,255,1); transform: translateY(-50%) scale(1.05); }
  .pp__nav--prev { left: 8px; }
  .pp__nav--next { right: 8px; }

  .pp__dots {
    justify-content: center; gap: 8px;
  }
  .pp__dot {
    width: 8px; height: 8px;
    padding: 0; border: 0;
    border-radius: 50%;
    background: var(--c-stroke);
    cursor: pointer;
    transition: background .15s ease, transform .15s ease;
  }
  .pp__dot:hover { transform: scale(1.2); }
  .pp[data-slide="0"] .pp__dot[data-dot="0"],
  .pp[data-slide="1"] .pp__dot[data-dot="1"],
  .pp[data-slide="2"] .pp__dot[data-dot="2"],
  .pp[data-slide="3"] .pp__dot[data-dot="3"] {
    background: var(--c-text);
  }

  /* The stage is a width-constrained wrapper. Height adjusts to whatever
     aspect ratio the artwork actually has, so we never crop it. The
     max-height cap keeps super-portrait artworks from overflowing the
     1:1 slide viewport. */
  .pp__stage {
    position: relative;
    width: var(--art-w, 240px);
    max-width: 100%;
    max-height: 100%;
  }

  /* Floor shadow sits below the stage in the figure's flex flow rather than
     overlapping it absolutely — keeps it from creeping into the caption. */
  .pp__shadow {
    position: absolute; left: 50%; bottom: -18px;
    width: 88%; height: 14px; transform: translateX(-50%);
    background: radial-gradient(ellipse at center, rgba(0,0,0,.18), rgba(0,0,0,0) 65%);
    filter: blur(3px); pointer-events: none;
  }

  /* ---- Frame layer (only the "framed" format actually shows it) ---- */
  .pp__frame {
    transition: padding .2s ease, background .2s ease, box-shadow .2s ease;
  }
  .pp[data-format="poster"] .pp__frame {
    padding: 0;
    box-shadow: 0 14px 28px -16px rgba(0,0,0,.25), 0 4px 8px -4px rgba(0,0,0,.15);
  }
  /* Natural wood — warm tan/oak with visible grain. The repeating gradient
     suggests vertical wood-grain striations; the inset shadows form the
     dark rebate line at the print edge plus a subtle chamfered highlight
     just outside it. */
  .pp[data-format="framed"][data-frame="natural-wood"] .pp__frame {
    padding: 6px;
    background:
      repeating-linear-gradient(90deg,
        rgba(165,135,90,0)   0px,
        rgba(165,135,90,.10) 1px,
        rgba(165,135,90,0)   3px,
        rgba(115,85,50,.08)  5px,
        rgba(165,135,90,0)   8px),
      linear-gradient(135deg, #ead7b0 0%, #d8c498 40%, #e2cea3 70%, #c5b182 100%);
    background-color: #d8c498;
    box-shadow:
      inset 0 0 0 1px rgba(90,65,35,.7),
      inset 0 0 0 2px rgba(255,240,210,.15),
      inset 0 0 5px rgba(120,90,55,.22),
      0 14px 26px -14px rgba(0,0,0,.3),
      0 5px 10px -5px rgba(0,0,0,.18);
  }
  /* Dark wood — warm walnut/espresso with reddish-brown undertones and the
     same grain + rebate treatment as the natural variant. */
  .pp[data-format="framed"][data-frame="dark-wood"] .pp__frame {
    padding: 6px;
    background:
      repeating-linear-gradient(90deg,
        rgba(95,60,30,0)   0px,
        rgba(95,60,30,.20) 1px,
        rgba(95,60,30,0)   3px,
        rgba(20,10,5,.18)  5px,
        rgba(95,60,30,0)   8px),
      linear-gradient(135deg, #3a2316 0%, #271610 40%, #3d2618 70%, #1d100a 100%);
    background-color: #2a1810;
    box-shadow:
      inset 0 0 0 1px rgba(0,0,0,.9),
      inset 0 0 0 2px rgba(120,80,50,.18),
      inset 0 0 7px rgba(0,0,0,.5),
      0 14px 26px -14px rgba(0,0,0,.4),
      0 5px 10px -5px rgba(0,0,0,.22);
  }
  .pp[data-format="canvas"] .pp__frame {
    padding: 0;
    box-shadow:
      0 18px 32px -16px rgba(0,0,0,.4),
      0 6px 12px -6px rgba(0,0,0,.2);
  }

  /* ---- Mat board (kept in DOM but not used by any current product —
     real framed prints sit directly inside the frame with no mat). ---- */
  .pp__mat {
    background: transparent;
    padding: 0;
  }

  /* ---- Canvas wrap (chunky 3D edge for canvas products) ---- */
  .pp__canvas-wrap { position: relative; line-height: 0; }
  .pp[data-format="canvas"] .pp__canvas-wrap {
    box-shadow:
      inset 14px 0 12px -10px rgba(0,0,0,.2),
      inset -14px 0 12px -10px rgba(0,0,0,.2),
      inset 0 -10px 14px -10px rgba(0,0,0,.15);
  }

  /* ---- Artwork — natural aspect ratio drives preview height ---- */
  .pp__art {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ---- Glass sheen overlay on framed ---- */
  .pp__glass {
    position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(115deg, rgba(255,255,255,0) 40%, rgba(255,255,255,.18) 50%, rgba(255,255,255,0) 60%);
    opacity: 0; transition: opacity .2s ease;
  }
  .pp[data-format="framed"] .pp__glass { opacity: .8; }

  .pp__caption { font-size: 13px; }
</style>

<script>
  // Carousel wiring. The PDP toggles preview.dataset.format/.frame; we toggle
  // preview.dataset.slide and let CSS handle which slide + dot is highlighted.
  // The carousel resets to slide 0 whenever the format changes, since each
  // format has its own set of photo slides.
  (() => {
    const preview = document.getElementById("product-preview");
    const prev = document.getElementById("pp-prev");
    const next = document.getElementById("pp-next");
    const dots = document.getElementById("pp-dots");
    if (!preview || !prev || !next || !dots) return;

    // Slide 0 is the live mockup; remaining slides are real product photos.
    // Keep this in sync with the photo slides rendered in the markup above.
    const SLIDE_COUNTS: Record<string, number> = {
      framed: 4,
      canvas: 3,
      poster: 3,
    };
    const slideMax = () => SLIDE_COUNTS[preview.dataset.format ?? ""] ?? 1;

    const current = () => parseInt(preview.dataset.slide || "0", 10);
    const setSlide = (i: number) => {
      const max = slideMax();
      const n = ((i % max) + max) % max;
      preview.dataset.slide = String(n);
    };

    const renderDots = () => {
      const max = slideMax();
      dots.innerHTML = "";
      for (let i = 0; i < max; i++) {
        const dot = document.createElement("button");
        dot.type = "button";
        dot.className = "pp__dot";
        dot.dataset.dot = String(i);
        dot.setAttribute(
          "aria-label",
          i === 0 ? "Your portrait mockup" : `Product photo ${i}`,
        );
        dot.addEventListener("click", () => setSlide(i));
        dots.appendChild(dot);
      }
    };

    prev.addEventListener("click", () => setSlide(current() - 1));
    next.addEventListener("click", () => setSlide(current() + 1));

    new MutationObserver(() => {
      preview.dataset.slide = "0";
      renderDots();
    }).observe(preview, { attributes: true, attributeFilter: ["data-format"] });

    renderDots();
  })();
</script>
