---
import "../styles/global.css";
import Nav from "../components/Nav.astro";

interface Props {
  title?: string;
  hideNav?: boolean;
}
const { title = "Purrtraits — Museum-worthy art for your pet", hideNav = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Turn your pet into museum-worthy art. AI portraits in seconds — digital or printed and framed." />
    <!-- ?v=2 forces browsers to refetch when the favicon changes; bump it on
         future favicon updates to skip the aggressive favicon cache. -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5797288699504998"
         crossorigin="anonymous"></script>
    <title>{title}</title>
  </head>
  <body>
    {!hideNav && <Nav />}
    <slot />
  </body>
</html>
