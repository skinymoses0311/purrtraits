---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import SeoMeta from "../components/SeoMeta.astro";

interface Props {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
  hideNav?: boolean;
}
const { title, description, image, noindex, canonical, hideNav = false } = Astro.props;

// GTM container ID is env-driven so staging traffic doesn't pollute the prod
// GA4 / GTM reports. Set PUBLIC_GTM_ID per Vercel environment; leave it unset
// on staging if you don't want any tag firing at all. Ezoic / CMP scripts above
// are left always-on because Ezoic gates ad rendering itself based on the host.
const GTM_ID = import.meta.env.PUBLIC_GTM_ID as string | undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Ezoic: privacy (CMP) scripts must load before the header script and
         before any other ad/consent code. data-cfasync="false" keeps Cloudflare
         from reordering them. -->
    <script is:inline data-cfasync="false" src="https://cmp.gatekeeperconsent.com/min.js"></script>
    <script is:inline data-cfasync="false" src="https://the.gatekeeperconsent.com/cmp.min.js"></script>
    <!-- Ezoic header / standalone init -->
    <script is:inline async src="//www.ezojs.com/ezoic/sa.min.js"></script>
    <script is:inline>
      window.ezstandalone = window.ezstandalone || {};
      ezstandalone.cmd = ezstandalone.cmd || [];
    </script>
    <script is:inline src="//ezoicanalytics.com/analytics.js"></script>
    <SeoMeta {title} {description} {image} {noindex} {canonical}>
      <slot name="jsonld" slot="jsonld" />
    </SeoMeta>
    <!-- ?v=2 forces browsers to refetch when the favicon changes; bump it on
         future favicon updates to skip the aggressive favicon cache. -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
    {GTM_ID && (
      <Fragment>
        <!-- Google Tag Manager -->
        <script is:inline define:vars={{ gtmId: GTM_ID }}>
          (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
          new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
          j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
          'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
          })(window,document,'script','dataLayer',gtmId);
        </script>
        <!-- End Google Tag Manager -->
      </Fragment>
    )}
    <!-- Ezoic: preconnect warms TLS in parallel with HTML parsing. ezojs.com
         serves the async header script (sa.min.js); the Google ad endpoints
         still apply because Ezoic uses AdSense as a demand partner. -->
    <link rel="preconnect" href="https://www.ezojs.com" crossorigin />
    <link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin />
    <link rel="preconnect" href="https://googleads.g.doubleclick.net" crossorigin />
    <style>
      /* Sticky-footer scaffold: body is a column flex container, the main
         <slot> content flexes to fill, and the footer sits below — so on
         short pages (privacy/cookies) the footer doesn't float in the
         middle of the viewport. */
      body { min-height: 100vh; display: flex; flex-direction: column; }
      .layout__main { flex: 1 0 auto; display: flex; flex-direction: column; }
    </style>
  </head>
  <body>
    {GTM_ID && (
      <Fragment>
        <!-- Google Tag Manager (noscript) -->
        <noscript><iframe src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`}
        height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
        <!-- End Google Tag Manager (noscript) -->
      </Fragment>
    )}
    {!hideNav && <Nav />}
    <main class="layout__main">
      <slot />
    </main>
    <Footer />

    <script>
      // Emit a user_data event into the dataLayer on every page load for
      // authed users so GTM/GA4 can stitch sessions to a stable userId. The
      // module decodes the sub claim from the JWT — non-authed visits are a no-op.
      import { getCurrentUserId } from "../lib/authStorage.ts";
      import { setUserId } from "../lib/analytics.ts";
      import { initCmpTracking } from "../lib/cmp.ts";
      const uid = getCurrentUserId();
      if (uid) setUserId(uid);
      initCmpTracking();
    </script>
  </body>
</html>
