# =============================================================================
# STAGING environment — template for local override + Vercel "Production" env
# on the my-app-staging Vercel project.
# =============================================================================
# Copy this file to `.env.staging` if you want to point local tools at staging,
# OR mirror these values into Vercel's project settings (Production scope on
# the staging Vercel project). NEVER commit `.env.staging` itself.
# =============================================================================

# --- Convex (staging deployment: lovely-warthog-649) -------------------------
# Astro reads PUBLIC_CONVEX_URL at build time and ships it to the browser.
PUBLIC_CONVEX_URL=https://lovely-warthog-649.convex.cloud
# Used by Node-side scripts (scripts/upload-artwork-refs.ts etc.)
CONVEX_URL=https://lovely-warthog-649.convex.cloud
# Convex Auth provider audience — must match the staging convex.site URL.
CONVEX_SITE_URL=https://lovely-warthog-649.convex.site
# Vercel-only: required so `npx convex deploy` during the Vercel build pushes
# backend code to the staging deployment. Get from Convex dashboard → Settings
# → Deploy Keys (CI/CD section) for the staging deployment.
CONVEX_DEPLOY_KEY=

# --- Seed-script token (used by scripts/* only) ------------------------------
# Must match the value set on the staging Convex deployment via:
#   npx convex env set ARTWORKS_SEED_TOKEN <uuid>
# Rotate any time — it gates write access to the artworks seed table.
ARTWORKS_SEED_TOKEN=

# --- Analytics --------------------------------------------------------------
# Optional: a *staging* GTM container ID, so staging traffic doesn't pollute
# the production GA4 reports. Leave unset to disable GTM entirely on staging.
PUBLIC_GTM_ID=

# =============================================================================
# Convex deployment env vars — these are NOT read from this file; they are set
# directly on the Convex deployment via `npx convex env set <NAME> <VALUE>`.
# Listed here for documentation only.
# =============================================================================
#
# STRIPE_SECRET_KEY            sk_test_…       (Stripe Dashboard, Test mode)
# STRIPE_WEBHOOK_SECRET        whsec_…         (Stripe webhook for staging URL)
# GELATO_API_KEY               <prod key>      (Gelato has no sandbox — same key
#                                              as prod, scoped to safety by
#                                              GELATO_ORDER_TYPE=draft below)
# GELATO_ORDER_TYPE            draft           (create draft orders so they
#                                              don't auto-print on staging)
# FAL_KEY                      <staging key>   (separate fal sub-key recommended)
# BREVO_API_KEY                <brevo key>
# BREVO_SENDER_EMAIL           staging@purrtraits.shop
# BREVO_SENDER_NAME            Purrtraits (Staging)
# AUTH_GOOGLE_ID               <staging OAuth client id>
# AUTH_GOOGLE_SECRET           <staging OAuth client secret>
# JWT_PRIVATE_KEY              <set automatically by `npx @convex-dev/auth`>
# JWT_PRIVATE_KEY_TYPE         <set automatically by `npx @convex-dev/auth`>
# SITE_URL                     https://staging.purrtraits.shop
# CONVEX_SITE_URL              https://lovely-warthog-649.convex.site
# ARTWORKS_SEED_TOKEN          <UUID — same value as above>
