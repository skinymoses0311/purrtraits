# =============================================================================
# PRODUCTION environment — template for Vercel "Production" env on the live
# my-app Vercel project (the one serving www.purrtraits.shop).
# =============================================================================
# These values mirror what must be set in Vercel project settings → Environment
# Variables → Production scope. NEVER copy them into a checked-in file.
# =============================================================================

# --- Convex (production deployment — slug TBD after `npx convex deploy --prod`)
# Replace <prod-slug> with the deployment slug returned by `npx convex deploy --prod`.
PUBLIC_CONVEX_URL=https://<prod-slug>.convex.cloud
CONVEX_URL=https://<prod-slug>.convex.cloud
CONVEX_SITE_URL=https://<prod-slug>.convex.site
# Vercel-only: required for Vercel build → Convex prod deploy step. Get from
# Convex dashboard → Settings → Deploy Keys (production deployment).
CONVEX_DEPLOY_KEY=

# --- Seed-script token (used by scripts/* only) -----------------------------
# Different value from staging. Generate fresh:  uuidgen
ARTWORKS_SEED_TOKEN=

# --- Analytics --------------------------------------------------------------
PUBLIC_GTM_ID=GTM-MHRPN2P3

# =============================================================================
# Convex deployment env vars — set directly on the production Convex deployment
# via:  npx convex env set <NAME> <VALUE> --prod
# Listed here for documentation only.
# =============================================================================
#
# STRIPE_SECRET_KEY            sk_live_…
# STRIPE_WEBHOOK_SECRET        whsec_…         (Stripe Live-mode webhook)
# GELATO_API_KEY               <production key>
# GELATO_ORDER_TYPE            <unset>         (defaults to "order" — real prints.
#                                              ONLY set this to "draft" on staging.)
# FAL_KEY                      <production key>
# BREVO_API_KEY                <brevo key — paid plan>
# BREVO_SENDER_EMAIL           orders@purrtraits.shop
# BREVO_SENDER_NAME            Purrtraits
# AUTH_GOOGLE_ID               <production OAuth client id — verified>
# AUTH_GOOGLE_SECRET           <production OAuth client secret>
# JWT_PRIVATE_KEY              <set automatically by `npx @convex-dev/auth`>
# JWT_PRIVATE_KEY_TYPE         <set automatically by `npx @convex-dev/auth`>
# SITE_URL                     https://www.purrtraits.shop
# CONVEX_SITE_URL              https://<prod-slug>.convex.site
# ARTWORKS_SEED_TOKEN          <UUID — same value as above>
